---
import AccentScript from "../components/AccentScript.astro";
import Services from "../components/Services.astro";
import Showreel from "../components/Showreel.astro";
import TrustedBrands from "../components/TrustedBrands.astro";
import TargetSegments from "../components/TargetSegments.astro";
import About from "../components/About.astro";
import Portfolio from "../components/Portfolio.astro";
import Testimonials from "../components/Testimonials.astro";
import "../styles/global.css";
import TopSlogan from "../components/TopSlogan.astro";
import PromoBanner from "../components/PromoBanner.astro";
import ProjectsSection from "../components/ProjectsSection.astro";
import ProjectsNavSection from "../components/ProjectsNavSection.astro";
import ShowreelSection from "../components/ShowreelSection.astro";
import BrandsSection from "../components/BrandsSection.astro";
import SegmentsSection from "../components/TargetSegments.astro";
import Hero from "../components/Hero.astro";
import WeGoodAt from "../components/WeGoodAt.astro";
// import ContactSection from "../components/ContactSection.astro";
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <title>easy. production</title>
        <link
            href="https://fonts.googleapis.com/css2?family=Manrope:wght@800&display=swap"
            rel="stylesheet"
        />
    </head>
    <body>
        <header class="main-header">
            <a class="brand-logo" href="/">
                <img
                    src="/photos/logo.svg"
                    alt="easy. production"
                    class="logo-img"
                />
            </a>
        </header>
        <main>
            <Hero />
            <WeGoodAt client:load />
            <ProjectsNavSection />

            <Portfolio />

            <Services />

            <Showreel />

            <TrustedBrands />

            <TargetSegments />

            <Testimonials />

            <!-- Figma-based sections -->
            <TopSlogan />
            <!-- <PromoBanner /> -->
            <!-- <ProjectsSection /> -->
            <ShowreelSection />
            <BrandsSection />

            <!-- <ContactSection /> -->
        </main>
    </body>
    <style>
        :root {
            --font-size-xl: 88px; /* Main headlines */
            --font-size-lg: 42px; /* Section headlines */
            --font-size-md: 32px; /* Sub headlines */
            --font-size-base: 16px; /* Body text */
            --main-padding: 0.6em;
            --main-maxwidth: 1300px;
            --hero-head-size: clamp(2.05rem, 8vw, 3.3rem);
            --hero-tagline-size: clamp(1rem, 1.25vw, 1.11rem);
        }
        .main-header {
            width: 100%;
            display: flex;
            align-items: center;
            padding: 1.2rem 1.1rem 0.4rem 0.8rem;
            background: transparent;
            box-sizing: border-box;
        }
        .main-header .brand-logo {
            text-decoration: none;
            background: transparent;
            border: 0;
            padding: 0;
            line-height: 1.05;
            transition: opacity 0.13s;
        }
        .main-header .brand-logo:focus-visible,
        .main-header .brand-logo:hover {
            opacity: 0.8;
            outline: none;
        }
        .logo-img {
            width: 128px;
            height: auto;
            display: block;
            mix-blend-mode: multiply;
            background: transparent;
        }
        .hero-section {
            width: 100%;
            max-width: var(--main-maxwidth);
            margin: 0 auto 1.35em auto;
            padding: 0 2rem;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            position: relative;
            box-sizing: border-box;
        }
        .hero-text {
            max-width: none;
            padding-right: 0.5em;
            z-index: 1;
            width: 100%;
        }
        .hero-head {
            font-size: var(--font-size-xl);
            position: relative;
            letter-spacing: 0.03em;
            font-family: "Manrope", var(--font-sans);
            font-weight: 800;
            color: var(--brand-red);
            text-transform: uppercase;
            margin: 0 0 0.25em 0;
            line-height: 1.06;
            display: flex;
            flex-direction: column;
            gap: 2rem;
            width: 100%;
        }
        .hero-tagline {
            margin: 1.15em 0 0 0;
            font-size: var(--hero-tagline-size);
            line-height: 1.25;
            letter-spacing: 0.015em;
            color: var(--brand-black);
            max-width: 28ch;
        }
        `` .hero-photo {
            width: 100%;
            max-width: 390px;
            margin-top: 1.2em;
            border-radius: var(--radius);
            background: var(--site-bg);
            box-shadow: 0 4px 32px 0 #0002;
            object-fit: cover;
            aspect-ratio: 4/5;
            display: block;
        }
        .hero-line {
            display: flex;
            align-items: center;
            justify-content: start;
            gap: 1rem;
            width: 100%;
        }
        .hero-line:nth-child(even) {
            flex-direction: row-reverse;
        }
        .hero-line span {
            font-size: var(--font-size-xl);
            flex: 0 1 auto;
        }
        .hero-line-img {
            height: 85px;
            width: auto;
            min-width: 200px;
            object-fit: cover;
        }
        @media (max-width: 768px) {
            :root {
                --font-size-xl: 48px;
                --font-size-lg: 36px;
                --font-size-md: 24px;
                --font-size-base: 16px;
            }
            .hero-line,
            .hero-line:nth-child(even) {
                flex-direction: column;
                align-items: flex-start;
                gap: 1rem;
                margin-bottom: 3rem;
            }
            .hero-line span {
                font-size: var(--font-size-xl);
            }
            .hero-line-img {
                width: 100%;
                height: auto;
                max-height: 85px;
                min-width: unset;
            }
        }
        @media (max-width: 420px) {
            :root {
                --font-size-xl: 42px;
                --font-size-lg: 32px;
                --font-size-md: 21px;
                --font-size-base: 16px;
            }
            .hero-section {
                padding: 0 2rem;
            }
            .hero-text {
                padding-right: 0.1em;
            }
            .hero-photo {
                margin-top: 0.9em;
            }
        }
        .showreel-img {
            width: 100%;
            height: auto;
            margin-top: 4rem;
            object-fit: cover;
        }
        .showreel-heading {
            font-family: "Manrope", var(--font-sans);
            font-weight: 800;
            font-size: var(--font-size-lg);
            color: var(--brand-red);
            text-align: center;
            margin: 2rem 0;
            width: 100%;
        }
        .brands-title,
        .we-cater-title {
            font-size: var(--font-size-lg);
            font-family: "Manrope", var(--font-sans);
            font-weight: 800;
            text-align: center;
            margin-bottom: 2rem;
        }
        .segment-title {
            font-size: var(--font-size-md);
            font-family: "Manrope", var(--font-sans);
            font-weight: 800;
            margin-bottom: 1rem;
        }
        .segment-desc,
        .service-desc {
            font-size: var(--font-size-base);
            line-height: 1.5;
        }
        .service-title {
            font-size: var(--font-size-md);
            font-family: "Manrope", var(--font-sans);
            font-weight: 800;
            margin-bottom: 0.5rem;
        }
    </style>
</html>

<!-- SERVICES/FEATURE CARDS -->
