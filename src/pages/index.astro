---
import Showreel from "../components/Showreel.astro";
import TargetSegments from "../components/TargetSegments.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import Hero from "../components/Hero.astro";
import Header from "../components/Header.astro";
import ExceptionalValue from "../../sections/ExceptionalValue.astro";
import Team from "../components/Team.astro";
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <title>easy. production</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Onest:wght@800&display=swap"
            rel="stylesheet"
        />
    </head>
    <body>
        <main>
            <Header isHomePage={true} />
            <Showreel />
            <Hero />
            <TargetSegments />
            <ExceptionalValue />
            <Team />
        </main>

        <Footer />
    </body>
    <style>
        :root {
            --font-size-xl: 88px; /* Main headlines */
            --font-size-lg: 42px; /* Section headlines */
            --font-size-md: 32px; /* Sub headlines */
            --font-size-base: 16px; /* Body text */
            --main-padding: clamp(1rem, 2.5vw, 2rem);
            --main-maxwidth: 1200px;
            --hero-head-size: clamp(2.05rem, 8vw, 3.3rem);
            --hero-tagline-size: clamp(1rem, 1.25vw, 1.11rem);
        }

        main {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: var(--main-padding);
            max-width: var(--main-maxwidth);
            margin: 0 auto;
            width: 100%;
        }
    </style>
</html>
