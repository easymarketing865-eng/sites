---
import AccentScript from "../components/AccentScript.astro";
import Services from "../components/Services.astro";
import Showreel from "../components/Showreel.astro";
import TrustedBrands from "../components/TrustedBrands.astro";
import TargetSegments from "../components/TargetSegments.astro";
import About from "../components/About.astro";
import Portfolio from "../components/Portfolio.astro";
import Testimonials from "../components/Testimonials.astro";
import "../styles/global.css";
import TopSlogan from "../components/TopSlogan.astro";
import PromoBanner from "../components/PromoBanner.astro";
import ProjectsSection from "../components/ProjectsSection.astro";
import ProjectsNavSection from "../components/ProjectsNavSection.astro";
import ShowreelSection from "../components/ShowreelSection.astro";
import BrandsSection from "../components/BrandsSection.astro";
import SegmentsSection from "../components/TargetSegments.astro";
// import ContactSection from "../components/ContactSection.astro";
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <title>easy. production</title>
        <link
            href="https://fonts.googleapis.com/css2?family=Manrope:wght@800&display=swap"
            rel="stylesheet"
        />
    </head>
    <body>
        <header class="main-header">
            <!-- <img src="photos/headshot.webp" /> -->
            <a class="brand-logo" href="/">easy production</a>
        </header>
        <main>
            <section class="hero-section">
                <div class="hero-text">
                    <h1 class="hero-head headline">
                        <div class="hero-line">
                            <span>STUNNING</span>
                            <img src="/photos/stunning.jpg" alt="Stunning visual" class="hero-line-img" />
                        </div>
                        <div class="hero-line">
                            <img src="/photos/affordable.jpg" alt="Affordable production" class="hero-line-img" />
                            <span>AFFORDABLE</span>
                        </div>
                        <div class="hero-line">
                            <span>PRODUCTIONS</span>
                            <img src="/photos/productions.jpg" alt="Production scene" class="hero-line-img" />
                        </div>
                        <div class="hero-line">
                            <span>FROM CENTRAL ASIA</span>
                            
                        </div>
                    </h1>
                    <img src="/photos/showreel.jpg" alt="Showreel" class="showreel-img" />
                    <h1 class="showreel-heading">Where stories meet the wild.</h1>
                </div>
            </section>

            <Services />

            <Showreel />

            <TrustedBrands />

            <TargetSegments />

            <Portfolio />

            <Testimonials />

            <!-- Figma-based sections -->
            <TopSlogan />
            <PromoBanner />
            <ProjectsSection />
            <ProjectsNavSection />
            <ShowreelSection />
            <BrandsSection />
            <SegmentsSection />
            <!-- <ContactSection /> -->
        </main>
    </body>
    <style>
        :root {
            --hero-head-size: clamp(2.05rem, 8vw, 3.3rem);
            --main-padding: 0.6em;
            --main-maxwidth: 1300px;
            --hero-tagline-size: clamp(1rem, 1.25vw, 1.11rem);
        }
        .main-header {
            width: 100%;
            display: flex;
            align-items: center;
            padding: 1.2rem 1.1rem 0.4rem 0.8rem;
            background: transparent;
            box-sizing: border-box;
        }
        .main-header .brand-logo {
            font-size: 1.11rem;
            font-weight: 900;
            letter-spacing: 0.08em;
            /* text-transform: lowercase; */
            color: var(--brand-red);
            text-decoration: none;
            background: none;
            border: 0;
            padding: 0;
            font-family: var(--font-sans);
            line-height: 1.05;
            transition: color 0.13s;
        }
        .main-header .brand-logo:focus-visible,
        .main-header .brand-logo:hover {
            color: #c81111;
            outline: none;
            text-decoration: underline;
        }

        .hero-section {
            width: 100%;
            max-width: var(--main-maxwidth);
            margin: 0 auto 1.35em auto;
            padding: 0 var(--main-padding);
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            position: relative;
            box-sizing: border-box;
        }
        .hero-text {
            max-width: none;
            padding-right: 0.5em;
            z-index: 1;
            width: 100%;
        }
        .hero-head {
            font-size: 88px;
            position: relative;
            letter-spacing: 0.03em;
            font-family: 'Manrope', var(--font-sans);
            font-weight: 800;
            color: var(--brand-red);
            text-transform: uppercase;
            margin: 0 0 0.25em 0;
            line-height: 1.06;
            display: flex;
            flex-direction: column;
            gap: 2rem;
            width: 100%;
        }
        .hero-tagline {
            margin: 1.15em 0 0 0;
            font-size: var(--hero-tagline-size);
            line-height: 1.25;
            letter-spacing: 0.015em;
            color: var(--brand-black);
            max-width: 28ch;
        }
        .hero-photo {
            width: 100%;
            max-width: 390px;
            margin-top: 1.2em;
            border-radius: var(--radius);
            background: #eee;
            box-shadow: 0 4px 32px 0 #0002;
            object-fit: cover;
            aspect-ratio: 4/5;
            display: block;
        }
        .hero-line {
            display: flex;
            align-items: center;
            gap: 2rem;
            margin-bottom: 1rem;
            width: 100%;

        }
        .hero-line span {
            font-size: 88px;
        }
        .hero-line-img {
            height: 85px;
            width: auto;
            object-fit: cover;
            border-radius: 8px;
        }
        @media (max-width: 768px) {
            .hero-line {
                flex-direction: column;
                align-items: flex-start;
                gap: 1rem;
            }
            .hero-line span {
                font-size: 48px;
            }
            .hero-line-img {
                width: 100%;
                height: auto;
                max-height: 85px;
            }
        }
        @media (max-width: 420px) {
            .hero-section {
                padding: 0 0.5em;
            }
            .hero-text {
                padding-right: 0.1em;
            }
            .hero-photo {
                margin-top: 0.9em;
            }
        }
        .showreel-img {
            width: 100%;
            height: auto;
            margin-top: 4rem;
            border-radius: 12px;
            object-fit: cover;
        }
        .showreel-heading {
            font-family: 'Manrope', var(--font-sans);
            font-weight: 800;
            font-size: 48px;
            color: var(--brand-red);
            text-align: center;
            margin: 2rem 0;
            width: 100%;
        }
    </style>
</html>

<!-- SERVICES/FEATURE CARDS -->
<section class="services-section">
    <div class="services-row">
        <div class="service-card">
            <div class="service-icon service-icon-creative"></div>
            <div class="service-title">Ycayzu</div>
            <div class="service-desc">Creative Direction</div>
        </div>
        <div class="service-card">
            <div class="service-icon service-icon-brand"></div>
            <div class="service-title">Brand</div>
            <div class="service-desc">Brand Strategy</div>
        </div>
        <div class="service-card">
            <div class="service-icon service-icon-script"></div>
            <div class="service-title">Script Writing</div>
            <div class="service-desc">Story &amp; Scripting</div>
        </div>
        <div class="service-card">
            <div class="service-icon service-icon-broadcast"></div>
            <div class="service-title">Broadcast &amp; Creativity</div>
            <div class="service-desc">Media &amp; Production</div>
        </div>
    </div>
</section>

<!-- SHOWREEL SECTION (Placeholder) -->
<section class="showreel-section">
    <div class="showreel-background">
        <AccentScript
            text="production, creativity, direction, editing, filming, quality, Kyrgyzstan, Dubai, visuals, documentary, brand, campaign, crew, global, unique, storytelling"
            style="left:2vw;top:0.2em;font-size:1.08rem;opacity:0.15;position:absolute;z-index:1;"
        />
    </div>
    <div class="showreel-content">
        <div class="showreel-video-placeholder">
            <span>Showreel Video Coming Soon</span>
        </div>
        <div class="showreel-facts">
            <div class="showreel-fact">
                <strong>Gear:</strong> ARRI, RED, Drone
            </div>
            <div class="showreel-fact"><strong>Scripts:</strong> 100+</div>
            <div class="showreel-fact">
                <strong>Locations:</strong> 3+ countries
            </div>
        </div>
    </div>
</section>

<!-- TRUSTED BRANDS GRID -->
<section class="brands-section">
    <h2 class="brands-title">Best Brands Trust Us</h2>
    <div class="brands-grid">
        <div class="brand-logo brand1">Demir Bank</div>
        <div class="brand-logo brand2">Asia Store</div>
        <div class="brand-logo brand3">Elizaveta Real Estate</div>
        <div class="brand-logo brand4">MENIKI</div>
        <div class="brand-logo brand5">Red Petrolium</div>
        <div class="brand-logo brand6">Fashion</div>
        <div class="brand-logo brand7">VILAR</div>
        <div class="brand-logo brand8">VITALIN</div>
    </div>
</section>

<!-- WE CATER TO (TARGET SEGMENTS) -->
<section class="we-cater-section">
    <h2 class="we-cater-title">We Cater To</h2>
    <div class="segments-columns">
        <div class="segment-column">
            <div class="segment-title">Independent Filmmakers</div>
            <div class="segment-desc">
                High production value, unique aesthetics, cost-effective,
                creative, striking Kyrgyz locations.
            </div>
        </div>
        <div class="segment-column">
            <div class="segment-title">Advertising Agencies</div>
            <div class="segment-desc">
                Reliable, creative, cost-efficient partner, professional
                standards, deadlines, concept-to-visuals.
            </div>
        </div>
        <div class="segment-column">
            <div class="segment-title">Brands</div>
            <div class="segment-desc">
                Direct-to-brand work, high-quality marketing videos,
                commercials, brand stories, exceptional value.
            </div>
        </div>
        <div class="segment-column">
            <div class="segment-title">
                Companies Needing Crews in Central Asia
            </div>
            <div class="segment-desc">
                Local expertise, established network, regional logistics.
            </div>
        </div>
        <div class="segment-column">
            <div class="segment-title">International Productions</div>
            <div class="segment-desc">
                Proven ability to execute abroad, adaptable team, quality/cost
                model, ready to travel.
            </div>
        </div>
    </div>
</section>
