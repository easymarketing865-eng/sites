---
/**
 * Contact Page - English Version
 * Comprehensive contact page with team story and multiple contact options
 */
import Layout from "../layouts/Layout.astro";
import { Mail, Phone, MapPin } from "lucide-astro";
import { t } from "../lib/i18n.js";

const locale = 'en';
---

<Layout title={t(locale, 'titles.contact')}>
    <main class="contact-page">
        <!-- Hero Section with Team Story -->
        



        <!-- Contact Form -->
        <section class="contact-form-section">
            <div class="form-container">
                <div class="form-header">
                    <h2 class="section-headline">TELL US ABOUT YOUR PROJECT</h2>
                    <p class="section-subtitle">
                        Share your vision with us. The more details you provide, the better we can understand your needs and create something extraordinary together.
                    </p>
                </div>

                <form class="contact-form" id="contactForm" action="/api/submit-contact" method="POST">
                    <div class="form-fields">
                        <div class="basic-info">
                            <div class="form-row">
                                <label for="name" class="text-base font-medium">Your name</label>
                                <input 
                                    type="text" 
                                    id="name" 
                                    name="name" 
                                    class="form-input" 
                                    required
                                    placeholder="Enter your full name"
                                />
                            </div>

                            <div class="form-row">
                                <label for="email" class="text-base font-medium">Email address</label>
                                <input 
                                    type="email" 
                                    id="email" 
                                    name="email" 
                                    class="form-input" 
                                    required
                                    placeholder="your@email.com"
                                />
                            </div>

                            <div class="form-row">
                                <label for="phone" class="text-base font-medium">Phone number</label>
                                <input 
                                    type="tel" 
                                    id="phone" 
                                    name="phone" 
                                    class="form-input"
                                    placeholder="+996 XXX XXX XXX"
                                />
                            </div>

                            <div class="form-row">
                                <label for="company" class="text-base font-medium">Company</label>
                                <input 
                                    type="text" 
                                    id="company" 
                                    name="company" 
                                    class="form-input"
                                    placeholder="Your company name (optional)"
                                />
                            </div>
                        </div>

                        <div class="form-section">
                            <h3 class="text-base font-medium">Project type</h3>
                            <div class="switch-group">
                                <label class="switch-item">
                                    <input type="radio" name="project-type" value="commercial" />
                                    <span class="switch-label">Commercial/Advertisement</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="project-type" value="corporate" />
                                    <span class="switch-label">Corporate Video</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="project-type" value="social-media" />
                                    <span class="switch-label">Social Media Content</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="project-type" value="product" />
                                    <span class="switch-label">Product Photography/Video</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="project-type" value="event" />
                                    <span class="switch-label">Event Coverage</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="project-type" value="brand" />
                                    <span class="switch-label">Brand Story/Documentary</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="project-type" value="other" />
                                    <span class="switch-label">Other</span>
                                </label>
                            </div>
                        </div>

                        <div class="form-section">
                            <h3 class="text-base font-medium">Budget range (USD)</h3>
                            <div class="switch-group">
                                <label class="switch-item">
                                    <input type="radio" name="budget" value="under-1k" />
                                    <span class="switch-label">Under $1,000</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="budget" value="1k-5k" />
                                    <span class="switch-label">$1,000 - $5,000</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="budget" value="5k-10k" />
                                    <span class="switch-label">$5,000 - $10,000</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="budget" value="10k-25k" />
                                    <span class="switch-label">$10,000 - $25,000</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="budget" value="25k-plus" />
                                    <span class="switch-label">$25,000+</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="budget" value="discuss" />
                                    <span class="switch-label">Let's discuss</span>
                                </label>
                            </div>
                        </div>

                        <div class="form-section">
                            <h3 class="text-base font-medium">Project timeline</h3>
                            <div class="switch-group">
                                <label class="switch-item">
                                    <input type="radio" name="timeline" value="asap" />
                                    <span class="switch-label">ASAP</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="timeline" value="1-week" />
                                    <span class="switch-label">Within 1 week</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="timeline" value="2-weeks" />
                                    <span class="switch-label">Within 2 weeks</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="timeline" value="1-month" />
                                    <span class="switch-label">Within 1 month</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="timeline" value="2-months" />
                                    <span class="switch-label">Within 2 months</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="timeline" value="flexible" />
                                    <span class="switch-label">I'm flexible</span>
                                </label>
                            </div>
                        </div>

                        <div class="form-row message-row">
                            <label for="message" class="text-base font-medium">Project details</label>
                            <textarea 
                                id="message" 
                                name="message" 
                                class="form-textarea" 
                                rows="4"
                                placeholder="Tell us about your project, goals, target audience, style preferences, and any specific requirements..."
                            ></textarea>
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="submit-button btn btn-primary" id="submitBtn">
                            <span id="submitText">SEND PROJECT DETAILS</span>
                            <span id="loadingText" style="display: none;">SENDING...</span>
                        </button>
                        <p class="form-note">
                            We'll get back to you within 24 hours with a detailed proposal.
                        </p>
                        <div id="formMessage" class="form-message" style="display: none;"></div>
                    </div>
                </form>
            </div>
        </section>

        <!-- Contact Info -->
        
    </main>
</Layout>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('contactForm');
    const submitBtn = document.getElementById('submitBtn');
    const submitText = document.getElementById('submitText');
    const loadingText = document.getElementById('loadingText');
    const formMessage = document.getElementById('formMessage');

    // Check if all elements exist
    if (!form || !submitBtn || !submitText || !loadingText || !formMessage) {
        console.error('Required form elements not found');
        return;
    }

    form.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        // Disable submit button and show loading state
        submitBtn.disabled = true;
        submitText.style.display = 'none';
        loadingText.style.display = 'inline';
        formMessage.style.display = 'none';

        try {
            const formData = new FormData(form);
            
            const response = await fetch('/api/submit-contact', {
                method: 'POST',
                body: formData
            });

            const result = await response.json();

            if (result.success) {
                // Show success message
                formMessage.textContent = result.message;
                formMessage.className = 'form-message success';
                formMessage.style.display = 'block';
                
                // Reset form
                form.reset();
                
                // Scroll to message
                formMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
            } else {
                throw new Error(result.error || 'Unknown error occurred');
            }
        } catch (error) {
            console.error('Form submission error:', error);
            
            // Show error message
            const errorMessage = error instanceof Error ? error.message : 'Sorry, there was an error sending your message. Please try again or contact us directly.';
            formMessage.textContent = errorMessage;
            formMessage.className = 'form-message error';
            formMessage.style.display = 'block';
            
            // Scroll to message
            formMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } finally {
            // Re-enable submit button and restore original text
            (submitBtn).disabled = false;
            submitText.style.display = 'inline';
            loadingText.style.display = 'none';
        }
    });
});
</script>

<style>
    .contact-page {
        max-width: 1200px;
        width: 100%;
        min-height: 100vh;
        background: #000;
        color: #fff;
        display: flex;
        align-items: left;
    }





    /* Contact Form */
    .contact-form-section {
        margin-top: 4rem;
        
        background: #000;
    }

    .form-container {
        max-width: 800px;
        margin: 0 auto;
    }

    .form-header {
        text-align: left;
        margin-bottom: 3rem;
    }



    

    .form-fields {
        display: flex;
        flex-direction: column;
        gap: 4rem;
        margin-bottom: 2rem;
    }

    .basic-info {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    
      

    }

    .form-row {
        display: flex;
        align-items: center;
        gap: 2rem;
    }

    .message-row {
        align-items: flex-start;
    }

    .text-base.font-medium {
        margin: 0;
        min-width: 140px;
        width: 140px;
        text-align: left;
        color: #fff;
        flex-shrink: 0;
    }

    .form-input,
    .form-textarea {
        flex: 1;
        padding: 0.75rem 1rem;
        border: 2px solid #333;
        border-radius: 0.5rem;
 
        transition: border-color 0.3s ease;
        background: #000;
        color: #fff;
    }

    .form-input:focus,
    .form-textarea:focus {
        outline: none;
        border-color: #a00000;
    }

    .form-input::placeholder,
    .form-textarea::placeholder {
        color: #666;
    }

    .form-textarea {
        resize: vertical;
        min-height: 100px;
    }

    .form-section {
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }



    .switch-group {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-left: 0;
    }

    .switch-item {
        display: flex;
        align-items: center;
        cursor: pointer;
        background: #000;
        border: 2px solid #333;
        border-radius: 2rem;
        padding: 0.5rem 1rem;
        transition: all 0.3s ease;
        user-select: none;
    }

    .switch-item:hover {
        border-color: #a00000;
        background: #1a1a1a;
    }

    .switch-item input[type="radio"] {
        display: none;
    }

    .switch-item input[type="radio"]:checked + .switch-label {
        color: #fff;
    }

    .switch-item:has(input[type="radio"]:checked) {
        background: #a00000;
        border-color: #a00000;
    }

    .switch-label {
     
        font-weight: 500;
        color: var(--brand-white);
        transition: color 0.3s ease;
       
    }

    .form-actions {
        text-align: center;
    }

    .submit-button {
        height: 70px;
        padding: 0 3rem;
        letter-spacing: 0.02em;
        font-weight: 700;

       
    }

    .submit-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(160, 0, 0, 0.3);
    }

    .form-note {
        font-size: var(--text-small);
        color: var(--brand-white);
        margin: 1rem 0 0 0;
    }

    .form-message {
        margin-top: 1rem;
        padding: 1rem;
        border-radius: 0.5rem;
        text-align: center;
        font-weight: 500;
    }

    .form-message.success {
        background: rgba(34, 197, 94, 0.1);
        border: 2px solid rgba(34, 197, 94, 0.3);
        color: #22c55e;
    }

    .form-message.error {
        background: rgba(239, 68, 68, 0.1);
        border: 2px solid rgba(239, 68, 68, 0.3);
        color: #ef4444;
    }

    .submit-button:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none !important;
    }

    /* Contact Info */
    .contact-info {
        padding: 3rem 2rem;
        background: #000;
        color: #fff;
    }

    .info-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: rem;
    }

    .info-item {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .info-icon {
        width: 50px;
        height: 50px;
        background: #a00000;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .info-title {
        font-family: var(--font-sans);
        font-size: 0.9rem;
        font-weight: 700;
        color: #fff;
        margin: 0 0 0.3rem 0;
        text-transform: uppercase;
        letter-spacing: 0.02em;
    }

    .info-text {
        font-size: 1rem;
        color: #fff;
        margin: 0;
    }

    /* Responsive Design */
    @media (max-width: 768px) {



        .form-row {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.5rem;
        }

        .text-base.font-medium {
            min-width: auto;
        }

        .switch-group {
            gap: 0.5rem;
        }

        .switch-item {
            padding: 0.4rem 0.8rem;
        }

        .contact-form {
            padding: 2rem;
        }


    }

    @media (max-width: 480px) {



        .contact-form {
            padding: 1.5rem;
        }
    }
</style>