---
import Layout from '../../layouts/Layout.astro';
import portfolioData from '../../data/portfolio.json';

export const prerender = true;

export async function getStaticPaths() {
  const allProjects = [...portfolioData.featured, ...portfolioData.portfolio];
  
  return allProjects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<Layout title={`${project.title} - Portfolio - Easy Production`}>
  <main class="video-page">
    <div class="video-content">
      <!-- Back link -->
      <nav class="back-nav">
        <a href="/portfolio" class="back-link">← Back to Portfolio</a>
      </nav>

      <!-- Video title -->
      <h1 class="video-title">{project.title}</h1>
      
      <!-- Full-width video player -->
      <div class="video-player">
        <iframe
          src={`https://www.youtube.com/embed/${project.videoId}`}
          title={project.title}
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </main>
</Layout>

<style>
  .video-page {
    width: 100%;
    min-height: 100vh;
    background: var(--site-bg);
    padding: 2rem 0;
  }

  .video-content {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .back-nav {
    margin-bottom: 2rem;
  }

  .back-link {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 500;
    color: var(--brand-red);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .back-link:hover {
    opacity: 0.7;
  }

  .video-title {
    font-family: var(--font-heading);
    font-size: 3rem;
    font-weight: 700;
    color: var(--brand-black);
    margin: 0 0 2rem 0;
    letter-spacing: -0.02em;
    text-align: left;
  }

  .video-player {
    position: relative;
    width: 100%;
    height: 0;
    padding-bottom: 56.25%; /* 16:9 aspect ratio */
    background: #000;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
  }

  .video-player iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
    border-radius: 12px;
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .video-content {
      padding: 0 1rem;
    }

    .video-title {
      font-size: 2.5rem;
      margin-bottom: 1.5rem;
    }

    .video-player {
      border-radius: 8px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    }

    .video-player iframe {
      border-radius: 8px;
    }
  }

  @media (max-width: 480px) {
    .video-content {
      padding: 0 0.5rem;
    }

    .video-title {
      font-size: 2rem;
      margin-bottom: 1rem;
    }

    .back-nav {
      margin-bottom: 1.5rem;
    }

    .back-link {
      font-size: 0.9rem;
    }

    .video-player {
      border-radius: 6px;
    }

    .video-player iframe {
      border-radius: 6px;
    }
  }
</style>