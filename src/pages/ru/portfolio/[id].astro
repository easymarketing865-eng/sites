---
import Layout from '../../../layouts/Layout.astro';
import { projects } from '../../../lib/pocketbase.js';
import { t } from '../../../lib/i18n.js';

const locale = 'ru';

export const prerender = true;

export async function getStaticPaths() {
  let allProjects: any[] = [];
  
  try {
    // Try to fetch from PocketBase - get MORE projects to ensure we include all hero projects
    const result = await projects.getAll(1, 100); // Increased from 50 to 100
    allProjects = result.items || [];
    console.log(`Loaded ${allProjects.length} projects from PocketBase for static paths`);
    
    // Also fetch featured projects specifically to ensure they're included
    try {
      const featuredResult = await projects.getFeatured(20); // Get featured projects
      const featuredProjects = featuredResult.items || [];
      
      // Merge featured projects with all projects, removing duplicates by ID
      const existingIds = new Set(allProjects.map(p => p.id));
      const newFeaturedProjects = featuredProjects.filter(p => !existingIds.has(p.id));
      allProjects = [...allProjects, ...newFeaturedProjects];
      
      console.log(`Added ${newFeaturedProjects.length} additional featured projects for static paths`);
    } catch (featuredError) {
      console.log('Could not fetch featured projects separately:', (featuredError as Error).message);
    }
    
  } catch (error) {
    console.log('PocketBase not available for static paths:', (error as Error).message);
    allProjects = [];
  }
  
  return allProjects.map((project) => ({
    params: { id: project.id || project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;

// Get video ID from the correct field name (use bracket notation to avoid TypeScript errors)
const videoId = (project as any).videoID || project.videoId;
---

<Layout title={`${project.title} - ${t(locale, 'titles.portfolio')}`}>
  <main class="video-page">
    <div class="video-content">
      <!-- Back link -->
      <nav class="back-nav">
        <a href="/ru/portfolio" class="back-link">{t(locale, 'portfolio.backToPortfolio')}</a>
      </nav>

      <!-- Video title -->
      <h1 class="video-title">{project.title}</h1>
      
      <!-- Full-width video player -->
      <div class="video-player">
        {videoId ? (
          <iframe
            src={`https://www.youtube.com/embed/${videoId}`}
            title={project.title}
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
            loading="lazy"
          ></iframe>
        ) : (
          <div style="color: white; padding: 2rem; text-align: center;">
            Видео ID не найден для этого проекта
          </div>
        )}
      </div>
    </div>
  </main>
</Layout>

<style>
  :global(body) {
    background: #000000 !important;
  }
  
  :global(article) {
    width: 100%;
    background: #000000;
  }
  .video-page {
    width: 100%;
    background: #000000;
    padding: 2rem 0;
  }

  .video-content {
    margin: 0 auto;
    padding: 0 2rem;
  }

  .back-nav {
    margin-bottom: 2rem;
  }

  .back-link {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 500;
    color: #ffffff;
    text-decoration: none;
    transition: all 0.2s ease;
    opacity: 0.8;
  }

  .back-link:hover {
    opacity: 1;
    color: var(--brand-red);
  }

  .video-title {
    font-family: var(--font-heading);
    font-size: 3rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 2rem 0;
    letter-spacing: -0.02em;
    text-align: left;
  }

  .video-player {
    position: relative;
    width: 100%;
    height: 0;
    padding-bottom: 56.25%; /* 16:9 aspect ratio */
    background: #000;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    border: 1px solid rgba(0, 0, 0, 0.1);
  }

  .video-player iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
    border-radius: 12px;
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .video-content {
      padding: 0 1rem;
    }

    .video-title {
      font-size: 2.5rem;
      margin-bottom: 1.5rem;
    }

    .video-player {
      border-radius: 8px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
      border: 1px solid rgba(0, 0, 0, 0.08);
    }

    .video-player iframe {
      border-radius: 8px;
    }
  }

  @media (max-width: 480px) {
    .video-content {
      padding: 0 0.5rem;
    }

    .video-title {
      font-size: 2rem;
      margin-bottom: 1rem;
    }

    .back-nav {
      margin-bottom: 1.5rem;
    }

    .back-link {
      font-size: 0.9rem;
    }

    .video-player {
      border-radius: 6px;
    }

    .video-player iframe {
      border-radius: 6px;
    }
  }
</style> 