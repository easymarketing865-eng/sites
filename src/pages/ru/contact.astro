---
/**
 * Contact Page - Russian Version
 * Comprehensive contact page with team story and multiple contact options
 */
import Layout from "../../layouts/Layout.astro";
import { Mail, Phone, MapPin } from "lucide-astro";
import { t } from "../../lib/i18n.js";

const locale = 'ru';
---

<Layout title={t(locale, 'titles.contact')}>
    <main class="contact-page">
        <!-- Contact Form -->
        <section class="contact-form-section">
            <div class="form-container">
                <div class="form-header">
                    <h2 class="section-headline">{t(locale, 'contact.title')}</h2>
                    <p class="section-subtitle">
                        {t(locale, 'contact.subtitle')}
                    </p>
                </div>

                <form class="contact-form" id="contactForm" action="/api/submit-contact" method="POST">
                    <div class="form-fields">
                        <div class="basic-info">
                            <div class="form-row">
                                <label for="name" class="text-base font-medium">{t(locale, 'contact.form.name')}</label>
                                <input 
                                    type="text" 
                                    id="name" 
                                    name="name" 
                                    class="form-input" 
                                    required
                                    placeholder="Введите ваше полное имя"
                                />
                            </div>

                            <div class="form-row">
                                <label for="email" class="text-base font-medium">{t(locale, 'contact.form.email')}</label>
                                <input 
                                    type="email" 
                                    id="email" 
                                    name="email" 
                                    class="form-input" 
                                    required
                                    placeholder="your@email.com"
                                />
                            </div>

                            <div class="form-row">
                                <label for="phone" class="text-base font-medium">{t(locale, 'contact.form.phone')}</label>
                                <input 
                                    type="tel" 
                                    id="phone" 
                                    name="phone" 
                                    class="form-input"
                                    placeholder="+996 XXX XXX XXX"
                                />
                            </div>

                            <div class="form-row">
                                <label for="company" class="text-base font-medium">{t(locale, 'contact.form.company')}</label>
                                <input 
                                    type="text" 
                                    id="company" 
                                    name="company" 
                                    class="form-input"
                                    placeholder="Название вашей компании (необязательно)"
                                />
                            </div>
                        </div>

                        <div class="form-section">
                            <h3 class="text-base font-medium">{t(locale, 'contact.form.projectType')}</h3>
                            <div class="switch-group">
                                <label class="switch-item">
                                    <input type="radio" name="project-type" value="commercial" required />
                                    <span class="switch-label">{t(locale, 'contact.projectTypes.commercial')}</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="project-type" value="corporate" />
                                    <span class="switch-label">{t(locale, 'contact.projectTypes.corporate')}</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="project-type" value="social-media" />
                                    <span class="switch-label">{t(locale, 'contact.projectTypes.socialMedia')}</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="project-type" value="product" />
                                    <span class="switch-label">{t(locale, 'contact.projectTypes.product')}</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="project-type" value="event" />
                                    <span class="switch-label">{t(locale, 'contact.projectTypes.event')}</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="project-type" value="brand" />
                                    <span class="switch-label">{t(locale, 'contact.projectTypes.brand')}</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="project-type" value="other" />
                                    <span class="switch-label">{t(locale, 'contact.projectTypes.other')}</span>
                                </label>
                            </div>
                        </div>

                        <div class="form-section">
                            <h3 class="text-base font-medium">{t(locale, 'contact.form.budget')}</h3>
                            <div class="switch-group">
                                <label class="switch-item">
                                    <input type="radio" name="budget" value="under-1k" />
                                    <span class="switch-label">{t(locale, 'contact.budgetRanges.under1k')}</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="budget" value="1k-5k" />
                                    <span class="switch-label">{t(locale, 'contact.budgetRanges.1k-5k')}</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="budget" value="5k-10k" />
                                    <span class="switch-label">{t(locale, 'contact.budgetRanges.5k-10k')}</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="budget" value="10k-25k" />
                                    <span class="switch-label">{t(locale, 'contact.budgetRanges.10k-25k')}</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="budget" value="25k-plus" />
                                    <span class="switch-label">{t(locale, 'contact.budgetRanges.25k-plus')}</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="budget" value="discuss" />
                                    <span class="switch-label">{t(locale, 'contact.budgetRanges.discuss')}</span>
                                </label>
                            </div>
                        </div>

                        <div class="form-section">
                            <h3 class="text-base font-medium">{t(locale, 'contact.form.timeline')}</h3>
                            <div class="switch-group">
                                <label class="switch-item">
                                    <input type="radio" name="timeline" value="asap" />
                                    <span class="switch-label">{t(locale, 'contact.timelines.asap')}</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="timeline" value="1-week" />
                                    <span class="switch-label">{t(locale, 'contact.timelines.1-week')}</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="timeline" value="2-weeks" />
                                    <span class="switch-label">{t(locale, 'contact.timelines.2-weeks')}</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="timeline" value="1-month" />
                                    <span class="switch-label">{t(locale, 'contact.timelines.1-month')}</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="timeline" value="2-months" />
                                    <span class="switch-label">{t(locale, 'contact.timelines.2-months')}</span>
                                </label>
                                <label class="switch-item">
                                    <input type="radio" name="timeline" value="flexible" />
                                    <span class="switch-label">{t(locale, 'contact.timelines.flexible')}</span>
                                </label>
                            </div>
                        </div>

                        <div class="form-row message-row">
                            <label for="message" class="text-base font-medium">{t(locale, 'contact.form.message')}</label>
                            <textarea 
                                id="message" 
                                name="message" 
                                class="form-textarea" 
                                rows="4"
                                required
                                placeholder="Расскажите нам о вашем проекте, целях, целевой аудитории, стилевых предпочтениях и любых специфических требованиях..."
                            ></textarea>
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="submit-button btn btn-primary" id="submitBtn">
                            <span id="submitText">{t(locale, 'contact.form.submit')}</span>
                            <span id="loadingText" style="display: none;">{t(locale, 'contact.form.sending')}</span>
                        </button>
                        <p class="form-note">
                            {t(locale, 'contact.form.note')}
                        </p>
                        <div id="formMessage" class="form-message" style="display: none;"></div>
                    </div>
                </form>
            </div>
        </section>
    </main>
</Layout>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('contactForm');
    const submitBtn = document.getElementById('submitBtn');
    const submitText = document.getElementById('submitText');
    const loadingText = document.getElementById('loadingText');
    const formMessage = document.getElementById('formMessage');

    // Check if all elements exist
    if (!form || !submitBtn || !submitText || !loadingText || !formMessage) {
        console.error('Required form elements not found');
        return;
    }

    form.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        // Disable submit button and show loading state
        submitBtn.disabled = true;
        submitText.style.display = 'none';
        loadingText.style.display = 'inline';
        formMessage.style.display = 'none';

        try {
            const formData = new FormData(form);
            
            const response = await fetch('/api/submit-contact', {
                method: 'POST',
                body: formData
            });

            const result = await response.json();

            if (result.success) {
                // Show success message
                formMessage.textContent = result.message;
                formMessage.className = 'form-message success';
                formMessage.style.display = 'block';
                
                // Reset form
                form.reset();
                
                // Scroll to message
                formMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
            } else {
                throw new Error(result.error || 'Unknown error occurred');
            }
        } catch (error) {
            console.error('Form submission error:', error);
            
            // Show error message
            const errorMessage = error instanceof Error ? error.message : 'Извините, произошла ошибка при отправке сообщения. Попробуйте еще раз или свяжитесь с нами напрямую.';
            formMessage.textContent = errorMessage;
            formMessage.className = 'form-message error';
            formMessage.style.display = 'block';
            
            // Scroll to message
            formMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } finally {
            // Re-enable submit button and restore original text
            (submitBtn).disabled = false;
            submitText.style.display = 'inline';
            loadingText.style.display = 'none';
        }
    });
});
</script>

<style>
    .contact-page {
        max-width: 1200px;
        width: 100%;
        min-height: 100vh;
        background: #000;
        color: #fff;
        display: flex;
        align-items: left;
    }

    /* Contact Form */
    .contact-form-section {
        margin-top: 4rem;
        background: #000;
    }

    .form-container {
        max-width: 800px;
        margin: 0 auto;
    }

    .form-header {
        text-align: left;
        margin-bottom: 3rem;
    }

    .form-fields {
        display: flex;
        flex-direction: column;
        gap: 4rem;
        margin-bottom: 2rem;
    }

    .basic-info {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .form-row {
        display: flex;
        align-items: center;
        gap: 2rem;
    }

    .message-row {
        align-items: flex-start;
    }

    .text-base.font-medium {
        margin: 0;
        min-width: 140px;
        width: 140px;
        text-align: left;
        color: #fff;
        flex-shrink: 0;
    }

    .form-input,
    .form-textarea {
        flex: 1;
        padding: 0.75rem 1rem;
        border: 2px solid #333;
        border-radius: 0.5rem;
        transition: border-color 0.3s ease;
        background: #000;
        color: #fff;
    }

    .form-input:focus,
    .form-textarea:focus {
        outline: none;
        border-color: #a00000;
    }

    .form-input::placeholder,
    .form-textarea::placeholder {
        color: #666;
    }

    .form-textarea {
        resize: vertical;
        min-height: 100px;
    }

    .form-section {
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .switch-group {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-left: 0;
    }

    .switch-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.25rem;
        border: 2px solid #333;
        border-radius: 2rem;
        cursor: pointer;
        transition: all 0.3s ease;
        background: #000;
    }

    .switch-item:hover {
        border-color: #666;
    }

    .switch-item input[type="radio"] {
        margin: 0;
        width: 16px;
        height: 16px;
    }

    .switch-item input[type="radio"]:checked + .switch-label {
        color: #a00000;
        font-weight: 600;
    }

    .switch-item:has(input[type="radio"]:checked) {
        border-color: #a00000;
        background: rgba(160, 0, 0, 0.1);
    }

    .switch-label {
        color: #fff;
        font-size: 0.9rem;
        user-select: none;
    }

    .form-actions {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        margin-top: 3rem;
    }

    .submit-button {
        background: #a00000;
        color: #fff;
        border: none;
        padding: 1rem 2rem;
        border-radius: 0.5rem;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        transition: background-color 0.3s ease;
        text-transform: uppercase;
        min-width: 280px;
    }

    .submit-button:hover:not(:disabled) {
        background: #800000;
    }

    .submit-button:disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }

    .form-note {
        text-align: center;
        color: #999;
        font-size: 0.9rem;
        margin: 0;
    }

    .form-message {
        padding: 1rem;
        border-radius: 0.5rem;
        text-align: center;
        font-weight: 500;
        max-width: 500px;
        margin: 0 auto;
    }

    .form-message.success {
        background: rgba(0, 255, 0, 0.1);
        border: 1px solid rgba(0, 255, 0, 0.3);
        color: #00ff00;
    }

    .form-message.error {
        background: rgba(255, 0, 0, 0.1);
        border: 1px solid rgba(255, 0, 0, 0.3);
        color: #ff6b6b;
    }

    /* Mobile responsiveness */
    @media (max-width: 768px) {
        .form-row {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.5rem;
        }

        .text-base.font-medium {
            min-width: auto;
            width: auto;
        }

        .form-input,
        .form-textarea {
            width: 100%;
        }

        .switch-group {
            gap: 0.5rem;
        }

        .switch-item {
            padding: 0.5rem 1rem;
            font-size: 0.85rem;
        }

        .submit-button {
            min-width: 100%;
        }
    }
</style> 