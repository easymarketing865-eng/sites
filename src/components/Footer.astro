---
/**
 * Footer.astro
 * Comprehensive footer with trust signals, social links, and contact form
 */
import "../styles/global.css";
import styles from "../styles/Footer.module.css";
import SocialShare from "./SocialShare.astro";

const clientLogos = [
    { name: "M-Bank", logo: "/logos/mbank.webp" },
    { name: "Elizaveta Real Estate", logo: "/logos/elizaveta.webp" },
    { name: "BMW", logo: "/logos/bmw.webp" },
    { name: "Geely", logo: "/logos/geely.webp" },
    { name: "Novotel", logo: "/logos/novotel.webp" },
    { name: "Hyatt Regency", logo: "/logos/hyatt.webp" },
    { name: "Avangard", logo: "/logos/avangard.webp" },
    { name: "Arbat", logo: "/logos/arbat.webp" },
    { name: "Beren", logo: "/logos/beren.webp" },
    { name: "Crystal", logo: "/logos/crystal.webp" },
];

---

<footer class={styles.footer}>
    <!-- Trust Signals Section -->
    <section class={styles.trustSection}>
        <div class={styles.container}>
            <h2 class={styles.trustHeading}>
                Trusted by Kyrgyzstan's Leading Brands
            </h2>
            <div class={styles.clientGrid}>
                {
                    clientLogos.map((client) => (
                        <div class={styles.clientLogo}>
                            <img
                                src={client.logo}
                                alt={`${client.name} logo`}
                                class={styles.logoImage}
                                loading="lazy"
                            />
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Main Footer Content -->
    <section class={styles.mainFooter}>
        <div class={styles.container}>
            <div class={styles.footerGrid}>
                <!-- Company Info -->
                <div class={styles.companyInfo}>
                    <img
                        src="/photos/logo.svg"
                        alt="Easy Production"
                        class={styles.footerLogo}
                    />
                    <p class={styles.companyDescription}>
                        Professional video production and creative services in
                        Kyrgyzstan. We bring your vision to life with stunning
                        visuals and authentic storytelling.
                    </p>
                    <div class={styles.contactInfo}>
                        <div class={styles.contactItem}>
                            <span class={styles.contactIcon}>📍</span>
                            <span>Bishkek, Kyrgyzstan</span>
                        </div>
                        <div class={styles.contactItem}>
                            <span class={styles.contactIcon}>📞</span>
                            <span>+996 555 123 456</span>
                        </div>
                        <div class={styles.contactItem}>
                            <span class={styles.contactIcon}>✉️</span>
                            <span>hello@easyproduction.kg</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Social Links Section -->
    <section class={styles.socialSection}>
        <div class={styles.container}>
            <!-- Social Share Section -->
            <div class="footer-share-section">
                <SocialShare 
                    title="Easy Production - Professional Video Services"
                    description="Discover amazing video production services in Kyrgyzstan with international standards"
                    className="footer-share"
                />
            </div>
        </div>
    </section>

    <!-- Team Photo Section -->
    <section class={styles.teamSection}>
        <div class={styles.container}>
            <img
                src="/team/at_work.webp"
                alt="Easy Production team at work"
                class={styles.teamImage}
                loading="lazy"
            />
            <div class={styles.copyright}>
                <p>&copy; 2024 Easy Production. All rights reserved.</p>
            </div>
        </div>
    </section>
</footer>

<style>
    /* Footer Social Share Section Styling */
    .footer-share-section {
        
        
    }
</style>
