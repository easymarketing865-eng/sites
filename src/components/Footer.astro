</footer>

<style>
    .footer {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: var(--main-padding);
        max-width: var(--main-maxwidth);
        margin: 0 auto;
        width: 100%;

        color: #ffffff;
        margin-top: 2rem;
    }

    .footer-container {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 3rem;
    }

    /* Footer Header */
    .footer-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
        flex-wrap: wrap;
    }

    .footer-title {
        font-size: var(--text-base);
        font-weight: 600;
        color: #ffffff;
        margin: 0;
        flex: 1;
        min-width: 280px;
    }

    .footer-btn {
        flex-shrink: 0;
        background: var(--brand-red);
        color: white;
        padding: 6px 24px;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 500;
        font-size: var(--text-base);
        transition: all 0.2s ease;
        border: none;
        cursor: pointer;
        height: 40px;
    }

    .footer-btn:hover {
        background: linear-gradient(135deg, #800B10 0%, #A91D23 100%);
       
       
    }

    /* Locations Section */
    .locations-section {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 2rem;
    }

    .location {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .location-title {
        font-size: var(--text-base);
        font-weight: 600;
        margin: 0;
        color: #ffffff;
        letter-spacing: 0.5px;
    }

    .contact-info {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .contact-link {
        font-size: var(--text-base);
        font-weight: 500;
        color: #ffffff;
        text-decoration: none;
        transition: color 0.2s ease;
    }

    .contact-link:hover {
        color: var(--brand-red);
    }

    .email {
        font-weight: 600;
    }

    /* Social Section */
    .social-section {
        border-top: 1px solid rgba(255, 255, 255, 0.2);
        padding-top: 2rem;
    }

    .social-buttons {
        width: 40px;
        height: 40px;
        color: rgba(255, 255, 255, 0.7);
        display:inline;
        gap: 0.75rem;
  
        flex-wrap: wrap;
      
    }

    .social-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.25rem;
        border: none;
        border-radius: 6px;
        color: #fff;
        font-family: var(--font-sans);
        font-size: 20px;
        font-weight: 500;
        text-decoration: none;
        cursor: pointer;
        /* transition: all 0.2s ease; */
        max-height: 40px;
        box-sizing: border-box;
    }

    .social-btn:hover {
        /* No animations */
    }

    .social-icon {
        width: 20px;
        height: 20px;
        flex-shrink: 0;
        color: #fff;
    }

    /* Service-specific background colors - slightly muted */
    .instagram-btn {
        background: linear-gradient(135deg, #3a52c4, #4e46c7, #7530a0, #a8297a, #c72860, #e01a1a);
    }

    .telegram-btn {
        background: #0077b3;
    }

    .whatsapp-btn {
        background: #20b558;
    }

    .youtube-btn {
        background: #d60000;
    }

    /* Hover effects - slightly darker colors */
    .instagram-btn:hover {
        background: linear-gradient(135deg, #324ba0, #423d9f, #652a85, #8d2466, #a32350, #bc1717);
    }

    .telegram-btn:hover {
        background: #00639a;
    }

    .whatsapp-btn:hover {
        background: #1c9b4a;
    }

    .youtube-btn:hover {
        background: #b30000;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .footer {
            padding: var(--main-padding);
        }

        .footer-container {
            gap: 2rem;
        }

        .footer-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 1.5rem;
        }

        .footer-title {
            min-width: auto;
        }

        .locations-section {
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        .contact-link {
            font-size: var(--text-small);
        }

        .social-buttons {
            gap: 0.5rem;
        }

        .social-btn {
            padding: 0.6rem 0.5rem;
            font-size: 0.8rem;
        }

        .social-icon {
            width: 16px;
            height: 16px;
        }
    }

    @media (max-width: 480px) {
        .footer {
            padding: var(--main-padding);
        }

        .footer-container {
            gap: 1.5rem;
        }

        .locations-section {
            gap: 1.5rem;
        }

        .contact-info {
            gap: 0.5rem;
        }

        .social-buttons {
            flex-direction: row;
            justify-content: center;
            gap: 0.5rem;
        }

        .social-btn {
            position: relative;
            padding: 0.5rem;
            min-width: 60px;
            justify-content: center;
            align-items: center;
        }

        .social-btn span {
            position: absolute;
            left: -9999px;
            opacity: 0;
        }

        .social-icon {
            width: 20px;
            height: 20px;
            margin: 0;
        }
    }
</style>