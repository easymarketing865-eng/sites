---
const {
    factoids = [],
    position = "top-right",
    colorScheme = "primary",
} = Astro.props;

const colorMap = {
    primary: "#8E0C12",
    accent: "#212144",
};
const fillColor = colorScheme in colorMap ? colorMap[colorScheme] : colorScheme;
---

<div class={`factoid ${position}`}>
    <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
        <path
            fill={fillColor}
            d="M62.4,-33C75.5,-13.2,77.2,16.2,64.9,34.1C52.6,52,26.3,58.4,6.8,54.5C-12.8,50.6,-25.6,36.4,-35.5,19.9C-45.5,3.3,-52.5,-15.5,-46.1,-31.4C-39.7,-47.3,-19.9,-60.3,2.4,-61.6C24.6,-63,49.2,-52.8,62.4,-33Z"
            transform="translate(100 100)"></path>
    </svg>
    <div class="factoid-text">
        {
            factoids.map((f, i) => (
                <div
                    class={`factoid-line${i === 0 ? " factoid-number" : " factoid-label"}`}
                    key={i}
                >
                    {f}
                </div>
            ))
        }
    </div>
</div>

<style>
    .factoid {
        position: absolute;
        width: 220px;
        height: 220px;
        z-index: 2;
    }

    /* Position variants */
    .factoid.top-right {
        top: -2rem;
        right: -2rem;
    }
    .factoid.top-left {
        top: -2rem;
        left: -2rem;
    }
    .factoid.bottom-right {
        bottom: -2rem;
        right: -2rem;
    }
    .factoid.bottom-left {
        bottom: -2rem;
        left: -2rem;
    }
    .factoid.center {
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
    }

    .factoid svg {
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
    }

    .factoid-text {
        position: relative;
        z-index: 3;
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: white;
        text-align: center;
        transform: translate(-45%, -55%);
        position: absolute;
        top: 50%;
        left: 50%;
    }

    .factoid-number {
        font-family: "Manrope", var(--font-sans);
        font-size: 42px;
        font-weight: 800;
        line-height: 1;
        display: block;
    }

    .factoid-label,
    .factoid-line:not(.factoid-number) {
        font-family: "Manrope", var(--font-sans);
        font-size: 20px;
        font-weight: 500;
        letter-spacing: 0.05em;
        line-height: 1;
        display: block;
    }

    @media (max-width: 768px) {
        .factoid {
            width: 120px;
            height: 120px;
        }
        .factoid.top-right,
        .factoid.top-left {
            top: -1rem;
        }
        .factoid.top-right,
        .factoid.bottom-right {
            right: -1rem;
        }
        .factoid.top-left,
        .factoid.bottom-left {
            left: -1rem;
        }
        .factoid.bottom-right,
        .factoid.bottom-left {
            bottom: -1rem;
        }
        .factoid.center {
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }
        .factoid-number {
            font-size: 24px;
        }
        .factoid-label,
        .factoid-line:not(.factoid-number) {
            font-size: 12px;
            letter-spacing: 0.05em;
        }
    }
</style>
