---
/**
 * PortfolioPage.astro
 * Full portfolio page with filtering and categories
 */
import "../styles/global.css";
import portfolioData from "../data/portfolio.json";

const allProjects = [...portfolioData.featured, ...portfolioData.portfolio];
const categories = portfolioData.categories;
---

<section class="portfolio-page">
  <header class="page-header">
    <h1 class="page-title">Portfolio</h1>
    <p class="page-subtitle">Showcasing our creative work across industries and mediums</p>
  </header>

  <div class="filter-bar">
    <div class="filter-container">
      {categories.map(category => (
        <button 
          class={`filter-btn ${category === 'All' ? 'active' : ''}`}
          data-filter={category === 'All' ? '*' : category}
        >
          {category}
        </button>
      ))}
    </div>
  </div>

  <div class="portfolio-grid">
    {allProjects.map((project, index) => (
      <article 
        class={`portfolio-item ${project.featured ? 'featured' : ''}`}
        data-category={project.category}
      >
        <a href={`/portfolio/${project.slug}`} class="project-link">
          <div class="project-image-container">
            <img 
              src={project.hero} 
              alt={`${project.title} project`} 
              class="project-image"
              loading="lazy"
            />
            <div class="project-overlay">
              <div class="project-meta">
                <span class="project-category">{project.category}</span>
                <span class="project-year">{project.year}</span>
              </div>
              {project.featured && (
                <div class="featured-badge">Featured</div>
              )}
            </div>
          </div>
          
          <div class="project-content">
            <h3 class="project-title">{project.title}</h3>
            <p class="project-description">{project.shortDescription}</p>
            
            <div class="project-services">
              {project.services.slice(0, 3).map(service => (
                <span class="service-tag">{service}</span>
              ))}
            </div>
            
            {(project as any).results && (
              <div class="project-stats">
                <div class="stat">
                  <span class="stat-value">{(project as any).results.reach}</span>
                  <span class="stat-label">Reach</span>
                </div>
                <div class="stat">
                  <span class="stat-value">{(project as any).results.duration}</span>
                  <span class="stat-label">Duration</span>
                </div>
              </div>
            )}
          </div>
        </a>
      </article>
    ))}
  </div>
</section>

<script>
  // Portfolio filtering functionality
  document.addEventListener('DOMContentLoaded', function() {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const portfolioItems = document.querySelectorAll('.portfolio-item');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', function(this: HTMLElement) {
        // Remove active class from all buttons
        filterBtns.forEach(b => b.classList.remove('active'));
        // Add active class to clicked button
        this.classList.add('active');

        const filterValue = this.getAttribute('data-filter');

        portfolioItems.forEach(item => {
          const htmlItem = item as HTMLElement;
          if (filterValue === '*') {
            htmlItem.style.display = 'block';
            htmlItem.style.animation = 'fadeIn 0.5s ease';
          } else {
            const itemCategory = item.getAttribute('data-category');
            if (itemCategory === filterValue) {
              htmlItem.style.display = 'block';
              htmlItem.style.animation = 'fadeIn 0.5s ease';
            } else {
              htmlItem.style.display = 'none';
            }
          }
        });
      });
    });
  });
</script>

<style>
  .portfolio-page {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 1rem 1rem 2rem 1rem;
  }

  .page-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .page-title {
    font-size: 1.75rem;
    color: var(--brand-red, #A00000);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.5em 0;
    font-family: var(--font-sans);
  }

  .page-subtitle {
    font-size: 0.95rem;
    color: var(--brand-black, #666);
    font-family: var(--font-sans);
    line-height: 1.4;
    margin: 0;
    max-width: 600px;
    margin: 0 auto;
  }

  .filter-bar {
    margin-bottom: 2rem;
    display: flex;
    justify-content: center;
  }

  .filter-container {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5em;
    justify-content: center;
  }

  .filter-btn {
    background: var(--brand-white, #fff);
    border: 2px solid #e9ecef;
    padding: 0.5em 1em;
    border-radius: 2em;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--brand-black, #666);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .filter-btn:hover,
  .filter-btn.active {
    background: var(--brand-red, #A00000);
    border-color: var(--brand-red, #A00000);
    color: var(--brand-white, #fff);
    transform: translateY(-2px);
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 480px) {
    .portfolio-page {
      padding: 1.5rem 1.25rem 2.5rem 1.25rem;
    }

    .page-header {
      margin-bottom: 2.5rem;
    }

    .page-title {
      font-size: 2rem;
    }

    .page-subtitle {
      font-size: 1rem;
    }

    .filter-bar {
      margin-bottom: 2.5rem;
    }

    .filter-btn {
      padding: 0.6em 1.2em;
      font-size: 0.85rem;
    }

    .portfolio-grid {
      gap: 2rem;
    }
  }

  @media (min-width: 768px) {
    .portfolio-page {
      padding: 2rem 1.5rem 3rem 1.5rem;
    }

    .page-header {
      margin-bottom: 3rem;
    }

    .page-title {
      font-size: 2.25rem;
    }

    .page-subtitle {
      font-size: 1.1rem;
    }

    .filter-bar {
      margin-bottom: 3rem;
    }

    .filter-btn {
      padding: 0.7em 1.5em;
      font-size: 0.9rem;
    }

    .portfolio-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.5rem;
    }
  }

  @media (min-width: 1024px) {
    .portfolio-page {
      padding: 2rem 2rem 4rem 2rem;
    }

    .page-title {
      font-size: 2.5rem;
    }
  }

  @media (min-width: 1200px) {
    .portfolio-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .portfolio-item {
    background: var(--brand-white, #fff);
    border-radius: 1.5em;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.04);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .portfolio-item.featured {
    grid-column: span 1;
  }

  @media (min-width: 1200px) {
    .portfolio-item.featured:nth-child(3n + 1) {
      grid-column: span 2;
    }
  }

  .portfolio-item:hover {
    transform: translateY(-12px);
    box-shadow: 0 16px 48px rgba(160, 0, 0, 0.12);
  }

  .project-link {
    text-decoration: none;
    color: inherit;
    display: block;
    height: 100%;
  }

  .project-image-container {
    position: relative;
    width: 100%;
    height: 200px;
    overflow: hidden;
  }

  .featured .project-image-container {
    height: 220px;
  }

  .project-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.4s ease;
  }

  .portfolio-item:hover .project-image {
    transform: scale(1.08);
  }

  .project-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.6) 100%);
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 1rem;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .portfolio-item:hover .project-overlay {
    opacity: 1;
  }

  .project-meta {
    display: flex;
    flex-direction: column;
    gap: 0.5em;
  }

  .project-category {
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(8px);
    padding: 0.4em 0.8em;
    border-radius: 1em;
    font-family: var(--font-sans);
    font-size: 0.75em;
    font-weight: 600;
    color: var(--brand-red, #A00000);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .project-year {
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(8px);
    padding: 0.4em 0.8em;
    border-radius: 1em;
    font-family: var(--font-sans);
    font-size: 0.75em;
    font-weight: 600;
    color: var(--brand-white, #fff);
  }

  .featured-badge {
    background: var(--brand-red, #A00000);
    color: var(--brand-white, #fff);
    padding: 0.5em 1em;
    border-radius: 1em;
    font-family: var(--font-sans);
    font-size: 0.8em;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .project-content {
    padding: 1.25rem;
  }

  .project-title {
    font-family: var(--font-sans);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--brand-black, #222);
    margin: 0 0 0.8em 0;
    line-height: 1.3;
  }

  .featured .project-title {
    font-size: 1.2rem;
  }

  .project-description {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--brand-black, #666);
    margin: 0 0 1.25rem 0;
  }

  .project-services {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.25rem;
  }

  .service-tag {
    background: #f8f9fa;
    padding: 0.3rem 0.6rem;
    border-radius: 0.6rem;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--brand-black, #555);
    font-weight: 500;
  }

  .project-stats {
    display: flex;
    gap: 1.5rem;
    padding-top: 0.75rem;
    border-top: 1px solid #f0f0f0;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.2em;
  }

  .stat-value {
    font-family: var(--font-sans);
    font-size: 0.9em;
    font-weight: 700;
    color: var(--brand-red, #A00000);
  }

  .stat-label {
    font-family: var(--font-sans);
    font-size: 0.75em;
    color: var(--brand-black, #888);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (min-width: 480px) {
    .project-image-container {
      height: 240px;
    }

    .featured .project-image-container {
      height: 260px;
    }

    .project-overlay {
      padding: 1.25rem;
    }

    .project-content {
      padding: 1.5rem;
    }

    .project-title {
      font-size: 1.2rem;
    }

    .featured .project-title {
      font-size: 1.3rem;
    }

    .project-description {
      font-size: 0.95rem;
      margin-bottom: 1.5rem;
    }

    .service-tag {
      padding: 0.4rem 0.8rem;
      border-radius: 0.8rem;
      font-size: 0.8rem;
    }

    .project-stats {
      gap: 2rem;
      padding-top: 1rem;
    }
  }

  @media (min-width: 768px) {
    .project-image-container {
      height: 280px;
    }

    .featured .project-image-container {
      height: 320px;
    }

    .project-overlay {
      padding: 1.5rem;
    }

    .project-content {
      padding: 2rem;
    }

    .project-title {
      font-size: 1.4rem;
    }

    .featured .project-title {
      font-size: 1.6rem;
    }

    .project-description {
      font-size: 1rem;
      margin-bottom: 1.5rem;
    }

    .project-services {
      gap: 0.5rem;
      margin-bottom: 1.5rem;
    }

    .service-tag {
      font-size: 0.85rem;
    }

    .project-stats {
      gap: 2rem;
      padding-top: 1rem;
    }
  }
</style>