---
/**
 * PortfolioPage.astro
 * Full portfolio page using the designer's approved styles from Portfolio component
 */
import "../styles/global.css";
import portfolioData from "../data/portfolio.json";

const allProjects = [...portfolioData.featured, ...portfolioData.portfolio];
const categories = portfolioData.categories;
---

<section class="portfolio-section" id="portfolio">
    <!-- Start decoration SVG -->
    <div class="decoration decoration-start">
        <img src="/photos/start.svg" alt="Start decoration" class="decoration-svg" />
    </div>

    <div class="portfolio-content">
        <h1 class="headline">Portfolio</h1>
        <p class="portfolio-subtitle">Showcasing our creative work across industries and mediums</p>
        
        <div class="filter-bar">
            <div class="filter-container">
                {categories.map(category => (
                    <button 
                        class={`filter-btn ${category === 'All' ? 'active' : ''}`}
                        data-filter={category === 'All' ? '*' : category}
                    >
                        {category}
                    </button>
                ))}
            </div>
        </div>

        <div class="portfolio-grid">
            {
                allProjects.map((p, index) => {
                    return (
                        <a href={`/portfolio/${p.slug}`} class="portfolio-card" data-category={p.category}>
                            <img
                                src={p.hero}
                                alt={p.title + " project image"}
                                class="portfolio-img"
                                loading="lazy"
                            />
                            {index === allProjects.length - 1 && (
                                <div class="factoid">
                                    <img
                                        src="/photos/factoid-3d.png"
                                        alt="3D motion"
                                        class="factoid-img"
                                    />
                                </div>
                            )}
                            {index === 1 && (
                                <div class="factoid factoid-small">
                                    <img
                                        src="/photos/factoid-delivered.png"
                                        alt="Delivered in 4 days"
                                        class="factoid-img"
                                    />
                                </div>
                            )}
                            <figcaption class="portfolio-caption">
                                <div class="portfolio-title">{p.title}</div>
                                <div class="portfolio-desc">{p.shortDescription}</div>
                                <div class="portfolio-meta">
                                    <span class="portfolio-category">{p.category}</span>
                                    {p.year && <span class="portfolio-year">{p.year}</span>}
                                </div>
                            </figcaption>
                        </a>
                    );
                })
            }
        </div>
    </div>

    <!-- End decoration SVG -->
    <div class="decoration decoration-end">
        <img src="/photos/end.svg" alt="End decoration" class="decoration-svg" />
    </div>
</section>

<script>
  // Portfolio filtering functionality
  document.addEventListener('DOMContentLoaded', function() {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const portfolioItems = document.querySelectorAll('.portfolio-card');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', function(this: HTMLElement) {
        // Remove active class from all buttons
        filterBtns.forEach(b => b.classList.remove('active'));
        // Add active class to clicked button
        this.classList.add('active');

        const filterValue = this.getAttribute('data-filter');

        portfolioItems.forEach(item => {
          const htmlItem = item as HTMLElement;
          if (filterValue === '*') {
            htmlItem.style.display = 'block';
            htmlItem.style.animation = 'fadeIn 0.5s ease';
          } else {
            const itemCategory = item.getAttribute('data-category');
            if (itemCategory === filterValue) {
              htmlItem.style.display = 'block';
              htmlItem.style.animation = 'fadeIn 0.5s ease';
            } else {
              htmlItem.style.display = 'none';
            }
          }
        });
      });
    });
  });
</script>

<style>
    .headline {
        font-family: var(--font-heading);
        font-size: 2rem;
        font-weight: 600;
        color: #fff;
        margin: 0 auto;
        padding: 0 1rem;
        max-width: 1300px;
        margin-bottom: 1rem;
        text-align: center;
    }

    @media (min-width: 768px) {
        .headline {
            font-size: 2.5rem;
            padding: 0 1.5rem;
            margin-bottom: 1.5rem;
        }
    }

    @media (min-width: 1024px) {
        .headline {
            font-size: 3rem;
            margin-bottom: 2rem;
        }
    }

    .portfolio-subtitle {
        font-size: 1.1rem;
        color: rgba(255, 255, 255, 0.8);
        text-align: center;
        margin: 0 auto 3rem auto;
        max-width: 600px;
        line-height: 1.4;
        font-family: 'Manrope', var(--font-sans);
    }

    .filter-bar {
        margin-bottom: 3rem;
        display: flex;
        justify-content: center;
    }

    .filter-container {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        justify-content: center;
    }

    .filter-btn {
        background: rgba(255, 255, 255, 0.1);
        border: 2px solid rgba(255, 255, 255, 0.2);
        padding: 0.6rem 1.5rem;
        border-radius: 2rem;
        font-family: 'Manrope', var(--font-sans);
        font-size: 0.9rem;
        font-weight: 600;
        color: #fff;
        cursor: pointer;
        transition: all 0.3s ease;
        backdrop-filter: blur(10px);
    }

    .filter-btn:hover,
    .filter-btn.active {
        background: #fff;
        border-color: #fff;
        color: #000;
        transform: translateY(-2px);
    }

    .portfolio-section {
        width: 100%;
        justify-content: center;
    }
    .portfolio-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
        width: 100%;
        max-width: 1300px;
        padding: 0;
        margin: 0 auto;
    }
    .portfolio-card {
        width: 100%;
        margin: 0;
        padding: 0;
        position: relative;
        display: flex;
        flex-direction: column;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.2s ease;
        aspect-ratio: 4/3;
    }
    .portfolio-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        background: var(--site-bg);
    }
    .portfolio-caption {
        position: absolute;
        bottom: 1rem;
        left: 1.5rem;
        padding: 0;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.25rem;
        z-index: 2;
        max-width: calc(100% - 4rem);
    }
    .portfolio-title {
        font-family: 'Manrope', var(--font-sans);
        font-size: 32px;
        font-weight: 800;
        color: #fff;
        opacity: 1;
        margin: 0;
        line-height: 1.2;
        transition: all 0.2s ease;
    }
    .portfolio-desc {
        font-size: 16px;
        color: #fff;
        opacity: 0.7;
        font-family: 'Manrope', var(--font-sans);
        line-height: 1.2;
        margin: 0;
        font-weight: 400;
        transition: all 0.2s ease;
    }

    .portfolio-meta {
        display: flex;
        gap: 0.75rem;
        margin-top: 0.5rem;
        flex-wrap: wrap;
    }

    .portfolio-category,
    .portfolio-year {
        font-size: 11px;
        color: #000;
        background: rgba(255, 255, 255, 0.9);
        padding: 0.25rem 0.6rem;
        border-radius: 12px;
        font-family: 'Manrope', var(--font-sans);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        backdrop-filter: blur(4px);
    }

    /* Hover effects for the entire card */
    .portfolio-card:hover .portfolio-title,
    .portfolio-card:hover .portfolio-desc {
        opacity: 0.6;
    }

    /* Full-width card styles */
    .portfolio-card:nth-child(3n+1) {
        grid-column: 1 / -1;
        aspect-ratio: 16/9;
    }

    .portfolio-card:nth-child(3n+1) .portfolio-img {
        height: 100%;
    }

    .portfolio-card:nth-child(3n+1) .portfolio-caption {
        bottom: 1rem;
        left: 1.5rem;
    }

    @media (max-width: 768px) {
        .portfolio-section {
            width: 100vw;
            margin-left: calc(-50vw + 50%);
            margin-right: calc(-50vw + 50%);
        }
        
        .portfolio-grid {
            grid-template-columns: repeat(2, 1fr);
            padding: 0 1rem;
            gap: 0.5rem;
            max-width: 100%;
        }
        
        .portfolio-card {
            aspect-ratio: 3/4;
        }
        
        .portfolio-card:nth-child(3n+1) {
            grid-column: 1 / -1;
            aspect-ratio: 16/9;
        }
        
        .portfolio-img {
            height: 100%;
        }
        
        .portfolio-card:nth-child(3n+1) .portfolio-img {
            height: 100%;
        }
        
        .portfolio-caption {
            bottom: 1rem;
            left: 1.5rem;
            flex-direction: column;
            gap: 0.25rem;
            max-width: calc(100% - 2rem);
        }
        
        .portfolio-title {
            font-size: 20px;
        }
        
        .portfolio-desc {
            font-size: 12px;
        }
        
        .portfolio-card:nth-child(3n+1) .portfolio-caption {
            bottom: 1rem;
            left: 1.5rem;
        }

        .filter-container {
            gap: 0.5rem;
        }

        .filter-btn {
            padding: 0.5rem 1rem;
            font-size: 0.8rem;
        }

        .portfolio-subtitle {
            font-size: 1rem;
            margin-bottom: 2rem;
            padding: 0 1rem;
        }
    }

    .factoid {
        position: absolute;
        top: -2rem;
        right: -2rem;
        width: 120px;
        height: 120px;
        z-index: 2;
    }

    .factoid-img {
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        object-fit: contain;
        z-index: 1;
        pointer-events: none;
    }

    .factoid-small {
        width: 120px;
        height: 120px;
        top: -2rem;
        left: -2rem;
        right: auto;
    }

    @media (max-width: 768px) {
        .factoid {
            top: -1rem;
            right: -1rem;
            width: 80px;
            height: 80px;
        }
        
        .factoid-small {
            width: 80px;
            height: 80px;
            top: -1rem;
            left: -1rem;
            right: auto;
        }
    }

    .portfolio-content {
        width: 100%;
        background: #000;
        padding: 3rem 3rem;
    }

    @media (max-width: 768px) {
        .portfolio-content {
            padding: 3rem 1rem;
        }
        
        .portfolio-section {
            width: 100vw;
            margin-left: calc(-50vw + 50%);
            margin-right: calc(-50vw + 50%);
        }
    }

    .decoration {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .decoration svg {
        width: 100%;
        height: 100%;
    }

    .decoration-svg {
        width: 100%;
        object-fit: contain;
    }

    @media (max-width: 768px) {
        .decoration {
            width: 100vw;
            margin-left: calc(-50vw + 50%);
            margin-right: calc(-50vw + 50%);
        }
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>