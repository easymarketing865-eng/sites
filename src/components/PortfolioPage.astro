---
// @ts-nocheck
/**
 * PortfolioPage.astro
 * Full portfolio page using the designer's approved styles from Portfolio component
 */
import "../styles/global.css";
import { content, pb } from "../lib/pocketbase.js";
// Fallback to JSON data if PocketBase is not available
import portfolioData from "../data/portfolio.json";

let allProjects = [];

// Helper function to get image URL
function getImageUrl(project: any) {
    // First try to get the photo file if it exists
    if (project.photo) {
        return pb.files.getURL(project, project.photo);
    }
    
    // If no photo file, try the first gallery image
    if (project.gallery && project.gallery.length > 0) {
        return pb.files.getURL(project, project.gallery[0]);
    }
    
    // Try image field
    if (project.image) {
        return pb.files.getURL(project, project.image);
    }
    
    // Fallback to hero field (static URL)
    return project.hero || '/photos/placeholder.webp';
}

// Helper function to get video URL
function getVideoUrl(project: any) {
    // Handle video URLs
    if (project.video) {
        return pb.files.getURL(project, project.video);
    }
    
    if (project.videoField && typeof project.videoField === 'string' && project.videoField.length > 10) {
        return pb.files.getURL(project, project.videoField);
    }
    
    return null;
}

try {
  // Try to fetch from PocketBase using the same method as Hero
  const result = await content.getHeroProjects(50); // Get more projects for portfolio page
  allProjects = result.items || [];
  console.log(`Loaded ${allProjects.length} projects from PocketBase for Portfolio Page`);
  
  // Generate URLs for projects
  allProjects = allProjects.map(project => {
    // Handle video URLs
    const videoUrl = getVideoUrl(project);
    if (videoUrl) {
        project.videoUrl = videoUrl;
        console.log(`Generated video URL for ${project.title}: ${project.videoUrl}`);
    }
    
    // Handle image URLs
    project.imageUrl = getImageUrl(project);
    console.log(`Generated image URL for ${project.title}: ${project.imageUrl}`);
    
    return project;
  });
  
  // If no projects from PocketBase, use fallback
  if (allProjects.length === 0) {
    throw new Error('No projects found in PocketBase');
  }
} catch (error) {
  console.log('PocketBase not available for Portfolio Page, using JSON fallback:', (error as Error).message);
  // Fallback to JSON data
  const allPortfolioProjects = [...(portfolioData.featured || []), ...(portfolioData.portfolio || [])];
  allProjects = allPortfolioProjects;
  console.log(`Using JSON fallback: ${allProjects.length} projects`);
}
---

<section class="portfolio-section" id="portfolio">
    <div class="portfolio-content">
        

        <div class="portfolio-grid">
            {allProjects.map((project, index) => (
                <a href={`/portfolio/${(project as any).id || project.slug}`} class="portfolio-card" data-category={(project as any).category || 'Commercial'}>
                    {/* Video thumbnail with image fallback - SAME AS HERO */}
                    {((project as any).videoUrl || (project as any).videoThumbnail || (project as any).videoField) ? (
                        <video 
                            class="portfolio-video"
                            autoplay 
                            muted 
                            loop 
                            playsinline
                            preload="metadata"
                            poster={(project as any).imageUrl || project.hero || `https://i.ytimg.com/vi/${project.videoId}/maxresdefault.jpg`}
                        >
                            <source src={(project as any).videoUrl || (project as any).videoThumbnail || (project as any).videoField} type="video/mp4" />
                            {/* Fallback to image if video fails */}
                            <img
                                src={(project as any).imageUrl || project.hero || `https://i.ytimg.com/vi/${project.videoId}/maxresdefault.jpg`}
                                alt={project.title}
                                class="portfolio-img"
                                loading="lazy"
                            />
                        </video>
                    ) : (
                        <img
                            src={(project as any).imageUrl || project.hero || `https://i.ytimg.com/vi/${project.videoId}/maxresdefault.jpg`}
                            alt={project.title}
                            class="portfolio-img"
                            loading="lazy"
                        />
                    )}
                    
                    
                    <img src="/photos/top-left.svg" alt="" class="corner-svg top-left" />
                    <img src="/photos/bottom-right.svg" alt="" class="corner-svg bottom-right" />
                    <span class="project-label">{project.title}</span>
                </a>
            ))}
        </div>
    </div>
</section>



<style>
    .headline {
        font-family: var(--font-heading);
        font-size: 2rem;
        font-weight: 600;
        color: #ffffff;
        margin: 0 auto;
        padding: 0 1rem;
        max-width: 1300px;
        margin-bottom: 1rem;
        text-align: center;
    }

    @media (min-width: 768px) {
        .headline {
            font-size: 2.5rem;
            padding: 0 1.5rem;
            margin-bottom: 1.5rem;
        }
    }

    @media (min-width: 1024px) {
        .headline {
            font-size: 3rem;
            margin-bottom: 2rem;
        }
    }

    .portfolio-subtitle {
        font-size: 1.1rem;
        color: #ffffff;
        text-align: center;
        margin: 0 auto 3rem auto;
        max-width: 600px;
        line-height: 1.4;
        font-family: 'Manrope', var(--font-sans);
    }



    .portfolio-section {
        margin-top: -140px;
        position: relative;
        left: 50%;
        right: 50%;
        margin-left: -50vw;
        margin-right: -50vw;
        width: 100vw;
        display: grid;
        overflow: hidden;
        background: #000000;
    }

    .portfolio-grid {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        grid-template-rows: 70vh 500px 540px 530px 500px;
        
        width: 100%;
        
        margin: 0 auto;

    }

    /* Row 1: 1 featured project (70vh height) - LATEST PROJECT */
    .portfolio-card:nth-child(1) { 
        grid-column: 1 / 7; 
        grid-row: 1; 
    }

    /* Row 2: 3 projects (500px height) */
    .portfolio-card:nth-child(2) { 
        grid-column: 1 / 3; 
        grid-row: 2; 
    }
    .portfolio-card:nth-child(3) { 
        grid-column: 3 / 5; 
        grid-row: 2; 
    }
    .portfolio-card:nth-child(4) { 
        grid-column: 5 / 7; 
        grid-row: 2; 
    }

    /* Row 3: 2 projects (540px height) */
    .portfolio-card:nth-child(5) { 
        grid-column: 1 / 4; 
        grid-row: 3; 
    }
    .portfolio-card:nth-child(6) { 
        grid-column: 4 / 7; 
        grid-row: 3; 
    }

    /* Row 4: 3 projects (530px height) */
    .portfolio-card:nth-child(7) { 
        grid-column: 1 / 3; 
        grid-row: 4; 
    }
    .portfolio-card:nth-child(8) { 
        grid-column: 3 / 5; 
        grid-row: 4; 
    }
    .portfolio-card:nth-child(9) { 
        grid-column: 5 / 7; 
        grid-row: 4; 
    }

    /* Row 5: 3 projects (500px height) */
    .portfolio-card:nth-child(10) { 
        grid-column: 1 / 3; 
        grid-row: 5; 
    }
    .portfolio-card:nth-child(11) { 
        grid-column: 3 / 5; 
        grid-row: 5; 
    }
    .portfolio-card:nth-child(12) { 
        grid-column: 5 / 7; 
        grid-row: 5; 
    }

    .portfolio-card:nth-child(n+13) {
        display: none;
    }

    .portfolio-card {
        position: relative;
        overflow: hidden;
        cursor: pointer;
        text-decoration: none;
        display: block;
    }



    .portfolio-img,
    .portfolio-video {
        width: 100%;
        height: 100%;
        object-fit: cover;
  
        display: block;
    }

        .portfolio-video {
        /* Video-specific optimizations */
        background: #000;
    }

    /* Corner SVG styles - same as Hero */
    .corner-svg {
        position: absolute;
        width: 34px;
        height: 34px;
        z-index: 3;
        opacity: 0;
        transform: scale(0.5);
        transition: all 0.3s ease;
        pointer-events: none;
    }

    .corner-svg.top-left {
        top: 1rem;
        left: 1rem;
    }

    .corner-svg.bottom-right {
        bottom: 1rem;
        right: 1rem;
    }

    .portfolio-card:hover .corner-svg {
        opacity: 1;
        transform: scale(1);
    }

    /* Project label - same as Hero */
    .project-label {
        position: absolute;
        bottom: 1rem;
        left: 1rem;
        color: #ffffff;
        font-family: var(--font-sans);
        font-size: clamp(0.75rem, 1.5vw, 1rem);
        font-weight: 800;
        text-transform: uppercase;
        z-index: 5;
        border-radius: 2px;
        text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.8);
    }
    /* Mobile optimizations - updated for 12 projects */
    @media (max-width: 768px) {
        .portfolio-grid {
            grid-template-columns: 1fr 1fr;
            grid-template-rows: 50vh 350px 350px 400px 350px 400px;
         
            
        }

        /* Mobile: Stack differently for 12 projects */
        .portfolio-card:nth-child(1) { grid-column: 1 / 3; grid-row: 1; } /* Full width */
        .portfolio-card:nth-child(2) { grid-column: 1; grid-row: 2; }
        .portfolio-card:nth-child(3) { grid-column: 2; grid-row: 2; }
        .portfolio-card:nth-child(4) { grid-column: 1; grid-row: 3; }
        .portfolio-card:nth-child(5) { grid-column: 2; grid-row: 3; }
        .portfolio-card:nth-child(6) { grid-column: 1; grid-row: 4; }
        .portfolio-card:nth-child(7) { grid-column: 2; grid-row: 4; }
        .portfolio-card:nth-child(8) { grid-column: 1; grid-row: 5; }
        .portfolio-card:nth-child(9) { grid-column: 2; grid-row: 5; }
        .portfolio-card:nth-child(10) { grid-column: 1; grid-row: 6; }
        .portfolio-card:nth-child(11) { grid-column: 2; grid-row: 6; }
        .portfolio-card:nth-child(12) { grid-column: 1 / 3; grid-row: 7; } /* Full width last */
    }

    @media (max-width: 480px) {
        .portfolio-grid {
            grid-template-columns: 1fr;
            grid-template-rows: 40vh repeat(11, 300px);
            
        }

        .portfolio-card:nth-child(n) {
            grid-column: 1 !important;
            grid-row: unset !important;
        }

        .project-label {
            font-size: 0.8rem;
        }
    }



        .portfolio-content {
        width: 100%;
      
        }


</style>