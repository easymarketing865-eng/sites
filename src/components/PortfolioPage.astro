---
/**
 * PortfolioPage.astro
 * Simple portfolio page with full-width YouTube players
 */
import "../styles/global.css";
import { projects } from "../lib/pocketbase.js";
// Fallback to JSON data if PocketBase is not available
import portfolioData from "../data/portfolio.json";

let allProjects = [];

try {
  // Try to fetch from PocketBase
  const result = await projects.getAll(1, 50);
  allProjects = result.items || [];
  console.log(`Loaded ${allProjects.length} projects from PocketBase`);
} catch (error) {
  console.log('PocketBase not available, using JSON fallback:', (error as Error).message);
  // Fallback to JSON data
  allProjects = [...portfolioData.featured, ...portfolioData.portfolio];
}
---

<section class="portfolio-section">
    <div class="portfolio-content">
        <h1 class="portfolio-title">Portfolio</h1>
        
        <div class="videos-container">
            {allProjects.map((project: any) => (
                <div class="video-item">
                    <h2 class="video-title">{project.title}</h2>
                    <div class="video-player">
                        <iframe
                            src={`https://www.youtube.com/embed/${project.videoId}`}
                            title={project.title}
                            frameborder="0"
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                            allowfullscreen
                        ></iframe>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<style>
    .portfolio-section {
        width: 100%;
        min-height: 100vh;
        background: var(--site-bg);
        padding: 2rem 0;
    }

    .portfolio-content {
        max-width: 100%;
        margin: 0 auto;
        padding: 0 2rem;
    }

    .portfolio-title {
        font-family: var(--font-heading);
        font-size: 3rem;
        font-weight: 700;
        color: var(--brand-black);
        text-align: center;
        margin: 0 0 3rem 0;
        letter-spacing: -0.02em;
    }

    .videos-container {
        display: flex;
        flex-direction: column;
        gap: 4rem;
        max-width: 1400px;
        margin: 0 auto;
    }

    .video-item {
        width: 100%;
    }

    .video-title {
        font-family: var(--font-sans);
        font-size: 2rem;
        font-weight: 600;
        color: var(--brand-black);
        margin: 0 0 1rem 0;
        text-align: left;
    }

    .video-player {
        position: relative;
        width: 100%;
        height: 0;
        padding-bottom: 56.25%; /* 16:9 aspect ratio */
        background: #000;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
    }

    .video-player iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border: none;
        border-radius: 12px;
    }

    /* Responsive Design */
    @media (max-width: 768px) {
        .portfolio-content {
            padding: 0 1rem;
        }

        .portfolio-title {
            font-size: 2.5rem;
            margin-bottom: 2rem;
        }

        .videos-container {
            gap: 3rem;
        }

        .video-title {
            font-size: 1.5rem;
            margin-bottom: 0.75rem;
        }

        .video-player {
            border-radius: 8px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        }

        .video-player iframe {
            border-radius: 8px;
        }
    }

    @media (max-width: 480px) {
        .portfolio-content {
            padding: 0 0.5rem;
        }

        .portfolio-title {
            font-size: 2rem;
            margin-bottom: 1.5rem;
        }

        .videos-container {
            gap: 2rem;
        }

        .video-title {
            font-size: 1.25rem;
            margin-bottom: 0.5rem;
        }

        .video-player {
            border-radius: 6px;
        }

        .video-player iframe {
            border-radius: 6px;
        }
    }
</style>