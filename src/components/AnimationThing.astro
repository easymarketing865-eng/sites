---
import { TYPICAL_CLIENT_PROBLEMS, AGENCY_WORDS_30 } from "./constants";
const problems = TYPICAL_CLIENT_PROBLEMS.slice(0, 4);
const solutions = AGENCY_WORDS_30.slice(0, 4);
---

<div class="anim-line-container">
    <div class="anim-line">
        <span id="problem" class="anim-problem"></span>
        <img
            src="/photos/headshot.webp"
            alt="Team headshot"
            class="center-photo"
        />
        <span id="solution" class="anim-solution"></span>
    </div>
</div>

<script type="module" client:load define:vars={{ problems, solutions }}>
    let problemIdx = 0;
    let solutionIdx = 0;
    const problemSpan = document.getElementById("problem");
    const solutionSpan = document.getElementById("solution");
    const PROBLEM_DURATION = 1500; // ms
    const FADE_OVERLAP = 320; // ms for fade before photo edge
    const SOLUTION_DURATION = 1350; // ms
    const PAUSE_BETWEEN = 560; // ms

    function resetClass(el, classList) {
        el.classList.remove(...classList);
        void el.offsetWidth;
    }

    function moveWord(
        span,
        text,
        inTransform,
        inDuration,
        fadeoutTransform,
        fadeOverlap,
        onDone,
    ) {
        span.textContent = text;
        span.style.transform = inTransform;
        resetClass(span, ["in", "fadeout"]);
        setTimeout(() => {
            span.classList.add("in");
            setTimeout(() => {
                span.classList.add("fadeout");
                span.style.transform = fadeoutTransform; // move and fade left
                setTimeout(() => {
                    span.textContent = "";
                    resetClass(span, ["in", "fadeout"]);
                    onDone && onDone();
                }, fadeOverlap);
            }, inDuration - fadeOverlap);
        }, 20);
    }

    function runAnimation() {
        problemSpan.textContent = "";
        solutionSpan.textContent = "";
        resetClass(problemSpan, ["in", "fadeout"]);
        resetClass(solutionSpan, ["out"]);

        // Animate problem in gray, fade left just before photo
        moveWord(
            problemSpan,
            problems[problemIdx],
            "translate(-50%, -50%)",
            PROBLEM_DURATION,
            "translate(100px, -50%)",
            FADE_OVERLAP,
            () => {
                // Then solution in red, sliding out
                solutionSpan.textContent = solutions[solutionIdx];
                solutionSpan.classList.add("out");
                setTimeout(() => {
                    solutionSpan.textContent = "";
                    solutionSpan.classList.remove("out");
                    problemIdx = (problemIdx + 1) % problems.length;
                    solutionIdx = (solutionIdx + 1) % solutions.length;
                    setTimeout(runAnimation, PAUSE_BETWEEN);
                }, SOLUTION_DURATION);
            },
        );
    }

    runAnimation();
</script>

<style>
    .anim-line-container {
        width: 100vw;
        height: 60vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: #fff;
        overflow: hidden;
    }
    .anim-line {
        position: relative;
        display: flex;
        align-items: center;
        width: 520px;
        max-width: 96vw;
        justify-content: center;
    }
    .center-photo {
        position: absolute;
        left: 20%;
        width: 280px;
        height: 280px;
        /* border-radius: 50%; */
        object-fit: cover;
        margin: 0 80px;
        /* box-shadow:
            0 2px 72px #23232324,
            0 0 0 10px #fff,
            0 0 0 16px #1ba45922; */
        flex-shrink: 0;
        z-index: 1;
        border: 4px solid #fff;
        outline: 3px solid #1ba45921;
        transition:
            width 0.3s,
            height 0.3s,
            margin 0.3s;

        z-index: 1;
    }
    .anim-problem,
    .anim-solution {
        display: inline-block;
        min-width: 70px;
        max-width: 35vw;
        font-size: 1.55rem;
        font-weight: 700;
        white-space: nowrap;
        opacity: 0;
        pointer-events: none;
        position: absolute;
        top: 50%;
        z-index: 2;
        transition:
            opacity 0.18s,
            transform 0.5s;
    }
    .anim-problem {
        left: 0;
        color: #888;
        font-family: "Inter", "Segoe UI", Arial, Helvetica, sans-serif;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        transform: translate(-120%, -50%);
        transition:
            opacity 0.18s,
            transform 0.5s;
    }
    .anim-problem.in {
        opacity: 1;
        color: #888;
        transition:
            transform 1.5s cubic-bezier(0.19, 0.84, 0.46, 1.1),
            opacity 0.36s cubic-bezier(0.44, 0, 0.43, 1);
    }
    .anim-problem.in.fadeout {
        opacity: 0;
        color: #888;
        transition:
            opacity 0.28s cubic-bezier(0.37, 0.08, 0.73, 0.9),
            transform 0.1s;
    }

    /* The problem lands just left of centered photo, then fades out */

    .anim-solution {
        right: 0;
        color: #a00000;
        font-family:
            "Montserrat", "Inter", "Segoe UI", Arial, Helvetica, sans-serif;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.11em;
        transform: translate(calc(-200px - 36px), -50%);
        transition:
            opacity 0.18s,
            transform 0.5s;
    }
    .anim-solution.out {
        opacity: 1;
        color: #a00000;
        /* Moves out to right beyond center-photo */
        transform: translate(120%, -50%);
        transition:
            transform 1.5s cubic-bezier(0.35, 0.8, 0.48, 1.02),
            opacity 0.36s cubic-bezier(0.44, 0.23, 0.43, 1);
    }

    @media (max-width: 800px) {
        .center-photo {
            width: 100px;
            height: 100px;
            margin: 0 16px;
        }
        .anim-line {
            width: 270px;
        }
        .anim-problem,
        .anim-solution {
            font-size: 1.05rem;
        }
    }
</style>
