---
import { AGENCY_WORDS_30 } from "./constants";
const problems = [
  "brand confusion",
  "low engagement",
  "weak storytelling",
  "poor visuals"
];
const solutions = AGENCY_WORDS_30.slice(0, 4);
---

<section class="animation-section">
    <div class="animation-text">
        <h2 class="headline">Agency In Action</h2>
        <p class="animation-description">Watch how we transform common challenges into breakthrough solutions. Our creative process turns obstacles into opportunities, delivering results that exceed expectations.</p>
    </div>

    <div class="anim-line-container">
    <div class="anim-line">
        <span id="problem" class="anim-problem"></span>
        <img
            src="/photos/headshot.webp"
            alt="Team headshot"
            class="center-photo"
        />
        <span id="solution" class="anim-solution"></span>
    </div>
</section>

<script type="module" define:vars={{ problems, solutions }}>
    let idx = 0;
    const problemSpan = document.getElementById("problem");
    const solutionSpan = document.getElementById("solution");
    
    function updateText() {
        // Reset animations by removing and re-adding classes
        problemSpan.classList.remove('animate');
        solutionSpan.classList.remove('animate');
        
        // Update text content
        problemSpan.innerHTML = problems[idx].split(' ').join('<br/>');
        solutionSpan.innerHTML = solutions[idx].split(' ').join('<br/>');
        
        // Trigger animations after a small delay
        requestAnimationFrame(() => {
            problemSpan.classList.add('animate');
            setTimeout(() => {
                solutionSpan.classList.add('animate');
            }, 2000); // Solution starts 2 seconds after problem
        });
        
        idx = (idx + 1) % problems.length;
    }
    
    updateText();
    setInterval(updateText, 6000);
</script>

<style>
    .animation-section {
        width: 100%;
        max-width: 1200px;
        margin: 4rem auto;
        padding: 2rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 3rem;
    }

    .animation-text {
        text-align: center;
        max-width: 600px;
    }

    .headline {
        font-family: var(--font-sans);
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--brand-black, #222);
        margin: 0 0 1rem 0;
    }

    .animation-description {
        font-family: var(--font-sans);
        font-size: 1.1rem;
        line-height: 1.6;
        color: var(--brand-black, #666);
        margin: 0;
    }

    .anim-line-container {
        width: 100%;
        height: 40vh;
        max-height: 400px;
        display: flex;
        justify-content: center;
        align-items: center;
        background: #fff;
        overflow: hidden;
        border-radius: 1rem;
        border: 2px solid #f0f0f0;
    }
    
    .anim-line {
        position: relative;
        display: flex;
        align-items: center;
        width: 520px;
        max-width: 96vw;
        justify-content: center;
    }
    
    .center-photo {
        width: 40vw;
        max-width: 200px;
        height: auto;
        object-fit: cover;
        border: 3px solid #fff;
        outline: 2px solid #1ba45921;
        border-radius: 0.5rem;
        z-index: 1;
        transition: all 0.3s ease;
    }
    
    .anim-problem,
    .anim-solution {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        font-size: 1.2rem;
        font-weight: 700;
        white-space: nowrap;
        pointer-events: none;
        z-index: 2;
        opacity: 0;
    }
    
    .anim-problem {
        left: -100px;
        color: #888;
    }
    
    .anim-problem.animate {
        animation: problemFlow 4s ease-in-out forwards;
    }
    
    .anim-solution {
        left: 50%;
        transform: translate(-50%, -50%);
        color: #a00000;
        font-weight: 900;
    }
    
    .anim-solution.animate {
        animation: solutionFlow 3s ease-in-out forwards;
    }
    
    @keyframes problemFlow {
        0% {
            left: -100px;
            opacity: 0;
        }
        20% {
            opacity: 1;
        }
        50% {
            left: 40%;
            opacity: 1;
        }
        80% {
            left: 40%;
            opacity: 1;
        }
        100% {
            left: 40%;
            opacity: 0;
        }
    }
    
    @keyframes solutionFlow {
        0% {
            left: 50%;
            opacity: 0;
        }
        20% {
            opacity: 1;
        }
        80% {
            left: calc(100% + 100px);
            opacity: 1;
        }
        100% {
            left: calc(100% + 100px);
            opacity: 0;
        }
    }
    
    @media (max-width: 800px) {
        .animation-section {
            margin: 2rem auto;
            padding: 1rem;
            gap: 2rem;
        }

        .headline {
            font-size: 2rem;
        }

        .animation-description {
            font-size: 1rem;
        }

        .anim-line-container {
            height: 30vh;
            max-height: 300px;
        }

        .center-photo {
            width: 60vw;
            max-width: 150px;
        }
        
        .anim-problem,
        .anim-solution {
            font-size: 0.9rem;
            max-width: 100px;
            word-break: break-word;
            white-space: normal;
            text-align: center;
        }
        
        .anim-problem {
            left: -80px;
        }
        
        @keyframes problemFlow {
            0% {
                left: -80px;
                opacity: 0;
            }
            20% {
                opacity: 1;
            }
            50% {
                left: 30%;
                opacity: 1;
            }
            80% {
                left: 30%;
                opacity: 1;
            }
            100% {
                left: 30%;
                opacity: 0;
            }
        }
        
        @keyframes solutionFlow {
            0% {
                left: 50%;
                opacity: 0;
            }
            20% {
                opacity: 1;
            }
            80% {
                left: calc(100% + 80px);
                opacity: 1;
            }
            100% {
                left: calc(100% + 80px);
                opacity: 0;
            }
        }
    }
</style>