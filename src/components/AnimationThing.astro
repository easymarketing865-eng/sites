---
import { TYPICAL_CLIENT_PROBLEMS, AGENCY_WORDS_30 } from "./constants";
const problems = TYPICAL_CLIENT_PROBLEMS.slice(0, 4);
const solutions = AGENCY_WORDS_30.slice(0, 4);
---

<div class="anim-line-container">
    <div class="anim-line">
        <span id="problem" class="anim-problem"></span>
        <img
            src="/photos/headshot.webp"
            alt="Team headshot"
            class="center-photo"
        />
        <span id="solution" class="anim-solution"></span>
    </div>
</div>

<script type="module" define:vars={{ TYPICAL_CLIENT_PROBLEMS, AGENCY_WORDS_30 }}
>
    // import { TYPICAL_CLIENT_PROBLEMS, AGENCY_WORDS_30 } from "./constants";
    const problems = TYPICAL_CLIENT_PROBLEMS.slice(0, 4);
    const solutions = AGENCY_WORDS_30.slice(0, 4);
    let idx = 0;
    let phase = 0; // 0: problem moving in, 1: solution moving out
    const problemSpan = document.getElementById("problem");
    const solutionSpan = document.getElementById("solution");
    const PROBLEM_DURATION = 1500; // ms
    const FADE_OVERLAP = 300; // ms for fade on photo
    const SOLUTION_DURATION = 1500; // ms
    const PAUSE_BETWEEN = 500; // ms

    function resetClass(el, classList) {
        el.classList.remove(...classList);
        // force reflow for restart
        void el.offsetWidth;
    }

    function runAnimation() {
        // Reset both spans
        problemSpan.textContent = "";
        solutionSpan.textContent = "";
        resetClass(problemSpan, ["in", "fadeout"]);
        resetClass(solutionSpan, ["out"]);

        // Start problem slide-in
        problemSpan.textContent = problems[idx];
        problemSpan.classList.add("in");
        setTimeout(() => {
            // Start fadeout on problem just before it reaches the image center
            problemSpan.classList.add("fadeout");
            setTimeout(() => {
                // Remove problem, start solution
                problemSpan.textContent = "";
                problemSpan.classList.remove("in", "fadeout");
                // Solution starts at center and slides out right
                solutionSpan.textContent = solutions[idx];
                solutionSpan.classList.add("out");
                setTimeout(() => {
                    // Clear solution and advance index
                    solutionSpan.textContent = "";
                    solutionSpan.classList.remove("out");
                    idx = (idx + 1) % problems.length;
                    setTimeout(runAnimation, PAUSE_BETWEEN);
                }, SOLUTION_DURATION);
            }, FADE_OVERLAP);
        }, PROBLEM_DURATION - FADE_OVERLAP);
    }

    runAnimation();
</script>

<style>
    .anim-line-container {
        width: 100vw;
        height: 60vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: #fff;
        overflow: hidden;
    }
    .anim-line {
        position: relative;
        display: flex;
        align-items: center;
        width: 520px;
        max-width: 96vw;
        justify-content: center;
    }
    .center-photo {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        object-fit: cover;
        margin: 0 36px;
        box-shadow: 0 2px 24px #23232318;
        flex-shrink: 0;
        z-index: 1;
    }
    .anim-problem,
    .anim-solution {
        display: inline-block;
        min-width: 70px;
        max-width: 35vw;
        font-size: 1.55rem;
        font-weight: 700;
        white-space: nowrap;
        color: blue;
        opacity: 0;
        pointer-events: none;
        position: absolute;
        top: 50%;
        z-index: 2;
        transition:
            opacity 0.18s,
            transform 0.5s;
    }
    .anim-problem {
        left: 0;
        color: #232323;
        transform: translate(-120%, -50%);
    }
    .anim-problem.in {
        opacity: 1;
        transform: translate(calc(200px + 36px), -50%);
        transition:
            transform 1.5s cubic-bezier(0.19, 0.84, 0.46, 1.1),
            opacity 0.36s cubic-bezier(0.44, 0, 0.43, 1);
    }
    .anim-problem.in.fadeout {
        opacity: 0;
        /* Stays at photo edge; fade quickly */
        transform: translate(calc(200px + 36px), -50%);
        transition:
            opacity 0.28s cubic-bezier(0.37, 0.08, 0.73, 0.9),
            transform 0s;
    }

    /* The problem lands just left of centered photo, then fades out */

    .anim-solution {
        right: 0;
        color: #1ba459;
        transform: translate(calc(-200px - 36px), -50%);
    }
    .anim-solution.out {
        opacity: 1;
        /* Moves out to right beyond center-photo */
        transform: translate(120%, -50%);
        transition:
            transform 1.5s cubic-bezier(0.35, 0.8, 0.48, 1.02),
            opacity 0.36s cubic-bezier(0.44, 0.23, 0.43, 1);
    }

    @media (max-width: 800px) {
        .center-photo {
            width: 100px;
            height: 100px;
            margin: 0 16px;
        }
        .anim-line {
            width: 270px;
        }
        .anim-problem,
        .anim-solution {
            font-size: 1.05rem;
        }
    }
</style>
