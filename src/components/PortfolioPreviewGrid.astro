---
/**
 * PortfolioPreviewGrid.astro
 * One-line horizontal grid portfolio preview component
 * Props: startIndex (default: 0), toShow (default: 4)
 * Uses PocketBase to fetch dynamic portfolio data
 */
import "../styles/global.css";
import { projects, pb, content } from "../lib/pocketbase.js";
import { t, getLocaleFromUrl, getLocalizedPath } from "../lib/i18n.js";

export interface Props {
  startIndex?: number;
  toShow?: number;
  showTitle?: boolean;
  title?: string;
  className?: string;
  locale?: string;
}

const { 
  startIndex = 0, 
  toShow = 5, 
  showTitle = true, 
  title,
  className = "",
  locale
} = Astro.props;

// Get current locale from URL if not provided as prop
const currentLocale = locale || getLocaleFromUrl(Astro.url.pathname);

// Use translated title if none provided
const displayTitle = title || t(currentLocale, 'portfolio.title');

// Generate localized portfolio link
const portfolioLink = getLocalizedPath('/portfolio', currentLocale);

// Helper function to get image URL (PocketBase only)
function getImageUrl(project: any) {
    // First try to get the photo file if it exists
    if (project.photo) {
        return pb.files.getURL(project, project.photo);
    }
    
    // If no photo file, try the first gallery image
    if (project.gallery && project.gallery.length > 0) {
        return pb.files.getURL(project, project.gallery[0]);
    }
    
    // Try image field
    if (project.image) {
        return pb.files.getURL(project, project.image);
    }
    
    // No local photo fallbacks - only PocketBase files
    return '';
}

// Fast fetch for service projects without retry delays
async function fetchServiceProjects() {
        try {
        // Use the unified page data for faster loading
        const pageData = await content.getPageData('home');
        const serviceProjects = pageData.serviceProjects || [];
        console.log(`✅ PortfolioPreviewGrid: Fetched ${serviceProjects.length} service projects from unified data`);
        return serviceProjects;
        } catch (error) {
        console.error('❌ PortfolioPreviewGrid: Failed to fetch service projects:', error);
                return [];
            }
}

// Fetch projects from PocketBase using optimized method
let allProjects: any[] = [];
try {
    allProjects = await fetchServiceProjects();
    console.log(`🎯 PortfolioPreviewGrid: Using ${allProjects.length} service_production projects`);
} catch (error) {
    console.error('❌ Fatal error in PortfolioPreviewGrid:', error);
    allProjects = [];
}

// Transform and slice projects for display
const displayProjects = allProjects.slice(startIndex, startIndex + toShow).map(project => ({
    id: project.id,
    title: project.title,
    img: getImageUrl(project),
    desc: project.shortDescription || project.description || '',
    slug: project.slug,
    services: project.services || [],
    category: project.category || 'project'
}));

// Log for debugging
console.log(`📊 PortfolioPreviewGrid: Displaying ${displayProjects.length} projects (${startIndex}-${startIndex + toShow})`);
---

<section class={`portfolio-preview-grid ${className}`}>
    {showTitle && (
        <h2 class="grid-title emerge" data-effect="slide" data-up="30px" data-expose="true">{displayTitle}</h2>
    )}
    
    <div class="grid-container">
        <div class="grid-scroll">
            {
                displayProjects.map((project, index) => (
                    <a href={`/portfolio/${project.slug}`} 
                       class="grid-item emerge" 
                       data-effect="slide" 
                       data-up="40px"
                       data-duration="600"
                       data-hold={index * 150}
                       data-expose="true">
                        <div class="grid-image-container">
                            {project.img && (
                                <img
                                    src={project.img}
                                    alt={`${project.title} project image`}
                                    class="grid-img"
                                    loading="lazy"
                                />
                            )}
                        </div>
                        <div class="grid-info">
                            <h3 class="grid-project-title">{project.title}</h3>
                            <p class="grid-project-desc">{project.desc}</p>
                        </div>
                    </a>
                ))
            }
        </div>
    </div>
    
    <div class="portfolio-link-container">
        <a href={portfolioLink} class="btn btn-secondary">{t(currentLocale, 'portfolio.viewFull')}</a>
    </div>
</section>

<style>
    .portfolio-preview-grid {
        width: 100%;
        margin: 4rem 0;
        border-radius: 8px;
    }

    .grid-title {
        color: #fff;
        margin-bottom: 1.5rem;
        text-align: left;

    }

    .grid-container {
        width: 100%;
        overflow: hidden;
    }

    .grid-scroll {
        display: flex;
        gap: 0.5rem;
        overflow-x: auto;
        scroll-behavior: smooth;
        scrollbar-width: thin;
        scrollbar-color: rgba(255, 255, 255, 0.3) transparent;
    }

    .grid-scroll::-webkit-scrollbar {
        height: 6px;
    }

    .grid-scroll::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 3px;
    }

    .grid-scroll::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.3);
        border-radius: 3px;
    }

    .grid-scroll::-webkit-scrollbar-thumb:hover {
        background: rgba(255, 255, 255, 0.5);
    }

    .grid-item {
        flex: 0 0 280px;
        text-decoration: none;
        cursor: pointer;
    }

    .grid-image-container {
        position: relative;
        aspect-ratio: 4/3;
        border-radius: 8px;
        overflow: hidden;
        margin-bottom: 1rem;
    }

    .grid-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .grid-info {
        color: #fff;
        padding: 0 0.25rem;
    }

    .grid-project-title {
        margin: 0 0 0.5rem 0;
        color: #fff;
    }

    .grid-project-desc {
        opacity: 0.8;
        margin: 0;
        color: #fff;
    }

    @media (max-width: 768px) {
        .grid-title {
            font-size: 1.5rem;
            padding: 0 0.5rem;
            margin-bottom: 1rem;
        }

        .grid-scroll {
            gap: 1rem;
            padding: 0.5rem 0.5rem;
        }

        .grid-item {
            flex: 0 0 220px;
        }

        .grid-image-container {
            aspect-ratio: 3/2;
            margin-bottom: 0.75rem;
        }

        .grid-project-title {
            font-size: 1rem;
        }

        .grid-project-desc {
            font-size: 0.8rem;
        }
    }

    @media (max-width: 480px) {
        .grid-scroll {
            padding: 0.5rem 0.25rem;
        }

        .grid-item {
            flex: 0 0 180px;
        }

        .grid-image-container {
            border-radius: 6px;
        }
    }

    /* Hide scrollbar on mobile for cleaner look */
    @media (max-width: 768px) {
        .grid-scroll {
            scrollbar-width: none;
            -ms-overflow-style: none;
        }

        .grid-scroll::-webkit-scrollbar {
            display: none;
        }
    }

    .portfolio-link-container {
        display: flex;
        justify-content: center;
        margin-top: 3rem;
        padding: 0 1rem;
    }

    @media (max-width: 768px) {
        .portfolio-link-container {
            margin-top: 2rem;
        }
    }
</style>