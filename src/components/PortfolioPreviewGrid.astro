---
/**
 * PortfolioPreviewGrid.astro
 * One-line horizontal grid portfolio preview component
 * Props: startIndex (default: 0), toShow (default: 4)
 */
import "../styles/global.css";
import portfolioData from "../data/portfolio.json";

export interface Props {
  startIndex?: number;
  toShow?: number;
  showTitle?: boolean;
  title?: string;
  className?: string;
}

const { 
  startIndex = 0, 
  toShow = 4, 
  showTitle = true, 
  title = "Recent Work",
  className = ""
} = Astro.props;

// Combine featured and regular portfolio items
const allProjects = [...portfolioData.featured, ...portfolioData.portfolio];
const projects = allProjects.slice(startIndex, startIndex + toShow).map(project => ({
    title: project.title,
    img: project.hero,
    desc: project.shortDescription,
    slug: project.slug,
    services: project.services || [],
    category: project.category
}));
---

<section class={`portfolio-preview-grid ${className}`}>
    {showTitle && (
        <h2 class="grid-title">{title}</h2>
    )}
    
    <div class="grid-container">
        <div class="grid-scroll">
            {
                projects.map((project, index) => (
                    <a href={`/portfolio/${project.slug}`} class="grid-item">
                        <div class="grid-image-container">
                            <img
                                src={project.img}
                                alt={`${project.title} project image`}
                                class="grid-img"
                                loading="lazy"
                            />
                        </div>
                        <div class="grid-info">
                            <h3 class="grid-project-title">{project.title}</h3>
                            <p class="grid-project-desc">{project.desc}</p>
                        </div>
                    </a>
                ))
            }
        </div>
    </div>
    
    <div class="portfolio-link-container">
        <a href="/portfolio" class="btn btn-secondary">View full portfolio</a>
    </div>
</section>

<style>
    .portfolio-preview-grid {
        width: 100%;
        margin: 4rem 0;
        border-radius: 8px;
    }

    .grid-title {
        color: #fff;
        margin-bottom: 1.5rem;
        text-align: left;

    }

    .grid-container {
        width: 100%;
        overflow: hidden;
    }

    .grid-scroll {
        display: flex;
        gap: 1.5rem;
        overflow-x: auto;
        scroll-behavior: smooth;
        scrollbar-width: thin;
        scrollbar-color: rgba(255, 255, 255, 0.3) transparent;
    }

    .grid-scroll::-webkit-scrollbar {
        height: 6px;
    }

    .grid-scroll::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 3px;
    }

    .grid-scroll::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.3);
        border-radius: 3px;
    }

    .grid-scroll::-webkit-scrollbar-thumb:hover {
        background: rgba(255, 255, 255, 0.5);
    }

    .grid-item {
        flex: 0 0 280px;
        text-decoration: none;
        cursor: pointer;
    }

    .grid-image-container {
        position: relative;
        aspect-ratio: 4/3;
        border-radius: 8px;
        overflow: hidden;
        margin-bottom: 1rem;
    }

    .grid-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .grid-info {
        color: #fff;
        padding: 0 0.25rem;
    }

    .grid-project-title {
        margin: 0 0 0.5rem 0;
        color: #fff;
    }

    .grid-project-desc {
        opacity: 0.8;
        margin: 0;
        color: #fff;
    }

    @media (max-width: 768px) {
        .grid-title {
            font-size: 1.5rem;
            padding: 0 0.5rem;
            margin-bottom: 1rem;
        }

        .grid-scroll {
            gap: 1rem;
            padding: 0.5rem 0.5rem;
        }

        .grid-item {
            flex: 0 0 220px;
        }

        .grid-image-container {
            aspect-ratio: 3/2;
            margin-bottom: 0.75rem;
        }

        .grid-project-title {
            font-size: 1rem;
        }

        .grid-project-desc {
            font-size: 0.8rem;
        }
    }

    @media (max-width: 480px) {
        .grid-scroll {
            padding: 0.5rem 0.25rem;
        }

        .grid-item {
            flex: 0 0 180px;
        }

        .grid-image-container {
            border-radius: 6px;
        }
    }

    /* Hide scrollbar on mobile for cleaner look */
    @media (max-width: 768px) {
        .grid-scroll {
            scrollbar-width: none;
            -ms-overflow-style: none;
        }

        .grid-scroll::-webkit-scrollbar {
            display: none;
        }
    }

    .portfolio-link-container {
        display: flex;
        justify-content: center;
        margin-top: 3rem;
        padding: 0 1rem;
    }

    @media (max-width: 768px) {
        .portfolio-link-container {
            margin-top: 2rem;
        }
    }
</style>