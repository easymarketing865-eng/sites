---
/** 
 * AccentScript.astro
 * Renders a reusable, absolutely or statically positioned handwritten accent for headlines or overlays.
 * Props:
 *   text (string, required): Accent message to show
 *   class (string, optional): Additional class names for positioning or styling
 *   style (string, optional): Inline style overrides
 */
const { text, class: customClass = "", style = "" } = Astro.props;
---
<span
  class={`accent-script ${customClass}`}
  style={style}
>
  {text}
  <style>
    .accent-script {
      font-family: 'Pacifico', cursive, sans-serif;
      font-size: 1.15em;
      font-weight: 400;
      color: var(--brand-red, #A00000);
      opacity: 0.52;
      pointer-events: none;
      user-select: none;
      white-space: nowrap;
      display: inline-block;
      vertical-align: baseline;
      /* Recommended for rotate/absolute overlays; override as needed */
      transform: rotate(-6deg);
      letter-spacing: 0.01em;
    }
  </style>
</span>
