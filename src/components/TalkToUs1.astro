---
/**
 * TalkToUs1.astro
 * Contact component following editorial visual style guide
 */
import "../styles/global.css";
import SocialShare from "./SocialShare.astro";
---

<section class="talk-to-us-1">
    <div class="talk-content">
        <h2 class="talk-headline">WE'RE JUST ONE TAP AWAY</h2>
        <p class="talk-description">
            Ready to bring your vision to life? Connect with us instantly
            through your preferred platform. Our team responds within minutes,
            not hours.
        </p>

        <!-- Social Share Section -->
        <div class="share-section">
            <SocialShare 
                title="Professional Video Production in Kyrgyzstan"
                description="Easy Production - Creative video production and marketing services with international standards"
                className="talk-share"
            />
        </div>
    </div>
</section>

<style>
    .talk-to-us-1 {
        padding: 2rem 2rem;
        background: #fff;
        width: 100%;
        margin: 0 auto;
    }

    .talk-content {
        max-width: 1200px;
        margin: 0 auto;
    }

    .talk-headline {
        font-family: var(--font-sans);
        font-size: 2.5rem;
        font-weight: 800;
        color: #a00000;
        margin: 0 0 1rem 0;
        line-height: 1.2;
        letter-spacing: 0.02em;
    }

    .talk-description {
        font-size: 1rem;
        line-height: 1.6;
        color: #000;
        margin: 0 0 2rem 0;
        max-width: 600px;
        font-weight: 500;
        letter-spacing: 0.02em;
    }

    /* Social Share Section Styling */
    .share-section {
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid #e0e0e0;
    }

    .share-section :global(.social-share-container) {
        background: transparent;
        box-shadow: none;
        padding: 1rem 0;
        margin: 0;
    }

    .share-section :global(.share-title) {
        color: #a00000;
        font-size: 1rem;
        font-weight: 800;
        letter-spacing: 0.02em;
        margin-bottom: 1rem;
    }

    .share-section :global(.share-btn) {
        color: #000;
        font-weight: 500;
        letter-spacing: 0.02em;
    }

    .share-section :global(.share-btn:hover) {
        background: hsla(0,0%,80%,.5);
        color: #000;
    }

    /* Override with service-specific colors on hover */
    .share-section :global(.whatsapp-btn:hover) {
        background: rgba(37, 211, 102, 0.1);
        color: #000;
    }

    .share-section :global(.telegram-btn:hover) {
        background: rgba(0, 136, 204, 0.1);
        color: #000;
    }

    .share-section :global(.facebook-btn:hover) {
        background: rgba(24, 119, 242, 0.1);
        color: #000;
    }

    .share-section :global(.email-btn:hover) {
        background: rgba(102, 102, 102, 0.1);
        color: #000;
    }

    .share-section :global(.instagram-btn:hover) {
        background: rgba(228, 64, 95, 0.1);
        color: #000;
    }

    @media (max-width: 768px) {
        .talk-to-us-1 {
            padding: 2rem 1rem;
        }

        .talk-headline {
            font-size: 1.8rem;
        }

        .talk-description {
            font-size: 0.9rem;
            margin-bottom: 1.5rem;
        }

        .share-section {
            margin-top: 2rem;
            padding-top: 1.5rem;
        }
    }

    .talk-title {
        font-family: var(--font-heading);
        font-size: 2.5rem;
        font-weight: 800;
        color: #fff;
        margin: 0 0 1rem 0;
        line-height: 1.2;
    }

    .talk-subtitle {
        font-family: var(--font-heading);
        font-size: 1.5rem;
        font-weight: 600;
        color: #fff;
        margin: 0 0 2rem 0;
        line-height: 1.3;
    }
</style>
