---
/**
 * Timeline.astro
 * Project process timeline component
 */
import "../styles/global.css";
import styles from "../styles/Timeline.module.css";

const processSteps = [
  {
    step: "01",
    title: "Discovery & Strategy",
    description: "We dive deep into your brand, goals, and target audience to develop a comprehensive creative strategy that aligns with your vision.",
    duration: "1-2 days"
  },
  {
    step: "02", 
    title: "Concept Development",
    description: "Our creative team develops initial concepts, storyboards, and treatment documents. We refine ideas through collaborative feedback sessions.",
    duration: "3-5 days"
  },
  {
    step: "03",
    title: "Pre-Production Planning", 
    description: "Detailed planning phase including location scouting, casting, equipment preparation, and scheduling. Every detail is mapped out for smooth execution.",
    duration: "5-7 days"
  },
  {
    step: "04",
    title: "Production & Filming",
    description: "Professional filming with our experienced crew using high-end equipment. We maintain flexible schedules and adapt to ensure optimal results.",
    duration: "1-3 days"
  },
  {
    step: "05",
    title: "Post-Production",
    description: "Expert editing, color grading, sound design, and motion graphics. Multiple review rounds ensure the final product exceeds expectations.",
    duration: "1-2 weeks"
  },
  {
    step: "06",
    title: "Delivery & Support",
    description: "Final delivery in all required formats, along with ongoing support for distribution and any additional edits or versions needed.",
    duration: "1-2 days"
  }
];
---

<section class={styles.section} id="process">
  <h2 class="headline">Our Production Process</h2>
  <div class={styles.timeline}>
    {processSteps.map((step, index) => (
      <div class={styles.timelineItem}>
        <div class={styles.stepNumber}>{step.step}</div>
        <div class={styles.content}>
          <h3 class={styles.title}>{step.title}</h3>
          <p class={styles.description}>{step.description}</p>
          <span class={styles.duration}>{step.duration}</span>
        </div>
      </div>
    ))}
  </div>
</section>