<style>
    .hero-section {
        width: 100vw;
      margin-left: calc(-50vw + 50%);
      margin-right: calc(-50vw + 50%);
        height: 100vh;
        position: relative;
        display: grid;
        overflow: hidden;
    }

    .hero-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        grid-template-rows: repeat(3, 1fr);
        width: 100%;
        height: 100%;
        gap: 0;
    }

    .hero-item {
        position: relative;
        display: block;
    }

    .hero-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .image-label {
        position: absolute;
        top: 1rem;
        left: 1rem;
        background: rgba(0, 0, 0, 0.8);
        color: white;
        padding: 0.2rem 0.5rem;
        font-family: var(--font-sans);
        font-size: clamp(0.75rem, 1.5vw, 1rem);
        font-weight: 600;
        backdrop-filter: blur(5px);
        z-index: 5;
        opacity: 0.7;
    }

    .hero-overlay {
        position: absolute;
        top: 20%;
        left: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
        z-index: 10;
        background: rgba(0, 0, 0, 0.8);
        color: white;
        padding: 2rem 3rem;
        border-radius: 0;
        backdrop-filter: blur(15px);
        white-space: nowrap;
    }

    .hero-title {
        font-family: var(--font-heading);
        font-size: clamp(2rem, 4vw, 3.5rem);
        font-weight: 700;
        margin: 0;
        line-height: 1.2;
    }

    @media (max-width: 768px) {
        .hero-grid {
            grid-template-columns: repeat(3, 1fr);
            grid-template-rows: repeat(4, 1fr);
        }

        .hero-overlay {
            padding: 1.5rem 2rem;
        }

        .hero-title {
            font-size: clamp(1.5rem, 4vw, 2.5rem);
        }
    }

    @media (max-width: 480px) {
        .hero-grid {
            grid-template-columns: repeat(2, 1fr);
            grid-template-rows: repeat(6, 1fr);
        }

        .hero-overlay {
            padding: 1rem 1.5rem;
            white-space: normal;
        }

        .image-label {
            font-size: 0.7rem;
            padding: 0.25rem 0.5rem;
            top: 0.5rem;
            left: 0.5rem;
        }
    }
</style>
