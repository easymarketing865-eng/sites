---
import { Image } from "astro:assets";
import { content, pb, projects } from "../lib/pocketbase.js";

let heroProjects: any[] = [];

try {
  // Add longer delay to prevent auto-cancellation when multiple components load simultaneously
  await new Promise(resolve => setTimeout(resolve, 500));
  
  // Retry mechanism for auto-cancellation issues
  let retryCount = 0;
  let allProjects = [];
  
  while (retryCount < 3 && allProjects.length === 0) {
    try {
      // Use single request to reduce auto-cancellation risk
      const allProjectsResult = await projects.getAll(1, 15, {
        sort: '-featured, -created'
      });
      allProjects = allProjectsResult.items || [];
      
      if (allProjects.length > 0) {
        heroProjects = allProjects.slice(0, 11);
        console.log(`Loaded ${heroProjects.length} projects from PocketBase for Hero (attempt ${retryCount + 1})`);
        break;
      }
    } catch (retryError) {
      retryCount++;
      console.log(`Hero retry ${retryCount}/3 failed:`, (retryError as Error).message);
      if (retryCount < 3) {
        // Wait before retry
        await new Promise(resolve => setTimeout(resolve, 200 * retryCount));
      }
    }
  }
  
  // Helper function to get image URL (PocketBase only)
  function getImageUrl(project: any): string {
    // First try to get the photo file if it exists
    if (project.photo) {
        return pb.files.getURL(project, project.photo);
    }
    
    // If no photo file, try the first gallery image
    if (project.gallery && project.gallery.length > 0) {
        return pb.files.getURL(project, project.gallery[0]);
    }
    
    // Try image field
    if (project.image) {
        return pb.files.getURL(project, project.image);
    }
    
    // No local photo fallbacks - only PocketBase files
    return '';
  }

  // Helper function to get video URL
  function getVideoUrl(project: any): string | null {
    // Handle video URLs
    if (project.video) {
        return pb.files.getURL(project, project.video);
    }
    
    if (project.videoField && typeof project.videoField === 'string' && project.videoField.length > 10) {
        return pb.files.getURL(project, project.videoField);
    }
    
    return null;
  }
  
  // Generate video and image URLs for projects with uploaded files
  heroProjects = heroProjects.map((project: any) => {
    try {
      // Handle video URLs
      const videoUrl = getVideoUrl(project);
      if (videoUrl) {
          project.videoUrl = videoUrl;
          console.log(`Generated video URL for ${project.title}: ${project.videoUrl}`);
      }
      
      // Handle image URLs
      project.imageUrl = getImageUrl(project);
      console.log(`Generated image URL for ${project.title}: ${project.imageUrl}`);
    } catch (error) {
      console.log(`Error processing project ${project.title}`);
      project.imageUrl = '';
    }
    
    return project;
  });
} catch (error) {
  console.log('PocketBase error for Hero:', (error as Error).message);
  heroProjects = [];
}

// Final safety check - if still no projects after all retries, log it
if (heroProjects.length === 0) {
  console.log('⚠️ Hero: No projects loaded after all attempts. Hero will show fallback message.');
}
---

<section class="hero-section">
    <div class="hero-grid">
        {heroProjects.length > 0 ? heroProjects.map((project) => (
            <a href={`/portfolio/${project.id}`} class="hero-item">
                {/* Video thumbnail with image fallback */}
                {((project as any).videoUrl || (project as any).videoThumbnail || (project as any).videoField) ? (
                    <video 
                        class="hero-video"
                        autoplay 
                        muted 
                        loop 
                        playsinline
                        preload="metadata"
                        poster={(project as any).imageUrl || ''}
                    >
                        <source src={(project as any).videoUrl || (project as any).videoThumbnail || (project as any).videoField} type="video/mp4" />
                        {/* Fallback to image if video fails */}
                        {(project as any).imageUrl && (
                            <Image
                                src={(project as any).imageUrl}
                                alt={project.title}
                                class="hero-image"
                                width={1280}
                                height={720}
                            />
                        )}
                    </video>
                ) : (
                    (project as any).imageUrl && (
                        <Image
                            src={(project as any).imageUrl}
                            alt={project.title}
                            class="hero-image"
                            width={1280}
                            height={720}
                        />
                    )
                )}
                
                <img src="/photos/top-left.svg" alt="" class="corner-svg top-left" />
                <img src="/photos/bottom-right.svg" alt="" class="corner-svg bottom-right" />
                <span class="project-label">{project.title}</span>
            </a>
        )) : (
            <div class="hero-fallback">
                <p>Loading projects... Please refresh if this persists.</p>
            </div>
        )}}
    </div>

    <!-- <div class="hero-overlay">
        <h1 class="hero-title">We produce videos of all sorts</h1>
    </div> -->
</section>

<style>
    .hero-section {
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        margin-right: calc(-50vw + 50%);
        position: relative;
        display: grid;
        overflow: hidden;
        min-height: 400px;
    }

    .hero-grid {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        grid-template-rows: 0.6fr 0.8fr 0.6fr 0.8fr;
        width: 100%;
        height: 100%;
        gap: 2px;
        min-height: 400px;
    }

    .hero-fallback {
        grid-column: 1 / -1;
        grid-row: 1 / -1;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f5f5f5;
        color: #666;
        font-size: 1.2rem;
    }

    .hero-item {
        position: relative;
        display: block;
        min-height: 0;
        overflow: hidden;
        text-decoration: none;
        color: inherit;
    }

    /* Grid positioning for 10 projects */
    .hero-item:nth-child(1) { grid-column: 1 / 3; grid-row: 1; }
    .hero-item:nth-child(2) { grid-column: 3 / 5; grid-row: 1; }
    .hero-item:nth-child(3) { grid-column: 5 / 7; grid-row: 1; }
    .hero-item:nth-child(4) { grid-column: 1 / 4; grid-row: 2; }
    .hero-item:nth-child(5) { grid-column: 4 / 7; grid-row: 2; }
    .hero-item:nth-child(6) { grid-column: 1 / 3; grid-row: 3; }
    .hero-item:nth-child(7) { grid-column: 3 / 5; grid-row: 3; }
    .hero-item:nth-child(8) { grid-column: 5 / 7; grid-row: 3; }
    .hero-item:nth-child(9) { grid-column: 1 / 4; grid-row: 4; }
    .hero-item:nth-child(10) { grid-column: 4 / 7; grid-row: 4; }

    .hero-item:nth-child(n+11) {
        display: none;
    }

    /* Video and Image Styles */
    .hero-video,
    .hero-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.3s ease;
    }

    .hero-video {
        /* Video-specific optimizations */
        background: #000;
        will-change: transform;
    }

   
    

    /* Reduced motion support */
    @media (prefers-reduced-motion: reduce) {
        .hero-video {
            animation-play-state: paused;
        }
        
        .hero-item:hover .hero-video,
        .hero-item:hover .hero-image {
            transform: none;
        }
    }

    .corner-svg {
        position: absolute;
        width: 34px;
        height: 34px;
        z-index: 3;
        opacity: 0;
        transform: scale(0.5);
        transition: all 0.3s ease;
        pointer-events: none;
    }

    .corner-svg.top-left {
        top: 1rem;
        left: 1rem;
    }

    .corner-svg.bottom-right {
        bottom: 1rem;
        right: 1rem;
    }

    .hero-item:hover .corner-svg {
        opacity: 1;
        transform: scale(1);
    }

    .project-label {
        position: absolute;
        bottom: 1rem;
        left: 1rem;
        color: white;
        font-family: var(--font-sans);
        font-size: clamp(0.75rem, 1.5vw, 1rem);
        font-weight: 800;
        text-transform: uppercase;
        z-index: 5;
        border-radius: 2px;
        text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.8);
    }

    /* Mobile optimizations */
    @media (max-width: 768px) {
        .hero-grid {
            grid-template-columns: repeat(2, 1fr);
            grid-template-rows: repeat(7, 1fr);
            gap: 1px;
        }

        /* Mobile grid positioning */
        .hero-item:nth-child(1) { grid-column: 1; grid-row: 1; }
        .hero-item:nth-child(2) { grid-column: 2; grid-row: 1; }
        .hero-item:nth-child(3) { grid-column: 1 / 3; grid-row: 2; }
        .hero-item:nth-child(4) { grid-column: 1; grid-row: 3; }
        .hero-item:nth-child(5) { grid-column: 2; grid-row: 3; }
        .hero-item:nth-child(6) { grid-column: 1; grid-row: 4; }
        .hero-item:nth-child(7) { grid-column: 2; grid-row: 4; }
        .hero-item:nth-child(8) { grid-column: 1; grid-row: 5; }
        .hero-item:nth-child(9) { grid-column: 1 / 3; grid-row: 6; }
        .hero-item:nth-child(10) { grid-column: 1; grid-row: 7; }
        .hero-item:nth-child(11) { grid-column: 2; grid-row: 7; }
    }

    @media (max-width: 480px) {
        .hero-grid {
            grid-template-columns: 1fr;
            grid-template-rows: repeat(11, 1fr);
            gap: 1px;
        }

        .hero-item:nth-child(n) {
            grid-column: 1;
        }

        .hero-item:nth-child(1) { grid-row: 1; }
        .hero-item:nth-child(2) { grid-row: 2; }
        .hero-item:nth-child(3) { grid-row: 3; }
        .hero-item:nth-child(4) { grid-row: 4; }
        .hero-item:nth-child(5) { grid-row: 5; }
        .hero-item:nth-child(6) { grid-row: 6; }
        .hero-item:nth-child(7) { grid-row: 7; }
        .hero-item:nth-child(8) { grid-row: 8; }
        .hero-item:nth-child(9) { grid-row: 9; }
        .hero-item:nth-child(10) { grid-row: 10; }
        .hero-item:nth-child(11) { grid-row: 11; }

        .project-label {
            font-size: 1rem;
            font-weight: 800;
            text-transform: uppercase;
            padding: 0.25rem 0.25rem;
            bottom: 0.5rem;
            left: 0.5rem;
        }

        .corner-svg {
            width: 24px;
            height: 24px;
        }

        .corner-svg.top-left {
            top: 0.5rem;
            left: 0.5rem;
        }

        .corner-svg.bottom-right {
            bottom: 0.5rem;
            right: 0.5rem;
        }
    }
</style>
