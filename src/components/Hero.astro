---
import { Image } from "astro:assets";
import { content, files } from "../lib/pocketbase.js";
// Fallback to JSON data if PocketBase is not available
import portfolioData from "../data/portfolio.json";

let heroProjects = [];

try {
  // Try to fetch from PocketBase using the enhanced helper
  const result = await content.getHeroProjects(11);
  heroProjects = result.items || [];
  console.log(`Loaded ${heroProjects.length} projects from PocketBase for Hero`);
  
  // Generate video and image URLs for projects with uploaded files
  heroProjects = heroProjects.map(project => {
    // Handle video URLs
    if (project.video) {
      project.videoUrl = files.getUrl(project, project.video);
      console.log(`Generated video URL for ${project.title}: ${project.videoUrl}`);
    } else if (project.videoField && typeof project.videoField === 'string' && project.videoField.length > 10) {
      // Also handle videoField as a PocketBase file
      project.videoUrl = files.getUrl(project, project.videoField);
      console.log(`Generated video URL from videoField for ${project.title}: ${project.videoUrl}`);
    }
    
    // Handle image URLs
    if (project.image) {
      project.imageUrl = files.getUrl(project, project.image);
      console.log(`Generated image URL for ${project.title}: ${project.imageUrl}`);
    } else if (project.hero && typeof project.hero === 'string' && !project.hero.startsWith('http')) {
      // Handle hero field as PocketBase file if it doesn't start with http
      project.imageUrl = files.getUrl(project, project.hero);
      console.log(`Generated image URL from hero field for ${project.title}: ${project.imageUrl}`);
    }
    
    return project;
  });
} catch (error) {
  console.log('PocketBase not available for Hero, using JSON fallback:', (error as Error).message);
  // Fallback to JSON data
  const allProjects = [...portfolioData.featured, ...portfolioData.portfolio];
  heroProjects = allProjects.slice(0, 11);
}
---

<section class="hero-section">
    <div class="hero-grid">
        {heroProjects.map((project) => (
            <a href={`/portfolio/${project.id}`} class="hero-item">
                {/* Video thumbnail with image fallback */}
                {((project as any).videoUrl || (project as any).videoThumbnail || (project as any).videoField) ? (
                    <video 
                        class="hero-video"
                        autoplay 
                        muted 
                        loop 
                        playsinline
                        preload="metadata"
                        poster={(project as any).imageUrl || project.hero || `https://i.ytimg.com/vi/${project.videoId}/maxresdefault.jpg`}
                    >
                        <source src={(project as any).videoUrl || (project as any).videoThumbnail || (project as any).videoField} type="video/mp4" />
                        {/* Fallback to image if video fails */}
                        <Image
                            src={(project as any).imageUrl || project.hero || `https://i.ytimg.com/vi/${project.videoId}/maxresdefault.jpg`}
                            alt={project.title}
                            class="hero-image"
                            width={1280}
                            height={720}
                        />
                    </video>
                ) : (
                    <Image
                        src={(project as any).imageUrl || project.hero || `https://i.ytimg.com/vi/${project.videoId}/maxresdefault.jpg`}
                        alt={project.title}
                        class="hero-image"
                        width={1280}
                        height={720}
                    />
                )}
                
                <img src="/photos/top-left.svg" alt="" class="corner-svg top-left" />
                <img src="/photos/bottom-right.svg" alt="" class="corner-svg bottom-right" />
                <span class="project-label">{project.title}</span>
            </a>
        ))}
    </div>

    <!-- <div class="hero-overlay">
        <h1 class="hero-title">We produce videos of all sorts</h1>
    </div> -->
</section>

<style>
    .hero-section {
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        margin-right: calc(-50vw + 50%);
        position: relative;
        display: grid;
        overflow: hidden;
    }

    .hero-grid {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        grid-template-rows: 0.6fr 1.1fr 0.6fr 0.8fr;
        width: 100%;
        height: 100%;
        gap: 2px;
        min-height: 0;
    }

    .hero-item {
        position: relative;
        display: block;
        min-height: 0;
        overflow: hidden;
        text-decoration: none;
        color: inherit;
    }

    /* Grid positioning for 11 projects */
    .hero-item:nth-child(1) { grid-column: 1 / 3; grid-row: 1; }
    .hero-item:nth-child(2) { grid-column: 3 / 5; grid-row: 1; }
    .hero-item:nth-child(3) { grid-column: 5 / 7; grid-row: 1; }
    .hero-item:nth-child(4) { grid-column: 1 / 4; grid-row: 2; }
    .hero-item:nth-child(5) { grid-column: 4 / 7; grid-row: 2; }
    .hero-item:nth-child(6) { grid-column: 1 / 3; grid-row: 3; }
    .hero-item:nth-child(7) { grid-column: 3 / 5; grid-row: 3; }
    .hero-item:nth-child(8) { grid-column: 5 / 7; grid-row: 3; }
    .hero-item:nth-child(9) { grid-column: 1 / 3; grid-row: 4; }
    .hero-item:nth-child(10) { grid-column: 3 / 5; grid-row: 4; }
    .hero-item:nth-child(11) { grid-column: 5 / 7; grid-row: 4; }

    .hero-item:nth-child(n+12) {
        display: none;
    }

    /* Video and Image Styles */
    .hero-video,
    .hero-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.3s ease;
    }

    .hero-video {
        /* Video-specific optimizations */
        background: #000;
        will-change: transform;
    }

   
    

    /* Reduced motion support */
    @media (prefers-reduced-motion: reduce) {
        .hero-video {
            animation-play-state: paused;
        }
        
        .hero-item:hover .hero-video,
        .hero-item:hover .hero-image {
            transform: none;
        }
    }

    .corner-svg {
        position: absolute;
        width: 34px;
        height: 34px;
        z-index: 3;
        opacity: 0;
        transform: scale(0.5);
        transition: all 0.3s ease;
        pointer-events: none;
    }

    .corner-svg.top-left {
        top: 1rem;
        left: 1rem;
    }

    .corner-svg.bottom-right {
        bottom: 1rem;
        right: 1rem;
    }

    .hero-item:hover .corner-svg {
        opacity: 1;
        transform: scale(1);
    }

    .project-label {
        position: absolute;
        bottom: 1rem;
        left: 1rem;
        color: white;
        font-family: var(--font-sans);
        font-size: clamp(0.75rem, 1.5vw, 1rem);
        font-weight: 800;
        text-transform: uppercase;
        z-index: 5;
        border-radius: 2px;
        text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.8);
    }

    /* Mobile optimizations */
    @media (max-width: 768px) {
        .hero-grid {
            grid-template-columns: repeat(2, 1fr);
            grid-template-rows: repeat(6, 1fr);
            gap: 1px;
        }

        /* Mobile grid positioning */
        .hero-item:nth-child(1) { grid-column: 1; grid-row: 1; }
        .hero-item:nth-child(2) { grid-column: 2; grid-row: 1; }
        .hero-item:nth-child(3) { grid-column: 1 / 3; grid-row: 2; }
        .hero-item:nth-child(4) { grid-column: 1; grid-row: 3; }
        .hero-item:nth-child(5) { grid-column: 2; grid-row: 3; }
        .hero-item:nth-child(6) { grid-column: 1; grid-row: 4; }
        .hero-item:nth-child(7) { grid-column: 2; grid-row: 4; }
        .hero-item:nth-child(8) { grid-column: 1; grid-row: 5; }
        .hero-item:nth-child(9) { grid-column: 2; grid-row: 5; }
        .hero-item:nth-child(10) { grid-column: 1; grid-row: 6; }
        .hero-item:nth-child(11) { grid-column: 2; grid-row: 6; }
    }

    @media (max-width: 480px) {
        .hero-grid {
            grid-template-columns: 1fr;
            grid-template-rows: repeat(11, 1fr);
            gap: 1px;
        }

        .hero-item:nth-child(n) {
            grid-column: 1;
        }

        .hero-item:nth-child(1) { grid-row: 1; }
        .hero-item:nth-child(2) { grid-row: 2; }
        .hero-item:nth-child(3) { grid-row: 3; }
        .hero-item:nth-child(4) { grid-row: 4; }
        .hero-item:nth-child(5) { grid-row: 5; }
        .hero-item:nth-child(6) { grid-row: 6; }
        .hero-item:nth-child(7) { grid-row: 7; }
        .hero-item:nth-child(8) { grid-row: 8; }
        .hero-item:nth-child(9) { grid-row: 9; }
        .hero-item:nth-child(10) { grid-row: 10; }
        .hero-item:nth-child(11) { grid-row: 11; }

        .project-label {
            font-size: 1rem;
            font-weight: 800;
            text-transform: uppercase;
            padding: 0.25rem 0.25rem;
            bottom: 0.5rem;
            left: 0.5rem;
        }

        .corner-svg {
            width: 24px;
            height: 24px;
        }

        .corner-svg.top-left {
            top: 0.5rem;
            left: 0.5rem;
        }

        .corner-svg.bottom-right {
            bottom: 0.5rem;
            right: 0.5rem;
        }
    }
</style>
