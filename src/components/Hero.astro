---
import { Image } from "astro:assets";
import { projects, files } from "../lib/pocketbase.js";
// Fallback to JSON data if PocketBase is not available
import portfolioData from "../data/portfolio.json";

let featuredProjects = [];
let regularProjects = [];
let allProjects = [];

try {
  // Try to fetch from PocketBase
  const featuredData = await projects.getFeatured();
  const regularData = await projects.getAll(1, 9);
  
  featuredProjects = featuredData.items || [];
  regularProjects = regularData.items?.filter(p => !p.featured) || [];
  allProjects = [...featuredProjects, ...regularProjects].slice(0, 11);
  
  console.log(`Loaded ${allProjects.length} projects from PocketBase`);
} catch (error) {
  console.log('PocketBase not available, using JSON fallback:', error.message);
  // Fallback to JSON data
  featuredProjects = portfolioData.featured || [];
  regularProjects = (portfolioData.portfolio || []).slice(0, 9);
  allProjects = [...featuredProjects, ...regularProjects].slice(0, 11);
}

// Helper function to get image source (future-ready)
function getImageSource(project) {
  // Priority: PocketBase uploaded image > static hero > YouTube thumbnail
  if (project.image && project.id) {
    return files.getUrl(project, project.image);
  }
  if (project.hero) {
    return project.hero;
  }
  return `https://i.ytimg.com/vi/${project.videoId}/maxresdefault.jpg`;
}
---

<section class="hero-section emerge" data-spin="true" data-effect="slide" data-up="30px">
    <div class="hero-grid">
        {allProjects.map((project, index) => (
        <div class="hero-item emerge" data-continue="true" data-hold="100" data-effect="slide" data-up="20px">
            <Image
                    src={getImageSource(project)}
                    alt={project.title}
                class="hero-image"
                width={1280}
                height={720}
            />
            <img src="/photos/top-left.svg" alt="" class="corner-svg top-left" />
            <img src="/photos/bottom-right.svg" alt="" class="corner-svg bottom-right" />
                <span class="project-label">{project.title}</span>
            </div>
        ))}

        <div class="hero-item emerge" data-continue="true" data-hold="150" data-effect="slide" data-left="20px">
            <div class="social-links">
                <span class="social-link">INSTAGRAM</span>
                <span class="social-link">TELEGRAM</span>
                <span class="social-link">WHATSAPP</span>
                <span class="social-link">YOUTUBE</span>
            </div>
            </div>
    </div>

    <!-- <div class="hero-overlay">
        <h1 class="hero-title">We produce videos of all sorts</h1>
    </div> -->
</section>

<style>
    .hero-section {
        width: 100vw;
        /* Increased to show all 4 rows */
        margin-left: calc(-50vw + 50%);
        margin-right: calc(-50vw + 50%);
        position: relative;
        display: grid;
        overflow: hidden;
    }

        .hero-grid {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        grid-template-rows: 0.8fr 1.1fr 0.8fr 0.8fr; /* Different heights for each row */
        width: 100%;
        height: 100%;
        gap: 2px;
        min-height: 0; /* Ensures grid items can shrink */
    }

    .hero-item {
        position: relative;
        display: block;
        min-height: 0; /* Allows items to shrink to fit grid */
        overflow: hidden;
    }

    /* Row 1: img img img (first 3 items fill columns evenly) */
    .hero-item:nth-child(1) {
        grid-column: 1 / 3;
        grid-row: 1;
    }

    .hero-item:nth-child(2) {
        grid-column: 3 / 5;
        grid-row: 1;
    }

    .hero-item:nth-child(3) {
        grid-column: 5 / 7;
        grid-row: 1;
    }

    /* Row 2: equal width items (4th and 5th items same size) */
    .hero-item:nth-child(4) {
        grid-column: 1 / 4;
        grid-row: 2;
    }

    .hero-item:nth-child(5) {
        grid-column: 4 / 7;
        grid-row: 2;
    }

    /* Row 3: img img img (6th, 7th, 8th items fill columns evenly) */
    .hero-item:nth-child(6) {
        grid-column: 1 / 3;
        grid-row: 3;
    }

    .hero-item:nth-child(7) {
        grid-column: 3 / 5;
        grid-row: 3;
    }

    .hero-item:nth-child(8) {
        grid-column: 5 / 7;
        grid-row: 3;
    }

    /* Row 4: img img img (9th, 10th, 11th items fill columns evenly) */
    .hero-item:nth-child(9) {
        grid-column: 1 / 3;
        grid-row: 4;
    }

    .hero-item:nth-child(10) {
        grid-column: 3 / 5;
        grid-row: 4;
    }

    .hero-item:nth-child(11) {
        grid-column: 5 / 7;
        grid-row: 4;
    }

    /* Hide extra items beyond 11 */
    .hero-item:nth-child(n+12) {
        display: none;
    }

    .social-links {
        position: absolute;
        bottom: 0rem;
        left: 1rem;
        display: flex;
        flex-direction: column;
        gap: rem;
        z-index: 5;
    }

    .social-link {
        color: white;
        text-transform: uppercase;
        cursor: pointer;
    }

    .hero-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .corner-svg {
        position: absolute;
        width: 34px;
        height: 34px;
        z-index: 3;
        opacity: 0;
        transform: scale(0.5);
        transition: all 0.3s ease;
        pointer-events: none;
    }

    .corner-svg.top-left {
        top: 1rem;
        left: 1rem;
    }

    .corner-svg.bottom-right {
        bottom: 1rem;
        right: 1rem;
    }

    .hero-item:hover .corner-svg {
        opacity: 1;
        transform: scale(1);
    }

    .project-label {
        position: absolute;
        bottom: 1rem;
        left: 1rem;
        color: white;
        z-index: 5;
        border-radius: 2px;
    }

    .hero-overlay {
        position: absolute;
        top: 20%;
        left: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
        z-index: 10;
        background: rgba(0, 0, 0, 0.8);
        color: white;
        padding: 2rem 3rem;
        border-radius: 0;
        backdrop-filter: blur(15px);
        white-space: nowrap;
    }

    .hero-title {
        margin: 0;
    }

    @media (max-width: 768px) {
        .hero-grid {
            grid-template-columns: repeat(2, 1fr);
            grid-template-rows: repeat(6, 1fr);
            gap: 1px;
        }

        /* Mobile layout: stack items more simply */
        .hero-item:nth-child(1) {
            grid-column: 1;
            grid-row: 1;
        }

        .hero-item:nth-child(2) {
            grid-column: 2;
            grid-row: 1;
        }

        .hero-item:nth-child(3) {
            grid-column: 1 / 3;
            grid-row: 2;
        }

        .hero-item:nth-child(4) {
            grid-column: 1;
            grid-row: 3;
        }

        .hero-item:nth-child(5) {
            grid-column: 2;
            grid-row: 3;
        }

        .hero-item:nth-child(6) {
            grid-column: 1;
            grid-row: 4;
        }

        .hero-item:nth-child(7) {
            grid-column: 2;
            grid-row: 4;
        }

        .hero-item:nth-child(8) {
            grid-column: 1;
            grid-row: 5;
        }

        .hero-item:nth-child(9) {
            grid-column: 2;
            grid-row: 5;
        }

        .hero-item:nth-child(10) {
            grid-column: 1;
            grid-row: 6;
        }

        .hero-item:nth-child(11) {
            grid-column: 2;
            grid-row: 6;
        }

        .hero-overlay {
            padding: 1.5rem 2rem;
        }

        .hero-title {
            font-size: clamp(1.5rem, 4vw, 2.5rem);
        }
    }

    @media (max-width: 480px) {
        .hero-grid {
            grid-template-columns: 1fr;
            grid-template-rows: repeat(11, 1fr);
            gap: 1px;
        }

        /* Stack all items vertically on very small screens */
        .hero-item:nth-child(n) {
            grid-column: 1;
        }

        .hero-item:nth-child(1) { grid-row: 1; }
        .hero-item:nth-child(2) { grid-row: 2; }
        .hero-item:nth-child(3) { grid-row: 3; }
        .hero-item:nth-child(4) { grid-row: 4; }
        .hero-item:nth-child(5) { grid-row: 5; }
        .hero-item:nth-child(6) { grid-row: 6; }
        .hero-item:nth-child(7) { grid-row: 7; }
        .hero-item:nth-child(8) { grid-row: 8; }
        .hero-item:nth-child(9) { grid-row: 9; }
        .hero-item:nth-child(10) { grid-row: 10; }
        .hero-item:nth-child(11) { grid-row: 11; }

        .hero-overlay {
            padding: 1rem 1.5rem;
            white-space: normal;
        }

        .project-label {
            padding: 0.25rem 0.25rem;
            bottom: 0.5rem;
            left: 1rem;
        }

        .social-links {
            top: 0.5rem;
            left: 0.5rem;
            gap: 0.3rem;
        }

        .social-link {
            /* Remove font-size override */
        }

        .corner-svg {
            width: 24px;
            height: 24px;
        }

        .corner-svg.top-left {
            top: 0.5rem;
            left: 0.5rem;
        }

        .corner-svg.bottom-right {
            bottom: 0.5rem;
            right: 0.5rem;
        }
    }
</style>
