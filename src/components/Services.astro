---
const serviceLinks = [
  "production",
  "scouting",
  "photoshoots",
  "onsite",
  "storytelling",
  "branding",
  "editing",
  "direction",
  "creativity",
  "filmmaking"
];
---

<section style="width:100%;max-width:1300px;margin:0 auto 2.6rem auto;padding:0 0.7em;">
  <h2 class="headline">
    Our Services
  </h2>
  <div
    style="
      display:flex;
      flex-wrap:wrap;
      gap:1rem 1.4rem;
      width:100%;
      margin-bottom:.5em;
      align-items:center;
    "
  >
    {serviceLinks.map(word => (
      <a
        href="#"
        style="
          color:#A00000;
          font-weight:900;
          text-decoration:underline;
          font-size:1.14rem;
          text-transform:uppercase;
          letter-spacing:0.03em;
          font-family:var(--font-sans, Arial, sans-serif);
          cursor:pointer;
          padding:0.1em 0.18em;
          transition:background 0.12s;
          border-radius: 2px;
        "
        tabindex="-1"
        aria-disabled="true"
      >
        {word}
      </a>
    ))}
  </div>
</section>
