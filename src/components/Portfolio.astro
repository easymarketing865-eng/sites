---
/**
 * Portfolio.astro
 * Modular section: Featured Projects (grid or carousel), editorial, mobile-first, images from photos collection.
 * Change/filter projects/images as needed for real work.
 */
import "../styles/global.css";

const projects = [
    {
        title: "Demir Bank",
        img: "/photos/demir/width_800.webp",
        desc: "Campaign across Kyrgyzstan",
    },
    {
        title: "Elizaveta Real Estate",
        img: "/photos/ELIZAVETA.webp",
        desc: "Urban lifestyle visuals",
    },
    {
        title: "Fashion",
        img: "/photos/Fashion/width_800.webp",
        desc: "Editorial films",
    },
    {
        title: "MENIKI",
        img: "/photos/MENIKI_ONE/width_800.webp",
        desc: "Retail brand story",
    },
    {
        title: "Petrolium",
        img: "/photos/petrolium/width_800.webp",
        desc: "Energy leader visuals",
    },
    {
        title: "VILAR",
        img: "/photos/VILAR/width_800.webp",
        desc: "Product stories",
    },
    {
        title: "VITALIN",
        img: "/photos/VITALIN/width_800.webp",
        desc: "Health campaign",
    },
];
---

<section class="portfolio-section" id="portfolio">
    <div class="portfolio-grid">
        {
            projects.map((p) => (
                <a href="#" class="portfolio-card">
                    <img
                        src={p.img}
                        alt={p.title + " project image"}
                        class="portfolio-img"
                        loading="lazy"
                    />
                    <figcaption class="portfolio-caption">
                        <div class="portfolio-title">{p.title}</div>
                        <div class="portfolio-desc">{p.desc}</div>
                    </figcaption>
                </a>
            ))
        }
    </div>
</section>
<style>
.portfolio-section {
    width: 100%;
    padding: 4rem 0;
    background: var(--site-bg);
}
.portfolio-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    width: 100%;
    padding: 0 2rem;
}
.portfolio-card {
    width: 100%;
    margin: 0;
    padding: 0;
    position: relative;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s ease;
}
.portfolio-img {
    width: 100%;
    height: 50vh;
    object-fit: cover;
    background: var(--site-bg);
}
.portfolio-caption {
    position: absolute;
    bottom: 1rem;
    left: 2rem;
    padding: 0;
    display: flex;
    flex-direction: row;
    align-items: baseline;
    gap: 0.5rem;
    z-index: 2;
}
.portfolio-title {
    font-family: 'Manrope', var(--font-sans);
    font-size: 32px;
    font-weight: 800;
    color: #fff;
    opacity: 0.95;
    margin: 0;
    line-height: 1.2;
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 0.5px;
    text-decoration-color: rgba(255, 255, 255, 0.3);
    transition: all 0.2s ease;
}
.portfolio-desc {
    font-size: 16px;
    color: #fff;
    opacity: 0.8;
    font-family: 'Manrope', var(--font-sans);
    line-height: 1.5;
    margin: 0;
    font-weight: 400;
}

/* Hover effects for the entire card */
.portfolio-card:hover .portfolio-title {
    opacity: 1;
    text-decoration-color: rgba(255, 255, 255, 0.6);
}

.portfolio-card:hover .portfolio-desc {
    opacity: 0.9;
}

/* Full-width card styles */
.portfolio-card:nth-child(3n+1) {
    grid-column: 1 / -1;
}

.portfolio-card:nth-child(3n+1) .portfolio-img {
    height: 85vh;
}

.portfolio-card:nth-child(3n+1) .portfolio-caption {
    bottom: 1rem;
    left: 3rem;
}

@media (max-width: 768px) {
    .portfolio-grid {
        grid-template-columns: repeat(2, 1fr);
        padding: 0 1rem;
        gap: 0.5rem;
    }
    
    .portfolio-img {
        height: 300px;
    }
    
    .portfolio-card:nth-child(3n+1) {
        grid-column: 1 / -1;
    }
    
    .portfolio-card:nth-child(3n+1) .portfolio-img {
        height: 300px;
    }
    
    .portfolio-title {
        font-size: 20px;
    }
    
    .portfolio-desc {
        font-size: 12px;
    }
    
    .portfolio-caption {
        bottom: 1rem;
        left: 1rem;
        flex-direction: column;
        gap: 0.25rem;
        max-width: calc(100% - 2rem);
    }
    
    .portfolio-card:nth-child(3n+1) .portfolio-caption {
        bottom: 1rem;
        left: 1rem;
    }
}
</style>
