---
/**
 * Portfolio.astro
 * Modular section: Featured Projects (grid or carousel), editorial, mobile-first, images from photos collection.
 * Change/filter projects/images as needed for real work.
 */
import "../styles/global.css";

const projects = [
    {
        title: "Demir Bank",
        img: "/photos/demir/width_800.webp",
        desc: "Documentary campaign filmed across Kyrgyz banking, showing real stories and trust.",
    },
    {
        title: "Elizaveta Real Estate",
        img: "/photos/ELIZAVETA.webp",
        desc: "Bespoke lifestyle visuals for a leading property developer, promoting urban living.",
    },
    {
        title: "Fashion",
        img: "/photos/Fashion/width_800.webp",
        desc: "Editorial-style fashion films and campaign visuals with a modern edge.",
    },
    {
        title: "MENIKI",
        img: "/photos/MENIKI_ONE/width_800.webp",
        desc: "Bold commercials for a trailblazing retail brand, merging cinema and commerce.",
    },
    {
        title: "Petrolium",
        img: "/photos/petrolium/width_800.webp",
        desc: "Striking facility and team vignettes for an energy leader.",
    },
    {
        title: "VILAR",
        img: "/photos/VILAR/width_800.webp",
        desc: "Product stories and micro-documentaries for a key beverage brand.",
    },
    {
        title: "VITALIN",
        img: "/photos/VITALIN/width_800.webp",
        desc: "Health-focused spots highlighting authenticity and local story.",
    },
];
---

<section class="portfolio-section" id="portfolio">
    <div class="portfolio-grid">
        {
            projects.map((p) => (
                <a href="#" class="portfolio-card">
                    <img
                        src={p.img}
                        alt={p.title + " project image"}
                        class="portfolio-img"
                        loading="lazy"
                    />
                    <figcaption class="portfolio-caption">
                        <div class="portfolio-title">{p.title}</div>
                        <div class="portfolio-desc">{p.desc}</div>
                    </figcaption>
                </a>
            ))
        }
    </div>
</section>
<style>
.portfolio-section {
    width: 100%;
    padding: 4rem 0;
    background: var(--site-bg);
}
.portfolio-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    width: 100%;
    padding: 0 3rem;
}
.portfolio-card {
    width: 100%;
    margin: 0;
    padding: 0;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s ease;
}
.portfolio-img {
    width: 100%;
    height: 50vh;
    object-fit: cover;
    background: var(--site-bg);
}
.portfolio-caption {
    padding: 0;
    max-width: 800px;
    display: flex;
    flex-direction: column;
    
}
.portfolio-title {
    font-family: 'Manrope', var(--font-sans);
    font-size: 32px;
    font-weight: 800;
    color: #000;
    opacity: 0.85;
    margin: 0;
    line-height: 1.2;
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 0.5px;
    text-decoration-color: rgba(0, 0, 0, 0.2);
    transition: all 0.2s ease;
}
.portfolio-desc {
    font-size: 16px;
    color: #000;
    opacity: 0.7;
    font-family: 'Manrope', var(--font-sans);
    line-height: 1.5;
    margin: 0;
    font-weight: 400;
    transition: all 0.2s ease;
}

/* Hover effects for the entire card */
.portfolio-card:hover .portfolio-title {
    color: #A00000;
    opacity: 1;
    text-decoration-color: rgba(160, 0, 0, 0.4);
}

.portfolio-card:hover .portfolio-desc {
    opacity: 0.8;
}

/* Target every 3rd project and the ones after it */
.portfolio-card:nth-child(3n+1) {
    grid-column: 1 / -1;  /* Full width */
}

/* Adjust image heights based on layout */
.portfolio-img {
    width: 100%;
    height: 50vh;
    object-fit: cover;
    background: var(--site-bg);
}

/* Make full-width images taller */
.portfolio-card:nth-child(3n+1) .portfolio-img {
    height: 85vh;
}

@media (max-width: 768px) {
    .portfolio-grid {
        grid-template-columns: 1fr;
        padding: 0 1rem;
        gap: 4rem;
    }
    
    .portfolio-img,
    .portfolio-card:nth-child(3n+1) .portfolio-img {
        height: 60vh;  /* Consistent height on mobile */
    }
    .portfolio-card {
        padding: 0;
        gap: 1rem;
    }
    .portfolio-title {
        font-size: 24px;
        text-underline-offset: 3px;
        text-decoration-thickness: 0.5px;
    }
    .portfolio-desc {
        font-size: 14px;
        line-height: 1.4;
    }
}
</style>
