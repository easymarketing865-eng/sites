---
/**
 * Portfolio.astro
 * Modular section: Featured Projects (grid or carousel), editorial, mobile-first, images from photos collection.
 * Uses centralized portfolio data from portfolio.json
 */
import "../styles/global.css";
import portfolioData from "../data/portfolio.json";
import TalkToUs1 from "./TalkToUs1.astro";
import SocialShare from "./SocialShare.astro";


// Combine featured and regular portfolio items, taking first 7 for display
const allProjects = [...portfolioData.featured, ...portfolioData.portfolio];
const projects = allProjects.slice(0, 4).map((project) => ({
    title: project.title,
    img: project.hero,
    desc: project.shortDescription,
    slug: project.slug,
    services: project.services || [],
    category: project.category,
}));
---

<section class="portfolio-section" id="portfolio">
    <div class="portfolio-content">
        <h2 class="headline">Featured works</h2>
        <div class="scroll-indicator">
            <div class="scroll-hint">← Swipe to see more →</div>
        </div>
    <div class="portfolio-grid">
        {
                projects.map((p, index) => {
                    return (
                        <a href={`/portfolio/${p.slug}`} class="portfolio-card">
                    <img
                        src={p.img}
                        alt={p.title + " project image"}
                        class="portfolio-img"
                        loading="lazy"
                    />
                    <figcaption class="portfolio-caption">
                        <h3 class="portfolio-title">
                            {p.title}
                            {index === 0 && (
                                <div style="display: flex; align-items: center;">
                                    <span class="label-new-back"></span>
                                    <span class="label-new">new</span>
                                </div>
                            )}
                        </h3>
                    </figcaption>
                        </a>
                    );
                })
            }
        </div>

        <div class="portfolio-link-container">
            <a href="/portfolio" class="view-all-portfolio-btn"
                >View Full Portfolio</a
            >
        </div>

        <!-- Social Share Section -->
        <div class="portfolio-share-section">
            <SocialShare 
                title="Amazing Video Production Portfolio"
                description="Check out our featured video production works and creative projects in Kyrgyzstan"
                className="portfolio-share"
            />
        </div>

        
    </div>
</section>
<style>
/* ==========================================================================
   Portfolio Section Styles
   ========================================================================== */

/* Main Section */
.portfolio-section {
  width: 100%;
        justify-content: center;
}

.portfolio-content {
    width: 100%;
}

/* Headline */
.headline {
    font-family: "Manrope", var(--font-sans);
font-size: 3rem;
    font-weight: 800;
    color: #000;
    text-align: center;
    margin: 0 0 2rem 0;
    padding: 0;
}

/* Portfolio Grid */
.portfolio-grid {
  display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
  width: 100%;
        max-width: 1300px;
        padding: 0;
}

.portfolio-card {
        width: 100%;
        margin: 0;
        padding: 0;
        position: relative;
  display: flex;
  flex-direction: column;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.2s ease;
        aspect-ratio: 4/3;
}

.portfolio-card:nth-child(3n + 1) {
    grid-column: 1 / -1;
    aspect-ratio: 16/9;
}

.portfolio-img {
  width: 100%;
        height: 100%;
  object-fit: cover;
        background: var(--site-bg);
}

/* Portfolio Caption */
.portfolio-caption {
        position: absolute;
        bottom: 0.75rem;
        left: 0.75rem;
        padding: 0;
  display: flex;
  flex-direction: column;
        align-items: flex-start;
        z-index: 2;
        max-width: calc(100% - 4rem);
}

.portfolio-title {
        font-family: "Manrope", var(--font-sans);
        font-size: var(--size-3);
        font-weight: 600;
        color: #fff;
        opacity: 1;
        margin: 0;
        line-height: 1.2;
        transition: all 0.2s ease;
        display: flex;
        gap: 8px;
}

/* New Label Styles */
.label-new-back,
.label-new {
    position: absolute;
    font-family: var(--font-sans);
    font-size: 10px;
    line-height: 24px;
    height: 28px;
    font-weight: bold;
    display: inline-block;
}

.label-new-back {
    background: #e2bc22;
    margin: 0.3em 0 -8px 0;
    width: 8px;
}

.label-new {
    background: #fee445;
    color: #000;
    margin: -0.7em 0 0 0;
    padding: 0 4px 10px 2px;
    width: 38px;
    overflow: hidden;
    text-transform: uppercase;
    transform: skewY(-25deg);
}

/* Hover Effects */
.portfolio-card:hover .portfolio-title {
    opacity: 0.6;
}

/* Scroll Indicator */
.scroll-indicator {
    display: none;
    text-align: center;
    margin-bottom: 1rem;
}

.scroll-hint {
    font-family: 'Manrope', var(--font-sans);
    font-size: 14px;
    color: rgba(255, 255, 255, 0.6);
        font-weight: 400;
    animation: fadeInOut 2s ease-in-out infinite;
}

@keyframes fadeInOut {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1; }
}

/* Portfolio Link */
.portfolio-link-container {
        display: flex;
    justify-content: center;
    margin-top: 3rem;
}

.view-all-portfolio-btn {
    display: inline-block;
    padding: 0.8em 2em;
    font-size: 1rem;
    font-weight: 700;
        color: #fff;
        background: #000;
    border: 2px solid #000;
    border-radius: 2em;
    text-decoration: none;
    transition: all 0.3s ease;
    font-family: "Manrope", var(--font-sans);
    letter-spacing: 0.02em;
}

.view-all-portfolio-btn:hover {
    background: transparent;
    color: #000;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
}

/* Social Share */
.portfolio-share-section {
    margin-top: 1rem;
    padding-top: 2rem;
}

/* ==========================================================================
   Media Queries
   ========================================================================== */

/* Tablet */

}

/* Desktop */


/* Mobile */
    @media (max-width: 768px) {
        .portfolio-section {
            width: 100vw;
            margin-left: calc(-50vw + 50%);
            margin-right: calc(-50vw + 50%);
        }
        
    .portfolio-content {
        padding: 3rem 1rem;
    }
    
  .portfolio-grid {
            display: flex;
            overflow-x: auto;
            scroll-snap-type: x mandatory;
            gap: 1rem;
            padding: 0 1rem 0 1rem;
            max-width: 100%;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none;
            -ms-overflow-style: none;
            padding-right: 2rem;
        }
        
        .portfolio-grid::-webkit-scrollbar {
            display: none;
        }
        
        .portfolio-card {
            flex: 0 0 75vw;
            max-width: 280px;
            aspect-ratio: 3/4;
            scroll-snap-align: start;
            border-radius: 12px;
            overflow: hidden;
        }
        
        .portfolio-card:nth-child(3n+1) {
            flex: 0 0 85vw;
            max-width: 320px;
            aspect-ratio: 16/9;
        }
        
        .portfolio-card:last-child {
            margin-right: 1rem;
        }
        
        .portfolio-caption {
            bottom: 1rem;
            left: 1.5rem;
            flex-direction: column;
            gap: 0.25rem;
            max-width: calc(100% - 2rem);
        }
        
        .portfolio-title {
            font-size: 118px;
    }
    
        .scroll-indicator {
            display: block;
        }
        
        .portfolio-link-container {
            margin-top: 2rem;
        }
        
        .view-all-portfolio-btn {
            font-size: 0.9rem;
            padding: 0.7em 1.8em;
        }
    
        .portfolio-share-section {
            margin-top: 2rem;
            padding-top: 1.5rem;
        }
    }
</style>
