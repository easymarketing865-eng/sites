---
/**
 * Portfolio.astro
 * Modular section: Featured Projects (grid or carousel), editorial, mobile-first, images from photos collection.
 * Change/filter projects/images as needed for real work.
 */
import "../styles/global.css";

const projects = [
    {
        title: "Demir Bank",
        img: "/photos/demir/width_800.webp",
        desc: "Campaign across Kyrgyzstan",
    },
    {
        title: "Elizaveta Real Estate",
        img: "/photos/ELIZAVETA.webp",
        desc: "Urban lifestyle visuals",
    },
    {
        title: "Fashion",
        img: "/photos/Fashion/width_800.webp",
        desc: "Editorial films",
    },
    {
        title: "MENIKI",
        img: "/photos/MENIKI_ONE/width_800.webp",
        desc: "Retail brand story",
    },
    {
        title: "Petrolium",
        img: "/photos/petrolium/width_800.webp",
        desc: "Energy leader visuals",
    },
    {
        title: "VILAR",
        img: "/photos/VILAR/width_800.webp",
        desc: "Product stories",
    },
    {
        title: "VITALIN",
        img: "/photos/VITALIN/width_800.webp",
        desc: "Health campaign",
    },
];
---

<h2 class="headline">Our Portfolio</h2>
<section class="portfolio-section" id="portfolio">
    <div class="portfolio-grid">
        {
            projects.map((p, index) => {
                return (
                    <a href="#" class="portfolio-card">
                        <img
                            src={p.img}
                            alt={p.title + " project image"}
                            class="portfolio-img"
                            loading="lazy"
                        />
                        {index === projects.length - 1 && (
                            <div class="factoid">
                                <svg
                                    viewBox="0 0 200 200"
                                    xmlns="http://www.w3.org/2000/svg"
                                >
                                    <path
                                        fill="#8E0C12"
                                        d="M62.4,-33C75.5,-13.2,77.2,16.2,64.9,34.1C52.6,52,26.3,58.4,6.8,54.5C-12.8,50.6,-25.6,36.4,-35.5,19.9C-45.5,3.3,-52.5,-15.5,-46.1,-31.4C-39.7,-47.3,-19.9,-60.3,2.4,-61.6C24.6,-63,49.2,-52.8,62.4,-33Z"
                                        transform="translate(100 100)"
                                    />
                                </svg>
                                <div class="factoid-text">
                                    <span class="factoid-number">3D</span>
                                    <span class="factoid-label">MOTION</span>
                                </div>
                            </div>
                        )}
                        {index === 1 && (
                            <div class="factoid factoid-small">
                                <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
                                    <path fill="#8E0C12" d="M62.4,-33C75.5,-13.2,77.2,16.2,64.9,34.1C52.6,52,26.3,58.4,6.8,54.5C-12.8,50.6,-25.6,36.4,-35.5,19.9C-45.5,3.3,-52.5,-15.5,-46.1,-31.4C-39.7,-47.3,-19.9,-60.3,2.4,-61.6C24.6,-63,49.2,-52.8,62.4,-33Z" transform="translate(100 100)" />
                                </svg>
                                <div class="factoid-text">
                                    <span class="factoid-number">Delivered</span>
                                    <span class="factoid-label">in 4 days</span>
                                </div>
                            </div>
                        )}
                        <figcaption class="portfolio-caption">
                            <div class="portfolio-title">{p.title}</div>
                            <div class="portfolio-desc">{p.desc}</div>
                        </figcaption>
                    </a>
                );
            })
        }
    </div>
</section>
