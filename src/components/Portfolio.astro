---
/**
 * Portfolio.astro
 * Modular section: Featured Projects (grid or carousel), editorial, mobile-first, images from photos collection.
 * Uses centralized portfolio data from portfolio.json
 */
import "../styles/global.css";
import portfolioData from "../data/portfolio.json";

// Combine featured and regular portfolio items, taking first 7 for display
const allProjects = [...portfolioData.featured, ...portfolioData.portfolio];
const projects = allProjects.slice(0, 7).map(project => ({
    title: project.title,
    img: project.hero,
    desc: project.shortDescription,
    slug: project.slug
}));
---

<h2 class="headline">Our Portfolio</h2>
<section class="portfolio-section" id="portfolio">
    <div class="portfolio-grid">
        {
            projects.map((p, index) => {
                return (
                    <a href={`/portfolio/${p.slug}`} class="portfolio-card">
                        <img
                            src={p.img}
                            alt={p.title + " project image"}
                            class="portfolio-img"
                            loading="lazy"
                        />
                        {index === projects.length - 1 && (
                            <div class="factoid">
                                <img
                                    src="/photos/factoid-3d.png"
                                    alt="3D motion"
                                    class="factoid-img"
                                />
                            </div>
                        )}
                        {index === 1 && (
                            <div class="factoid factoid-small">
                                <img
                                    src="/photos/factoid-delivered.png"
                                    alt="Delivered in 4 days"
                                    class="factoid-img"
                                />
                            </div>
                        )}
                        <figcaption class="portfolio-caption">
                            <div class="portfolio-title">{p.title}</div>
                            <div class="portfolio-desc">{p.desc}</div>
                        </figcaption>
                    </a>
                );
            })
        }
    </div>
</section>
<style>
    .portfolio-section {
        width: 100%;
        padding: 2rem 0;
        background: var(--site-bg);
        display: flex;
        justify-content: center;
    }
    .portfolio-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
        width: 100%;
        max-width: 1300px;
        padding: 0 1rem;
        margin: 0 auto;
    }
    .portfolio-card {
        width: 100%;
        margin: 0;
        padding: 0;
        position: relative;
        display: flex;
        flex-direction: column;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.2s ease;
        aspect-ratio: 3/4;
    }
    .portfolio-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        background: var(--site-bg);
    }
    .portfolio-caption {
        position: absolute;
        bottom: 0.75rem;
        left: 1rem;
        padding: 0;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.25rem;
        z-index: 2;
        max-width: calc(100% - 2rem);
    }
    .portfolio-title {
        font-family: "Manrope", var(--font-sans);
        font-size: 1.25rem;
        font-weight: 800;
        color: #fff;
        opacity: 0.85;
        margin: 0;
        line-height: 1.2;
        transition: all 0.2s ease;
    }
    .portfolio-desc {
        font-size: 0.875rem;
        color: #fff;
        opacity: 0.7;
        font-family: "Manrope", var(--font-sans);
        line-height: 1.2;
        margin: 0;
        font-weight: 400;
        transition: all 0.2s ease;
    }

    /* Hover effects for the entire card */
    .portfolio-card:hover .portfolio-title,
    .portfolio-card:hover .portfolio-desc {
        opacity: 0.6;
    }

    /* Full-width card styles - only apply on larger screens */

    /* Mobile first responsive design */
    @media (min-width: 480px) {
        .portfolio-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 1.25rem;
            padding: 0 1.25rem;
        }
        
        .portfolio-caption {
            bottom: 1rem;
            left: 1.25rem;
            max-width: calc(100% - 2.5rem);
        }
        
        .portfolio-title {
            font-size: 1.375rem;
        }
        
        .portfolio-desc {
            font-size: 0.9rem;
        }
    }

    @media (min-width: 768px) {
        .portfolio-section {
            padding: 3rem 0;
        }
        
        .portfolio-grid {
            gap: 1.5rem;
            padding: 0 1.5rem;
        }
        
        .portfolio-card {
            aspect-ratio: 4/3;
        }
        
        /* Full-width card styles for tablets and up */
        .portfolio-card:nth-child(3n + 1) {
            grid-column: 1 / -1;
            aspect-ratio: 16/9;
        }
        
        .portfolio-caption {
            bottom: 1.25rem;
            left: 1.5rem;
            max-width: calc(100% - 3rem);
        }
        
        .portfolio-title {
            font-size: 1.75rem;
        }
        
        .portfolio-desc {
            font-size: 1rem;
        }
    }

    @media (min-width: 1024px) {
        .portfolio-section {
            padding: 4rem 0;
        }
        
        .portfolio-grid {
            gap: 2rem;
            padding: 0 2rem;
        }
        
        .portfolio-caption {
            bottom: 1.5rem;
            left: 1.5rem;
            max-width: calc(100% - 4rem);
        }
        
        .portfolio-title {
            font-size: 2rem;
        }
        
        .portfolio-desc {
            font-size: 1rem;
        }
    }

    .factoid {
        position: absolute;
        top: -0.75rem;
        right: -0.75rem;
        width: 60px;
        height: 60px;
        z-index: 2;
    }

    .factoid-img {
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        object-fit: contain;
        z-index: 1;
        pointer-events: none;
    }

    .factoid-small {
        width: 60px;
        height: 60px;
        top: -0.75rem;
        left: -0.75rem;
        right: auto;
    }

    @media (min-width: 480px) {
        .factoid {
            top: -1rem;
            right: -1rem;
            width: 80px;
            height: 80px;
        }

        .factoid-small {
            width: 80px;
            height: 80px;
            top: -1rem;
            left: -1rem;
        }
    }

    @media (min-width: 768px) {
        .factoid {
            top: -1.5rem;
            right: -1.5rem;
            width: 100px;
            height: 100px;
        }

        .factoid-small {
            width: 100px;
            height: 100px;
            top: -1.5rem;
            left: -1.5rem;
        }
    }

    @media (min-width: 1024px) {
        .factoid {
            top: -2rem;
            right: -2rem;
            width: 120px;
            height: 120px;
        }

        .factoid-small {
            width: 120px;
            height: 120px;
            top: -2rem;
            left: -2rem;
        }
    }
</style>
