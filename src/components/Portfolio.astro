---
/**
 * Portfolio.astro
 * Modular section: Featured Projects (grid or carousel), editorial, mobile-first, images from photos collection.
 * Uses centralized portfolio data from portfolio.json
 */
import "../styles/global.css";
import portfolioData from "../data/portfolio.json";
import TalkToUs1 from "./TalkToUs1.astro";
import SocialShare from "./SocialShare.astro";


// Combine featured and regular portfolio items, taking first 7 for display
const allProjects = [...portfolioData.featured, ...portfolioData.portfolio];
const projects = allProjects.slice(0, 4).map((project) => ({
    title: project.title,
    img: project.hero,
    desc: project.shortDescription,
    slug: project.slug,
    services: project.services || [],
    category: project.category,
}));
---

<section class="portfolio-section" id="portfolio">
    <!-- Start decoration SVG -->
    <div class="decoration decoration-start">
        <img
            src="/photos/start.svg"
            alt="Start decoration"
            class="decoration-svg"
        />
    </div>

    <div class="portfolio-content">
        <h2 class="headline">Featured Works</h2>
        <div class="scroll-indicator">
            <div class="scroll-hint">← Swipe to see more →</div>
        </div>
        <div class="portfolio-grid">
            {
                projects.map((p, index) => {
                    return (
                        <a href={`/portfolio/${p.slug}`} class="portfolio-card">
                            <img
                                src={p.img}
                                alt={p.title + " project image"}
                                class="portfolio-img"
                                loading="lazy"
                            />
                            {index === projects.length - 1 && (
                                <div class="factoid">
                                    <img
                                        src="/photos/factoid-3d.png"
                                        alt="3D motion"
                                        class="factoid-img"
                                    />
                                </div>
                            )}
                            {index === 1 && (
                                <div class="factoid factoid-small">
                                    <img
                                        src="/photos/factoid-delivered.png"
                                        alt="Delivered in 4 days"
                                        class="factoid-img"
                                    />
                                </div>
                            )}
                            <figcaption class="portfolio-caption">
                                <h3 class="portfolio-title">{p.title}</h3>
                                <div class="portfolio-desc">{p.desc}</div>
                                {/* {p.services && p.services.length > 0 && (
                                    <div class="portfolio-tags">
                                        {p.services.slice(0, 2).map(service => (
                                            <span class="portfolio-tag">{service}</span>
                                        ))}
                                    </div>
                                )} */}
                            </figcaption>
                        </a>
                    );
                })
            }
        </div>

        <div class="portfolio-link-container">
            <a href="/portfolio" class="view-all-portfolio-btn"
                >View Full Portfolio</a
            >
        </div>

        <!-- Social Share Section -->
        <div class="portfolio-share-section">
            <SocialShare 
                title="Amazing Video Production Portfolio"
                description="Check out our featured video production works and creative projects in Kyrgyzstan"
                className="portfolio-share"
            />
        </div>

        
    </div>

    <!-- End decoration SVG -->
    <div class="decoration decoration-end">
        <img
            src="/photos/end.svg"
            alt="End decoration"
            class="decoration-svg"
        />
    </div>
</section>
<style>
    .headline {
        font-family: var(--font-heading);
        font-size: 2rem;
        font-weight: 600;
        color: #fff;
        margin: 0 auto;
        padding: 0 1rem;
        max-width: 1300px;
        margin-bottom: 1.5rem;
        text-align: center;
    }

    @media (min-width: 768px) {
        .headline {
            font-size: 2.5rem;
            padding: 0 1.5rem;
            margin-bottom: 2rem;
        }
    }

    @media (min-width: 1024px) {
        .headline {
            font-size: 3rem;

            margin-bottom: 2.5rem;
        }
    }

    .portfolio-section {
        width: 100%;
        justify-content: center;
    }
    .portfolio-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
        width: 100%;
        max-width: 1300px;
        padding: 0;
        margin: 0 auto;
    }
    .portfolio-card {
        width: 100%;
        margin: 0;
        padding: 0;
        position: relative;
        display: flex;
        flex-direction: column;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.2s ease;
        aspect-ratio: 4/3;
    }
    .portfolio-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        background: var(--site-bg);
    }
    .portfolio-caption {
        position: absolute;
        bottom: 1rem;
        left: 1.5rem;
        padding: 0;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.25rem;
        z-index: 2;
        max-width: calc(100% - 4rem);
    }
    .portfolio-title {
        font-family: "Manrope", var(--font-sans);
        font-size: 32px;
        font-weight: 800;
        color: #fff;
        opacity: 1;
        margin: 0;
        line-height: 1.2;
        transition: all 0.2s ease;
    }
    .portfolio-desc {
        font-size: 16px;
        color: #fff;
        opacity: 0.7;
        font-family: "Manrope", var(--font-sans);
        line-height: 1.2;
        margin: 0;
        font-weight: 400;
        transition: all 0.2s ease;
    }

    /* .portfolio-tags {
        display: flex;
        gap: 0.5rem;
        margin-top: 0.5rem;
        flex-wrap: wrap;
    }

    .portfolio-tag {
        font-size: 11px;
        color: #000;
        background: #fff;
        padding: 0.25rem 0.5rem;
        border-radius: 12px;
        font-family: 'Manrope', var(--font-sans);
        font-weight: 500;
        letter-spacing: 0.5px;
        backdrop-filter: blur(4px);
        border: 1px solid rgba(255, 255, 255, 0.1);
    } */

    /* Hover effects for the entire card */
    .portfolio-card:hover .portfolio-title,
    .portfolio-card:hover .portfolio-desc {
        opacity: 0.6;
    }

    /* Full-width card styles */
    .portfolio-card:nth-child(3n + 1) {
        grid-column: 1 / -1;
        aspect-ratio: 16/9;
    }

    .portfolio-card:nth-child(3n + 1) .portfolio-img {
        height: 100%;
    }

    .portfolio-card:nth-child(3n + 1) .portfolio-caption {
        bottom: 1rem;
        left: 1.5rem;
    }

    @media (max-width: 768px) {
        .portfolio-section {
            width: 100vw;
            margin-left: calc(-50vw + 50%);
            margin-right: calc(-50vw + 50%);
        }
        
        .portfolio-grid {
            display: flex;
            overflow-x: auto;
            scroll-snap-type: x mandatory;
            gap: 1rem;
            padding: 0 1rem 0 1rem;
            max-width: 100%;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none;
            -ms-overflow-style: none;
            padding-right: 2rem;
        }
        
        .portfolio-grid::-webkit-scrollbar {
            display: none;
        }
        
        .portfolio-card {
            flex: 0 0 75vw;
            max-width: 280px;
            aspect-ratio: 3/4;
            scroll-snap-align: start;
            border-radius: 12px;
            overflow: hidden;
        }
        
        .portfolio-card:nth-child(3n+1) {
            flex: 0 0 85vw;
            max-width: 320px;
            aspect-ratio: 16/9;
        }
        
        .portfolio-card:last-child {
            margin-right: 1rem;
        }
        
        .portfolio-img {
            height: 100%;
        }
        
        .portfolio-card:nth-child(3n+1) .portfolio-img {
            height: 100%;
        }
        
        .portfolio-caption {
            bottom: 1rem;
            left: 1.5rem;
            flex-direction: column;
            gap: 0.25rem;
            max-width: calc(100% - 2rem);
        }
        
        .portfolio-title {
            font-size: 18px;
        }
        
        .portfolio-desc {
            font-size: 12px;
        }
        
        /* .portfolio-tag {
            font-size: 10px;
            padding: 0.2rem 0.4rem;
        } */
        
        .portfolio-card:nth-child(3n+1) .portfolio-caption {
            bottom: 1rem;
            left: 1.5rem;
        }
    }

    .factoid {
        position: absolute;
        top: -2rem;
        right: -2rem;
        width: 120px;
        height: 120px;
        z-index: 2;
    }

    .factoid-img {
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        object-fit: contain;
        z-index: 1;
        pointer-events: none;
    }

    .factoid-small {
        width: 120px;
        height: 120px;
        top: -2rem;
        left: -2rem;
        right: auto;
    }

    @media (max-width: 768px) {
        .factoid {
            top: -1rem;
            right: -1rem;
            width: 80px;
            height: 80px;
        }

        .factoid-small {
            width: 80px;
            height: 80px;
            top: -1rem;
            left: -1rem;
            right: auto;
        }
    }

    .portfolio-content {
        width: 100%;
        background: #000;
        padding: 3rem 3rem;
    }

    @media (max-width: 768px) {
        .portfolio-content {
            padding: 3rem 1rem;
        }

        .portfolio-section {
            width: 100vw;
            margin-left: calc(-50vw + 50%);
            margin-right: calc(-50vw + 50%);
        }
    }

    .decoration {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .decoration svg {
        width: 100%;
        height: 100%;
    }

    .decoration-svg {
        width: 100%;

        object-fit: contain;
    }

    @media (max-width: 768px) {
        .decoration {
            width: 100vw;
            margin-left: calc(-50vw + 50%);
            margin-right: calc(-50vw + 50%);
        }
    }

    .portfolio-link-container {
        display: flex;
        justify-content: center;
        margin-top: 3rem;
    }

    .view-all-portfolio-btn {
        display: inline-block;
        padding: 0.8em 2em;
        font-size: 1rem;
        font-weight: 700;
        color: #000;
        background: #fff;
        border: 2px solid #fff;
        border-radius: 2em;
        text-decoration: none;
        transition: all 0.3s ease;
        font-family: "Manrope", var(--font-sans);
        letter-spacing: 0.02em;
    }

    .view-all-portfolio-btn:hover {
        background: transparent;
        color: #fff;
        box-shadow: 0 8px 24px rgba(255, 255, 255, 0.15);
    }

    .scroll-indicator {
        display: none;
        text-align: center;
        margin-bottom: 1rem;
    }

    .scroll-hint {
        font-family: 'Manrope', var(--font-sans);
        font-size: 14px;
        color: rgba(255, 255, 255, 0.6);
        font-weight: 400;
        animation: fadeInOut 2s ease-in-out infinite;
    }

    @keyframes fadeInOut {
        0%, 100% { opacity: 0.6; }
        50% { opacity: 1; }
    }

    @media (max-width: 768px) {
        .scroll-indicator {
            display: block;
        }
        
        .portfolio-link-container {
            margin-top: 2rem;
        }
        
        .view-all-portfolio-btn {
            font-size: 0.9rem;
            padding: 0.7em 1.8em;
        }
    }

    /* Portfolio Social Share Section Styling */
    .portfolio-share-section {
        margin-top: 1rem;
        padding-top: 2rem;
    }

    @media (max-width: 768px) {
        .portfolio-share-section {
            margin-top: 2rem;
            padding-top: 1.5rem;
        }
    }
</style>
