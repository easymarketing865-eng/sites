---
/**
 * Testimonials.astro
 * Enhanced modular section for showcasing client praise & testimonials with photos.
 */
import "../styles/global.css";
import styles from "../styles/Testimonials.module.css";

const testimonials = [
  {
    quote:
      "Easy Production transformed our real estate marketing with cinematic storytelling and authentic visuals. Their team understood our luxury market positioning perfectly.",
    client: "Elizaveta Real Estate",
    clientLogo: "/photos/elizaveta/width_800.webp",
    role: "Marketing Director"
  },
  {
    quote:
      "Professional excellence and international standards. Easy Production delivers campaigns that resonate across cultures while maintaining our brand integrity.",
    client: "Demir Bank",
    clientLogo: "/photos/demir/width_800.webp", 
    role: "Brand Manager"
  },
  {
    quote:
      "Creative vision meets flawless execution. They capture the essence of modern retail while honoring our local heritage. Outstanding partnership.",
    client: "Asia Store",
    clientLogo: "/photos/asiastore/asiastore.webp",
    role: "Creative Director"
  },
  {
    quote:
      "Bold concepts, smooth production workflow, and results that exceed expectations. Our clients consistently praise the final deliverables.",
    client: "MENIKI",
    clientLogo: "/photos/MENIKI_ONE/width_800 (1).webp",
    role: "Project Manager"
  }
];
---

<section class={styles.section} id="testimonials">
  <h2 class="headline">Client Testimonials</h2>
  <div class={styles.grid}>
    {testimonials.map(t => (
      <figure class={styles.card}>
        <div class={styles.imageContainer}>
          <img src={t.clientLogo} alt={`${t.client} project`} class={styles.clientImage} />
        </div>
        <blockquote class={styles.quote}>&ldquo;{t.quote}&rdquo;</blockquote>
        <figcaption class={styles.clientInfo}>
          <div class={styles.client}>{t.client}</div>
          <div class={styles.role}>{t.role}</div>
        </figcaption>
      </figure>
    ))}
  </div>
</section>
