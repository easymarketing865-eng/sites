---
/**
 * TargetSegments.astro
 * Editorial section: "We Cater To" – Agency target segments in a visually bold, clean, mobile-first grid.
 */
import "../styles/global.css";
import styles from "../styles/TargetSegments.module.css";

const segments = [
  {
    title: "Independent Filmmakers",
    description: "High-quality visuals in Kyrgyzstan's stunning locations at cost-effective rates."
  },
  {
    title: "Advertising Agencies",
    description: "Creative production partner for campaigns and concepts. Reliable delivery every time."
  },
  {
    title: "Brands",
    description: "Impactful marketing videos and commercials that capture and convert."
  },
  {
    title: "Companies in Central Asia",
    description: "Local crews and logistics with trusted on-the-ground expertise."
  },
  {
    title: "International Productions",
    description: "Global standards and adaptive teams ready to deliver anywhere."
  },
  {
    title: "Content Creators",
    description: "Professional production support for YouTube, social media, and digital content."
  }
];
---

<section class={styles.section} id="target-segments">
  <h2 class="headline">Who We Serve</h2>
  <div class={styles.grid}>
    {segments.map(segment => (
      <div class={styles.card}>
        <div class={styles.title}>{segment.title}</div>
        <div class={styles.desc}>{segment.description}</div>
      </div>
    ))}
  </div>
</section>
