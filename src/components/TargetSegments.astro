---
/**
 * TargetSegments.astro
 * Editorial section: "Who We Serve" – Agency target segments in a visually bold, clean, mobile-first grid.
 */
import "../styles/global.css";
import { t, getLocaleFromUrl } from "../lib/i18n.js";

export interface Props {
  locale?: string;
}

const { locale } = Astro.props;

// Get current locale from URL if not provided as prop
const currentLocale = locale || getLocaleFromUrl(Astro.url.pathname);

// Get translated segments data
const segments = [
  {
    title: t(currentLocale, 'segments.creativeAgency.title'),
    description: t(currentLocale, 'segments.creativeAgency.description'),
  },
  {
    title: t(currentLocale, 'segments.cgi.title'),
    description: t(currentLocale, 'segments.cgi.description'),
  },
  {
    title: t(currentLocale, 'segments.serviceProduction.title'),
    description: t(currentLocale, 'segments.serviceProduction.description'),
  },
  {
    title: t(currentLocale, 'segments.postProduction.title'),
    description: t(currentLocale, 'segments.postProduction.description'),
  }
];

// Chess pattern function: alternates properly in 2-column grid
const getChessClass = (index: number) => {
  const row = Math.floor(index / 2);
  const col = index % 2;
  return (row + col) % 2 === 0 ? 'card-white' : 'card-red';
};
---

<section class="target-segments-section" id="target-segments">
  <h2 class="section-headline emerge" data-effect="slide" data-up="40px" data-expose="true" set:html={t(currentLocale, 'segments.mainTitle')}></h2>
  <p class="section-subtitle emerge" data-effect="slide" data-up="30px" data-continue="true" data-expose="true">{t(currentLocale, 'segments.mainSubtitle')}</p>
  <div class="grids-container">
    <div class="segments-grid">
        {segments.slice(0, 2).map((segment, index) => (
        <div class={`segment-card ${getChessClass(index)} emerge`} data-effect="relax" data-scale="0.9" data-hold={index * 200} data-continue="true" data-expose="true">
            <div class="title-wrapper">
              <h3 class="card-title" set:html={segment.title}></h3>
            </div>
            <p class="card-description">{segment.description}</p>
          </div>
        ))}
      </div>
      <div class="segments-grid">
        {segments.slice(2, 4).map((segment, index) => (
          <div class={`segment-card ${getChessClass(index + 2)} emerge`} data-effect="relax" data-scale="0.9" data-hold={(index + 2) * 200} data-continue="true" data-expose="true">
            <div class="title-wrapper">
              <h3 class="card-title" set:html={segment.title}></h3>
          </div>
          <p class="card-description">{segment.description}</p>
        </div>
      ))}
      </div>
    </div>
</section>

<style>
  .target-segments-section {

    width: 100%;
    max-width: 1300px;
    margin: 0 auto 10rem auto;
    
    display: flex;
    flex-direction: column;
    align-items: left;
    padding: 0 3rem;
  }

  .section-headline {
    color: var(--brand-white);
    margin: 0 0 0.5rem 0;
  }

  .section-subtitle {
    color: var(--brand-white);
    margin: 0 0 2.5rem 0;
    opacity: 0.8;
  }

  .grids-container {
    display: flex;
    gap: 8px;
    width: 100%;
    margin: 0;
    padding: 0;
  }

  .segments-grid {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
    margin: 0;
    padding: 0;
  }

  .segment-card {
    box-shadow: 0 2px 14px #0001;
    padding-top: 16px;
    padding-left: 24px;
    padding-right: 1.2em;
    padding-bottom: 1.15em;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    position: relative;
  }

  .title-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .card-white {
    background: #fff;
  }

  .card-red {
    background: var(--brand-red);
  }

  .card-title {
    margin: 0;
    /* NO text-transform: uppercase - confirmed removed */
  }

  /* White card text - black color */
  .card-white .card-title {
    color: #000;
  }

  /* Red card text - white color */
  .card-red .card-title {
    color: white;
  }

  .card-description {
    opacity: 0.89;
    margin: 0;
    font-weight: 500;
  }

  /* White card description - black color */
  .card-white .card-description {
    color: #000;
  }

  /* Red card description - white color */
  .card-red .card-description {
    color: white;
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .target-segments-section {
      padding: 0; /* Remove horizontal padding on mobile */
    }
    .grids-container {
      flex-direction: column;
      gap: 8px;
    }
    
    .segments-grid {
      gap: 8px;
    }
    
    .segment-card {
      padding-top: 16px;
      padding-left: 24px;
      padding-right: 1em;
      padding-bottom: 1em;
    }

    /* Fix chess pattern for mobile - override the colors */
    .segment-card:nth-child(odd) {
      background: #fff !important;
    }
    
    .segment-card:nth-child(odd) .card-title,
    .segment-card:nth-child(odd) .card-description {
      color: #000 !important;
    }
    
    .segment-card:nth-child(even) {
      background: #A00000 !important;
    }
    
    .segment-card:nth-child(even) .card-title,
    .segment-card:nth-child(even) .card-description {
      color: white !important;
    }
  }

  /* Tablet responsive */
  @media (min-width: 769px) and (max-width: 949px) {
    .grids-container {
      flex-direction: row;
      gap: 8px;
    }
    
    .segments-grid {
      gap: 8px;
    }
  }

  /* Large screens */
  @media (min-width: 950px) {
    .grids-container {
      gap: 16px;
    }
    
    .segments-grid {
      gap: 8px;
    }
    
    .segment-card {
      padding-top: 1.6em;
      padding-left: 24px;
      padding-right: 1.6em;
      padding-bottom: 1.6em;
    }
  }
</style>
