---
/**
 * TargetSegments.astro
 * Editorial section: "Who We Serve" – Agency target segments in a visually bold, clean, mobile-first grid.
 */
import "../styles/global.css";

const segments = [
  {
    title: "Independent<br/>Filmmakers",
    description: "High-quality visuals in Kyrgyzstan's stunning locations at cost-effective rates.",
    icon: "/icons/director's-chair 2.svg"
  },
  {
    title: "Advertising<br/>Agencies",
    description: "Creative production partner for campaigns and concepts. Reliable delivery every time.",
    icon: "/icons/pavement-signs 1.svg"
  },
  {
    title: "Brands",
    description: "Impactful marketing videos and commercials that capture and convert.",
    icon: "/icons/sneakers 1.svg"
  },
  {
    title: "Companies in<br/>Central Asia",
    description: "Local crews and logistics with trusted on-the-ground expertise.",
    icon: "/icons/mountains 1.svg"
  },
  {
    title: "International<br/>Productions",
    description: "Global standards and adaptive teams ready to deliver anywhere.",
    icon: "/icons/earth 1.svg"
  },
  {
    title: "Content<br/>Creators",
    description: "Professional production support for YouTube, social media, and digital content.",
    icon: "/icons/phone-camera 1.svg"
  }
];

// Chess pattern function: alternates properly in 3-column grid
const getChessClass = (index: number) => {
  const row = Math.floor(index / 3);
  const col = index % 3;
  return (row + col) % 2 === 0 ? 'card-white' : 'card-red';
};
---

<section class="target-segments-section" id="target-segments">
  {/* Alternative titles to choose from:
    1. "Our Creative Partners"
    2. "Made For You"
    3. "Industries We Transform"
    4. "Let's Create Together"
    5. "Your Vision, Our Expertise"
  */}
  <h2 class="section-headline">Industries We Transform</h2>
  <div class="segments-grid">
    {segments.map((segment, index) => (
      <div class={`segment-card ${getChessClass(index)}`}>
        <div class="icon-title-wrapper">
          <div class="card-icon">
            <img src={segment.icon} alt={segment.title} />
          </div>
          <h3 class="card-title" set:html={segment.title}></h3>
        </div>
        <p class="card-description">{segment.description}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .target-segments-section {
    width: 100%;
    max-width: 1300px;
    margin: 0 auto 3em auto;
    
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .section-headline {
    
    font-weight: 900;
    color: var(--brand-black);
    letter-spacing: 0.0em;
    margin: 0 0 2rem 0;
    font-family: var(--font-sans);
  }

  .segments-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 8px;
    width: 100%;
    margin: 0;
    padding: 0;
  }

  .segment-card {
    box-shadow: 0 2px 14px #0001;
    padding-top: 16px;
    padding-left: 24px;
    padding-right: 1.2em;
    padding-bottom: 1.15em;
    min-width: 0;
    min-height: 120px;
    display: flex;
    flex-direction: column;
    gap: 0.75em;
    position: relative;
  }

  .icon-title-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .card-white {
    background: var(--brand-white, #fff);
  }

  .card-red {
    background: var(--brand-red, #A00000);
  }

  .card-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0px;
  }

  /* White card icons - black color */
  .card-white .card-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: brightness(0) saturate(100%) invert(0%);
  }

  /* Red card icons - white color */
  .card-red .card-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: brightness(0) saturate(100%) invert(100%);
  }

  .card-title {
    font-size: var(--font-size-md);
    font-weight: 800;
    letter-spacing: -1px;
    font-family: var(--font-sans);
    margin: 0;
    line-height: 100%;
    /* NO text-transform: uppercase - confirmed removed */
  }

  /* White card text - black color */
  .card-white .card-title {
    color: var(--brand-black, #111);
  }

  /* Red card text - white color */
  .card-red .card-title {
    color: white;
  }

  .card-description {
    font-size: 1em;
    font-family: var(--font-sans);
    line-height: 1.36;
    opacity: 0.89;
    margin: 0;
  }

  /* White card description - black color */
  .card-white .card-description {
    color: var(--brand-black, #111);
  }

  /* Red card description - white color */
  .card-red .card-description {
    color: white;
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .segments-grid {
      grid-template-columns: 1fr;
      gap: 8px;
    }
    
    .segment-card {
      min-height: 100px;
      padding-top: 16px;
      padding-left: 24px;
      padding-right: 1em;
      padding-bottom: 1em;
    }

    .card-icon {
      width: 36px;
      height: 36px;
    }
  }

  /* Tablet responsive */
  @media (min-width: 769px) and (max-width: 949px) {
    .segments-grid {
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }
  }

  /* Large screens */
  @media (min-width: 950px) {
    .segments-grid {
      gap: 8px;
    }
    
    .segment-card {
      min-height: 140px;
      padding-top: 16px;
      padding-left: 24px;
      padding-right: 1.6em;
      padding-bottom: 1.4em;
    }

    .card-icon {
      width: 44px;
      height: 44px;
    }
  }
</style>
