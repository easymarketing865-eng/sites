---
/**
 * TargetSegments.astro
 * Editorial section: "Who We Serve" – Agency target segments in a visually bold, clean, mobile-first grid.
 */
import "../styles/global.css";

const segments = [
  {
    title: "Creative <br/> agency",
    description: "We develop original concepts for commercials, documentaries, and brand films that connect with audiences. From the first idea to the final script, our creative team works closely with clients to shape powerful narratives and striking visual approaches. We specialize in building concepts that are bold, clear, and production-ready — with a strong focus on storytelling, mood, and message. Whether you're launching a new product or telling your brand's story, we help turn vision into concept — and concept into action.",
    
  },
  {
    title: "CGI",
    description: "We create high-end VFX, 3D animation, and motion design for global clients — working fully remotely with tight coordination and attention to detail. From realistic visual effects to stylized graphic elements, we adapt our style to each project's needs. Our portfolio includes collaborations with top brands, creative agencies, and film directors. Whether you need subtle enhancements or full-on CGI environments, our team delivers with technical precision and creative flair — always on time and on brief.",
  
  },
  {
    title: "Service <br/> Production ",
    description: "From scouting breathtaking locations to assembling a professional local crew, we handle every step of the process. Need equipment, casting, permits, or logistics? We've got it covered. Whether you're shooting a commercial, documentary, or branded content — we make it seamless.",
   
  },
  {
    title: "Post-production",
    description: "We handle the entire post-production process — from editing, color grading, and sound design to advanced VFX and final mastering. Our team works with international clients across time zones, ensuring fast, clear communication and consistent results. Whether it's a commercial, branded content, or narrative piece, we take your raw footage and deliver a polished, broadcast-ready product. You can trust us to meet deadlines without compromising quality — every frame, every time.",

  }
  
];

// Chess pattern function: alternates properly in 2-column grid
const getChessClass = (index: number) => {
  const row = Math.floor(index / 2);
  const col = index % 2;
  return (row + col) % 2 === 0 ? 'card-white' : 'card-red';
};
---

<section class="target-segments-section" id="target-segments">
  {/* Alternative titles to choose from:
    1. "Our Creative Partners"
    2. "Made For You"
    3. "Industries We Transform"
    4. "Let's Create Together"
    5. "Your Vision, Our Expertise"
  */}
  <h2 class="section-headline">From First Idea <br> to Final Cut</h2>
  <p class="section-subtitle">Concepts, crews, landscapes, pixels — we cover the full spectrum. Whether you need a local fixer in Kyrgyzstan or a world-class VFX pipeline, we're your behind-the-scenes team.</p>
  <div class="grids-container">
    <div class="segments-grid">
        {segments.slice(0, 2).map((segment, index) => (
        <div class={`segment-card ${getChessClass(index)}`}>
            <div class="title-wrapper">
              <h3 class="card-title" set:html={segment.title}></h3>
            </div>
            <p class="card-description">{segment.description}</p>
          </div>
        ))}
      </div>
      <div class="segments-grid">
        {segments.slice(2, 4).map((segment, index) => (
          <div class={`segment-card ${getChessClass(index + 2)}`}>
            <div class="title-wrapper">
              <h3 class="card-title" set:html={segment.title}></h3>
          </div>
          <p class="card-description">{segment.description}</p>
        </div>
      ))}
      </div>
    </div>
</section>

<style>
  .target-segments-section {

    width: 100%;
    max-width: 1300px;
    margin: 0 auto 10rem auto;
    
    display: flex;
    flex-direction: column;
    align-items: left;
  }

  .section-headline {
    color: var(--brand-black);
    margin: 0 0 0.5rem 0;
  }

  .section-subtitle {
    color: var(--brand-black);
    margin: 0 0 2.5rem 0;
    opacity: 0.8;
  }

  .grids-container {
    display: flex;
    gap: 16px;
    width: 100%;
    margin: 0;
    padding: 0;
  }

  .segments-grid {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
    margin: 0;
    padding: 0;
  }

  .segment-card {
    box-shadow: 0 2px 14px #0001;
    padding-top: 16px;
    padding-left: 24px;
    padding-right: 1.2em;
    padding-bottom: 1.15em;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    position: relative;
  }

  .title-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .card-white {
    background: #fff;
  }

  .card-red {
    background: #A00000;
  }

  .card-title {
    margin: 0;
    /* NO text-transform: uppercase - confirmed removed */
  }

  /* White card text - black color */
  .card-white .card-title {
    color: #000;
  }

  /* Red card text - white color */
  .card-red .card-title {
    color: white;
  }

  .card-description {
    opacity: 0.89;
    margin: 0;
    font-weight: 500;
  }

  /* White card description - black color */
  .card-white .card-description {
    color: #000;
  }

  /* Red card description - white color */
  .card-red .card-description {
    color: white;
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .grids-container {
      flex-direction: column;
      gap: 8px;
    }
    
    .segments-grid {
      gap: 8px;
    }
    
    .segment-card {
      padding-top: 16px;
      padding-left: 24px;
      padding-right: 1em;
      padding-bottom: 1em;
    }
  }

  /* Tablet responsive */
  @media (min-width: 769px) and (max-width: 949px) {
    .grids-container {
      flex-direction: row;
      gap: 16px;
    }
    
    .segments-grid {
      gap: 8px;
    }
  }

  /* Large screens */
  @media (min-width: 950px) {
    .grids-container {
      gap: 16px;
    }
    
    .segments-grid {
      gap: 8px;
    }
    
    .segment-card {
      padding-top: 1.6em;
      padding-left: 24px;
      padding-right: 1.6em;
      padding-bottom: 1.6em;
    }
  }
</style>
