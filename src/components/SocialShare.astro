---
/**
 * SocialShare.astro
 * Custom social sharing component with Likely-inspired styling
 * Supports Instagram, WhatsApp, Email, Facebook, and Telegram
 */
import "../styles/global.css";

interface Props {
  url?: string;
  title?: string;
  description?: string;
  className?: string;
}

const { 
  url = '',
  title = "Check this out!",
  description = "Amazing video production services",
  className = ""
} = Astro.props;

// Generate sharing URLs
const shareUrl = url || (typeof window !== 'undefined' ? window.location.href : '');
const encodedUrl = encodeURIComponent(shareUrl);
const encodedTitle = encodeURIComponent(title);
const encodedDescription = encodeURIComponent(description);
const fullText = encodeURIComponent(`${title} - ${description}`);

const shareLinks = {
  whatsapp: `https://wa.me/?text=${fullText}%20${encodedUrl}`,
  telegram: `https://t.me/share/url?url=${encodedUrl}&text=${fullText}`,
  facebook: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`,
};
---

<div class={`social-share-container ${className}`}>
  <div class="share-buttons">
    <!-- WhatsApp -->
    <a 
      href={shareLinks.whatsapp}
      class="share-btn whatsapp-btn"
      target="_blank"
      rel="noopener noreferrer"
      data-service="whatsapp"
    >
      <svg class="share-icon" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/>
      </svg>
      WhatsApp
    </a>

    <!-- Telegram -->
    <a 
      href={shareLinks.telegram}
      class="share-btn telegram-btn"
      target="_blank"
      rel="noopener noreferrer"
      data-service="telegram"
    >
      <svg class="share-icon" viewBox="0 0 24 24" fill="currentColor">
        <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
      </svg>
      Telegram
    </a>

    <!-- Facebook -->
    <a 
      href={shareLinks.facebook}
      class="share-btn facebook-btn"
      target="_blank"
      rel="noopener noreferrer"
      data-service="facebook"
    >
      <svg class="share-icon" viewBox="0 0 24 24" fill="currentColor">
        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
      </svg>
      Facebook
    </a>


    

    <!-- Instagram (Copy to clipboard) -->
    <button 
      class="share-btn instagram-btn"
      onclick="copyToClipboard()"
      title="Copy link to share on Instagram"
      data-service="instagram"
    >
      <svg class="share-icon" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
      </svg>
      Instagram
    </button>
  </div>
</div>

<script>
  // Copy to clipboard function for Instagram
  function copyToClipboard() {
    const url = window.location.href;
    const title = document.querySelector('.share-title')?.textContent || 'Check this out!';
    const textToCopy = `${title}\n\n${url}`;
    
    if (navigator.clipboard) {
      navigator.clipboard.writeText(textToCopy).then(() => {
        alert('Link copied! You can now paste it in Instagram.');
      }).catch(() => {
        fallbackCopyTextToClipboard(textToCopy);
      });
    } else {
      fallbackCopyTextToClipboard(textToCopy);
    }
  }
  
  function fallbackCopyTextToClipboard(text: string) {
    const textArea = document.createElement("textarea");
    textArea.value = text;
    textArea.style.top = "0";
    textArea.style.left = "0";
    textArea.style.position = "fixed";
    document.body.appendChild(textArea);
    textArea.focus();
    textArea.select();
    
    try {
      document.execCommand('copy');
      alert('Link copied! You can now paste it in Instagram.');
    } catch (err) {
      alert('Failed to copy link. Please copy manually: ' + text);
    }
    
    document.body.removeChild(textArea);
  }
  
  // Make functions global so they can be called from onclick
  (window as any).copyToClipboard = copyToClipboard;
</script>

<style>
  .social-share-container {
    padding: 1.5rem;
    border-radius: 12px;
  }

  .share-title {
    font-family: var(--font-sans);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--brand-black, #111);
    margin: 0 0 1rem 0;
    
  }

  /* Likely-inspired button styling */
  .share-buttons {
    display: flex;
    gap: 0.5rem;
  justify-content: center;
    flex-wrap: wrap;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border: none;
    border-radius: 3px;
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s ease;
    min-height: 32px;
    box-sizing: border-box;
  }

  .share-btn:hover {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  /* Service-specific background colors */
  .whatsapp-btn {
    background: #25D366;
  }

  .telegram-btn {
    background: #0088cc;
  }

  .facebook-btn {
    background: #1877f2;
  }


  .instagram-btn {
    background: #8E0C12;
  }

  .share-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    color: #fff;
  }

  /* Remove button default styles for Instagram button */
  .instagram-btn {
    border: none;
    background: #8E0C12;
  }

  @media (max-width: 768px) {
    .share-buttons {
      flex-direction: row;
      justify-content: center;
      gap: 1rem;
    }

    .share-btn {
      height: 56px;
      min-width: 56px;
      padding: 0;
      justify-content: center;
      align-items: center;
      font-size: 0;
      display: flex;
      border-radius: 4px;
      text-indent: -9999px;
      overflow: hidden;
    }

    .share-btn .share-icon {
      width: 28px;
      height: 28px;
      margin: 0;
      position: absolute;
    }
  }

  /* Portfolio-specific styling */
  .portfolio-share .social-share-container {
    background: transparent;
    box-shadow: none;
    padding: 1rem 0;
    margin: 0;
  }

  .portfolio-share .share-title {
    color: #fff;
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 1rem;
    text-align: center;
  }

  .portfolio-share .share-btn {
    color: #fff;
  }

  .portfolio-share .share-icon {
    color: #fff;
  }

  .portfolio-share .share-btn:hover {
    color: #fff;
  }

  /* Portfolio-specific darker hover backgrounds */
  .portfolio-share .whatsapp-btn:hover {
    background: #1ea952;
  }

  .portfolio-share .telegram-btn:hover {
    background: #006ba3;
  }

  .portfolio-share .facebook-btn:hover {
    background: #1464c7;
  }



  .portfolio-share .instagram-btn:hover {
    background: #6b090e;
  }
</style> 