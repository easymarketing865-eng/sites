---
/**
 * FloatingContactButton.astro
 * Floating action button for contact that leads to /contact page
 */
import "../styles/global.css";
---

<div class="floating-contact-button">
    <a href="/contact" class="fab-button" aria-label="Become client">
        <span class="fab-text">Become client</span>
    </a>
</div>

<style>
    .floating-contact-button {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        z-index: 1000;

    }

    .fab-button {
        display: flex;
        align-items: center;
        padding: 0.8rem 1.5rem;
        background: #a00000;
        color: #fff;
        text-decoration: none;
        box-shadow: 0 4px 20px rgba(160, 0, 0, 0.3);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
        border-radius: 8px;
    }

   

    .fab-button:hover {
        background: #fff;
        color: #a00000;
    }

    .fab-text {
        font-family: "Manrope", var(--font-sans);
        font-size: 0.8rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.02em;
        white-space: nowrap;
    }

    @media (max-width: 768px) {
        .floating-contact-button {
            bottom: 1.5rem;
            right: 1.5rem;
        }

        .fab-button {
            padding: 0.7rem 1.2rem;
        }

        .fab-text {
            font-size: 0.75rem;
        }
    }

    @media (max-width: 480px) {
        .floating-contact-button {
            bottom: 1rem;
            right: 1rem;
        }

        .fab-button {
            padding: 0.6rem 1rem;
        }

        .fab-text {
            font-size: 0.7rem;
        }
    }

    /* Focus states for accessibility */
    .btn:focus {
        outline: 2px solid white;
        outline-offset: 2px;
    }

    .floating-contact-btn {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        background: var(--brand-red);
        color: white;
        padding: 1rem 1.5rem;
        border-radius: 50px;
        text-decoration: none;
        font-family: var(--font-sans);
        font-weight: 700;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.02em;
        box-shadow: 0 4px 20px rgba(160, 0, 0, 0.3);
        transition: all 0.3s ease;
        z-index: 1000;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
</style>