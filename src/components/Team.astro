---
import { t, getLocaleFromUrl } from "../lib/i18n.js";

export interface Props {
  locale?: string;
}

const { locale } = Astro.props;

// Get current locale from URL if not provided as prop
const currentLocale = locale || getLocaleFromUrl(Astro.url.pathname);
---

<section class="team-section emerge" data-expose="true" data-effect="slide" data-up="40px">
    <div class="team-container">
        <div class="team-header emerge" data-continue="true" data-hold="200" data-effect="slide" data-up="30px">
            <h2 class="section-headline team-title">{t(currentLocale, 'team.mainTitle')}</h2>
            <p class="section-subtitle team-subtitle">{t(currentLocale, 'team.mainSubtitle')}</p>
        </div>
        
        <div class="team-grid">
                         <div class="team-member emerge" data-continue="true" data-hold="100" data-effect="zoom" data-scale="0.8">
                 <a href="/portfolio" class="member-card member-link">
                 <div class="member-image-wrapper">
                     <img
                         src="/team/alina-saiitova.png"
                         alt="Alina Saiitova"
                         class="member-image"
                     />
                     <div class="member-overlay">
                             <div class="member-info">
                         <h3 class="member-name">Alina Saiitova</h3>
                                 <p class="member-role">Owner, Producer & Creative Director</p>
                             </div>
                         </div>
                     </div>
                 </a>
             </div>

                         <div class="team-member emerge" data-continue="true" data-hold="100" data-effect="zoom" data-scale="0.8">
                 <a href="/portfolio" class="member-card member-link">
                 <div class="member-image-wrapper">
                     <img
                         src="/team/arsenii-morozov.png"
                         alt="Arsenii Morozov"
                         class="member-image"
                     />
                     <div class="member-overlay">
                             <div class="member-info">
                         <h3 class="member-name">Arsenii Morozov</h3>
                                 <p class="member-role">Camera Operator</p>
                             </div>
                         </div>
                     </div>
                 </a>
             </div>

                         <div class="team-member emerge" data-continue="true" data-hold="100" data-effect="zoom" data-scale="0.8">
                 <a href="/portfolio" class="member-card member-link">
                 <div class="member-image-wrapper">
                     <img
                         src="/team/aktilek-ibraimov.png"
                         alt="Aktilek Ibraimov"
                         class="member-image"
                     />
                     <div class="member-overlay">
                             <div class="member-info">
                         <h3 class="member-name">Aktilek Ibraimov</h3>
                                 <p class="member-role">CGI Artist</p>
                             </div>
                         </div>
                     </div>
                 </a>
             </div>

                         <div class="team-member emerge" data-continue="true" data-hold="100" data-effect="zoom" data-scale="0.8">
                 <a href="/portfolio" class="member-card member-link">
                 <div class="member-image-wrapper">
                     <img
                         src="/team/milena-islamova.png"
                         alt="Milena Islamova"
                         class="member-image"
                     />
                     <div class="member-overlay">
                             <div class="member-info">
                         <h3 class="member-name">Milena Islamova</h3>
                                 <p class="member-role">General Manager</p>
                             </div>
                         </div>
                     </div>
                 </a>
             </div>

             <div class="team-member emerge" data-continue="true" data-hold="100" data-effect="zoom" data-scale="0.8">
                 <a href="/portfolio" class="member-card member-link">
                 <div class="member-image-wrapper">
                     <img
                         src="/team/timur-vagizov.png"
                         alt="Timur Vagizov"
                         class="member-image"
                     />
                     <div class="member-overlay">
                             <div class="member-info">
                         <h3 class="member-name">Timur Vagizov</h3>
                                 <p class="member-role">Director of Photography</p>
                             </div>
                         </div>
                     </div>
                 </a>
             </div>

             <div class="team-member emerge" data-continue="true" data-hold="100" data-effect="zoom" data-scale="0.8">
                 <a href="/portfolio" class="member-card member-link">
                 <div class="member-image-wrapper">
                     <img
                         src="/team/asel-imankulova.png"
                         alt="Asel Imankulova"
                         class="member-image"
                     />
                     <div class="member-overlay">
                             <div class="member-info">
                         <h3 class="member-name">Asel Imankulova</h3>
                         <p class="member-role">Screenwriter</p>
                             </div>
                         </div>
                     </div>
                 </a>
             </div>

             <div class="team-member emerge" data-continue="true" data-hold="100" data-effect="zoom" data-scale="0.8">
                 <a href="/portfolio" class="member-card member-link">
                 <div class="member-image-wrapper">
                     <img
                         src="/team/yana-mashirova.png"
                         alt="Yana Mashirova"
                         class="member-image"
                     />
                     <div class="member-overlay">
                             <div class="member-info">
                         <h3 class="member-name">Yana Mashirova</h3>
                                 <p class="member-role">Project Manager</p>
                             </div>
                         </div>
                     </div>
                 </a>
             </div>

             <div class="team-member emerge" data-continue="true" data-hold="100" data-effect="zoom" data-scale="0.8">
                 <a href="/portfolio" class="member-card member-link">
                 <div class="member-image-wrapper">
                     <img
                         src="/team/alisa-ugarova.png"
                         alt="Alisa Ugarova"
                         class="member-image"
                     />
                     <div class="member-overlay">
                             <div class="member-info">
                         <h3 class="member-name">Alisa Ugarova</h3>
                                 <p class="member-role">Production Designer</p>
                             </div>
                         </div>
                     </div>
                 </a>
             </div>
            
            <div class="team-member join-us-card emerge" data-continue="true" data-hold="200" data-effect="slide" data-left="30px">
                <div class="member-card join-us-wrapper">
                    <div class="join-us-content">
                        <div class="join-us-icon">
                            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M12 12C14.7614 12 17 9.76142 17 7C17 4.23858 14.7614 2 12 2C9.23858 2 7 4.23858 7 7C7 9.76142 9.23858 12 12 12Z" fill="currentColor"/>
                                <path d="M12 14C7.58172 14 4 17.5817 4 22H20C20 17.5817 16.4183 14 12 14Z" fill="currentColor"/>
                            </svg>
                        </div>
                        <h3 class="join-us-title">Our Team</h3>
                        <p class="join-us-text">We're a close-knit creative family dedicated to bringing your vision to life</p>
                        <a href="/contact" class="btn btn-primary">
                            <span>Work With Us</span>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .team-section {
        width: 100%;
        padding: 0rem 2rem;
        
        min-height: 100vh;
        display: flex;
        align-items: center;
    }

    .team-container {
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
    }

    .team-header {
        text-align: center;
        margin-bottom: 5rem;
        max-width: 800px;
        margin-left: auto;
        margin-right: auto;
    }

    .team-title {
        color: var(--brand-white);
        margin: 0 0 1.5rem 0;
    }

    .team-subtitle {
        color: var(--brand-white);
        margin: 0;
    }

    .team-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1rem;
        width: 100%;
        max-width: 1400px;
        margin: 0 auto;
    }

    .team-member {
        position: relative;
    }

         .member-card {
         position: relative;
         overflow: hidden;
         box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
         background: #fff;
         height: 100%;
         aspect-ratio: 3/4;
     }

     .member-link {
         display: block;
         text-decoration: none;
         color: inherit;
     }

    /* Mobile responsive adjustments */
    @media (max-width: 768px) {
        .member-card {
            aspect-ratio: 4/5; /* More compact ratio for mobile */
        }
    }

    .member-image-wrapper {
        position: relative;
        width: 100%;
        height: 100%;
        overflow: hidden;
    }

    .member-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .member-overlay {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(
            transparent 0%, 
            rgba(0, 0, 0, 0.1) 30%, 
            rgba(0, 0, 0, 0.8) 100%
        );
        padding: 2rem 1.5rem 1.5rem;
        transform: translateY(0);
    }

    .member-info {
        color: white;
    }

    .member-name {
        color: white;
        margin: 0 0 0.5rem 0;
    }

    .member-role {
        color: rgba(255, 255, 255, 0.9);
        margin: 0;
    }

    /* Join Us Card Styles */
    .join-us-card .member-card {
        background: var(--brand-white);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .join-us-wrapper {
        border: none;
    }

    .join-us-content {
        text-align: center;
        color: white;
        padding: 2rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
    }

    .join-us-icon {
        color:var(--brand-black);
    }

    .join-us-title {
        color: var(--brand-black);
        margin: 0;
    }

    .join-us-text {
        color: var(--brand-black);
        margin: 0;
        max-width: 250px;
    }

    .join-us-content .btn {
        margin-top: 0.5rem;
        background-color: var(--brand-black);
        color: var(--brand-white);
    }

    .join-us-content .btn svg {
        width: 16px;
        height: 16px;
    }

    /* Responsive Design */
    @media (max-width: 1200px) {
        .team-grid {
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
        }
    }

    @media (max-width: 900px) {
        .team-section {
            padding: 0rem 1.5rem;
        }

        .team-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 1.25rem;
        }

        .team-header {
            margin-bottom: 4rem;
        }
    }

    @media (max-width: 600px) {
        .team-section {
            padding: 4rem 0;
        }

        .team-container {
            width: 100vw;
            margin-left: calc(-50vw + 50%);
            margin-right: calc(-50vw + 50%);
            padding: 0 0.5rem; /* Reduced padding */
        }

        .team-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 0.25rem; /* Reduced gap */
            width: 100%;
            max-width: none;
        }

        .member-card {
            aspect-ratio: 1/1.5; /* Square aspect ratio for very small screens */
        }

        .team-header {
            margin-bottom: 3rem;
            padding: 0 0.5rem;
        }

        .member-overlay {
            padding: 0.75rem 0.5rem 0.5rem;
        }

        .join-us-card {
            display: none; /* Hide entire join-us card on mobile */
        }
    }

    @media (max-width: 480px) {


        .member-card {
            /* border-radius: 16px; */
        }

        .member-overlay {
            padding: 1.5rem 0.75rem 0.75rem;
        }
    }

    /* Focus states for accessibility */
    .btn:focus {
        outline: 2px solid white;
        outline-offset: 2px;
    }
</style>