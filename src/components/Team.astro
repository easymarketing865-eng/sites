---
import { team } from "../lib/pocketbase.js";

let teamMembers = [];

try {
  // Try to fetch from PocketBase
  const result = await team.getAll();
  teamMembers = result.items || [];
  console.log(`Loaded ${teamMembers.length} team members from PocketBase`);
} catch (error) {
  console.log('PocketBase not available for Team, using fallback data:', (error as Error).message);
  // Fallback to default team data
  teamMembers = [
    {
      name: 'Timur Vagizov',
      role: 'Creative Director',
      bio: 'Creative visionary with over 5 years of experience in video production and storytelling.',
      photo: '/team/timur-vagizov.png',
      order: 1
    },
    {
      name: 'Alina Saiitova', 
      role: 'Producer',
      bio: 'Project management expert ensuring smooth production workflows.',
      photo: '/team/alina-saiitova.png',
      order: 2
    },
    {
      name: 'Arsenii Morozov',
      role: 'Director of Photography', 
      bio: 'Master of cinematography with an eye for compelling visual narratives.',
      photo: '/team/arsenii-morozov.png',
      order: 3
    },
    {
      name: 'Asel Imankulova',
      role: 'Project Manager',
      bio: 'Coordination specialist ensuring projects run smoothly from concept to delivery.',
      photo: '/team/asel-imankulova.png',
      order: 4
    },
    {
      name: 'Milena Islamova',
      role: 'Editor',
      bio: 'Post-production expert crafting compelling stories through editing.',
      photo: '/team/milena-islamova.png',
      order: 5
    },
    {
      name: 'Yana Mashirova',
      role: 'Motion Designer',
      bio: 'Creative motion graphics specialist bringing brands to life.',
      photo: '/team/yana-mashirova.png',
      order: 6
    },
    {
      name: 'Alisa Ugarova',
      role: 'Content Creator',
      bio: 'Digital content specialist creating engaging social media content.',
      photo: '/team/alisa-ugarova.png',
      order: 7
    },
    {
      name: 'Aktilek Ibraimov',
      role: 'Camera Operator',
      bio: 'Technical filming expert with precision and creative flair.',
      photo: '/team/aktilek-ibraimov.png',
      order: 8
    }
  ];
}

// Sort team members by order
teamMembers.sort((a, b) => (a.order || 999) - (b.order || 999));
---

<section class="team-section" id="team">
    <div class="team-content">
        <h2 class="team-headline">Our Team</h2>
        <p class="team-description">
            Meet the creative minds behind Easy Production. Our diverse team of professionals brings together years of experience in video production, storytelling, and creative excellence.
        </p>
        
        <div class="team-grid">
            {teamMembers.map((member) => (
                <div class="team-member">
                    <div class="member-photo">
                        <img 
                            src={member.photo || '/team/placeholder.png'} 
                            alt={member.name}
                            loading="lazy"
                        />
                    </div>
                    <div class="member-info">
                        <h3 class="member-name">{member.name}</h3>
                        <p class="member-role">{member.role}</p>
                        {member.bio && (
                            <div class="member-bio" set:html={member.bio} />
                        )}
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<style>
    .team-section {
        width: 100%;
        padding: 4rem 0;
        background: #ffffff;
    }

    .team-content {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    .team-headline {
        font-family: var(--font-heading);
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 700;
        color: var(--brand-black);
        text-align: center;
        margin-bottom: 1rem;
        letter-spacing: -0.02em;
    }

    .team-description {
        font-family: var(--font-sans);
        font-size: 1.1rem;
        line-height: 1.6;
        color: #666;
        text-align: center;
        max-width: 600px;
        margin: 0 auto 3rem auto;
    }

    .team-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 2rem;
        margin-top: 3rem;
    }

    .team-member {
        background: #ffffff;
        border-radius: 12px;
        padding: 2rem;
        text-align: center;
        border: 1px solid #f0f0f0;
        transition: all 0.3s ease;
        position: relative;
    }

    .team-member:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
        border-color: var(--brand-red);
    }

    .member-photo {
        width: 120px;
        height: 120px;
        margin: 0 auto 1.5rem auto;
        border-radius: 50%;
        overflow: hidden;
        border: 3px solid #f0f0f0;
        transition: border-color 0.3s ease;
    }

    .team-member:hover .member-photo {
        border-color: var(--brand-red);
    }

    .member-photo img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .team-member:hover .member-photo img {
        transform: scale(1.1);
    }

    .member-info {
        text-align: center;
    }

    .member-name {
        font-family: var(--font-heading);
        font-size: 1.3rem;
        font-weight: 600;
        color: var(--brand-black);
        margin-bottom: 0.5rem;
    }

    .member-role {
        font-family: var(--font-sans);
        font-size: 1rem;
        font-weight: 500;
        color: var(--brand-red);
        margin-bottom: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .member-bio {
        font-family: var(--font-sans);
        font-size: 0.9rem;
        line-height: 1.5;
        color: #666;
    }

    .member-bio p {
        margin: 0;
    }

    /* Responsive Design */
    @media (max-width: 768px) {
        .team-content {
            padding: 0 1rem;
        }

        .team-grid {
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
        }

        .team-member {
            padding: 1.5rem;
        }

        .member-photo {
            width: 100px;
            height: 100px;
            margin-bottom: 1rem;
        }

        .team-headline {
            font-size: 2rem;
        }

        .team-description {
            font-size: 1rem;
            margin-bottom: 2rem;
        }
    }

    @media (max-width: 480px) {
        .team-section {
            padding: 3rem 0;
        }

        .team-content {
            padding: 0 0.5rem;
        }

        .team-grid {
            grid-template-columns: 1fr;
            gap: 1rem;
        }

        .team-member {
            padding: 1rem;
        }

        .member-photo {
            width: 80px;
            height: 80px;
        }

        .member-name {
            font-size: 1.1rem;
        }

        .member-role {
            font-size: 0.9rem;
        }

        .member-bio {
            font-size: 0.8rem;
        }
    }
</style>
