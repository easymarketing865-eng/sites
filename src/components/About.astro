---
/**
 * About.astro
 * Modular editorial about/introduction section.
 * Can be placed after main flow or in footer.
 * Uses a photo placeholder (swap for any agency/team/documentary image).
 */
import "../styles/global.css";
import styles from "../styles/About.module.css";

const aboutText = `easy. production is a visionary film agency blending international standards with Kyrgyz heritage. Our team thrives on authenticity, bold editorial design, and crafting cinematic experiences that connect brands to real audiences, anywhere.`;

---

<section class={styles.section} id="about">
  <div class={styles.innerWrap}>
    <div class={styles.textBlock}>
      <h2 class="headline">About Us</h2>
      <p class={styles.body}>{aboutText}</p>
    </div>
    <div class={styles.imgBlock}>
      <img
        src="/photos/ELIZAVETA.webp"
        alt="Our creative team on set (documentary style)"
        class={styles.img}
        loading="lazy"
      />
    </div>
  </div>
</section>
