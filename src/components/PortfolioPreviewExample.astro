---
/**
 * PortfolioPreviewExample.astro
 * Example usage of both PortfolioPreview and PortfolioPreviewGrid components
 * This file demonstrates various configurations and use cases
 */
import PortfolioPreview from "./PortfolioPreview.astro";
import PortfolioPreviewGrid from "./PortfolioPreviewGrid.astro";
---

<div class="portfolio-examples">
    <!-- Standard Portfolio Preview - First 3 items -->
    <PortfolioPreview 
        startIndex={0}
        toShow={3}
        title="Featured Projects"
    />

    <!-- Grid Preview - Next 4 items in horizontal scroll -->
    <PortfolioPreviewGrid 
        startIndex={3}
        toShow={4}
        title="More Projects"
    />

    <!-- Compact Preview without title -->
    <PortfolioPreview 
        startIndex={1}
        toShow={2}
        showTitle={false}
        className="compact"
    />

    <!-- Grid with different starting point -->
    <PortfolioPreviewGrid 
        startIndex={0}
        toShow={5}
        title="Latest Work"
        className="extended"
    />

    <!-- Small preview for sidebar or footer -->
    <PortfolioPreview 
        startIndex={2}
        toShow={4}
        title="Related Projects"
        className="compact"
    />
</div>

<style>
    .portfolio-examples {
        max-width: 1400px;
        margin: 0 auto;
        padding: 2rem 1rem;
        background: #000;
    }

    .portfolio-examples > :global(.portfolio-preview),
    .portfolio-examples > :global(.portfolio-preview-grid) {
        margin-bottom: 4rem;
    }

    .portfolio-examples > :global(.portfolio-preview.compact) {
        margin-bottom: 2rem;
    }

    .portfolio-examples > :global(.portfolio-preview-grid.extended) {
        margin-bottom: 3rem;
    }

    @media (max-width: 768px) {
        .portfolio-examples {
            padding: 1rem 0.5rem;
        }

        .portfolio-examples > :global(.portfolio-preview),
        .portfolio-examples > :global(.portfolio-preview-grid) {
            margin-bottom: 2.5rem;
        }
    }
</style>