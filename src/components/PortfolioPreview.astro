---
/**
 * PortfolioPreview.astro
 * Reusable portfolio preview component with configurable display options
 * Props: startIndex (default: 0), toShow (default: 3)
 */
import "../styles/global.css";
import portfolioData from "../data/portfolio.json";

export interface Props {
  startIndex?: number;
  toShow?: number;
  showTitle?: boolean;
  title?: string;
  className?: string;
}

const { 
  startIndex = 0, 
  toShow = 3, 
  showTitle = true, 
  title = "Portfolio Preview",
  className = ""
} = Astro.props;

// Combine featured and regular portfolio items
const allProjects = [...portfolioData.featured, ...portfolioData.portfolio];
const projects = allProjects.slice(startIndex, startIndex + toShow).map(project => ({
    title: project.title,
    img: project.hero,
    desc: project.shortDescription,
    slug: project.slug,
    services: project.services || [],
    category: project.category
}));
---

<section class={`portfolio-preview ${className}`}>
    {showTitle && (
        <h2 class="preview-title">{title}</h2>
    )}
    
    <div class="preview-grid">
        {
            projects.map((project, index) => (
                <a href={`/portfolio/${project.slug}`} class="preview-card">
                    <img
                        src={project.img}
                        alt={`${project.title} project image`}
                        class="preview-img"
                        loading="lazy"
                    />
                    <div class="preview-overlay">
                        <div class="preview-content">
                            <h3 class="preview-project-title">{project.title}</h3>
                            <p class="preview-project-desc">{project.desc}</p>
                            <span class="preview-category">{project.category}</span>
                        </div>
                    </div>
                </a>
            ))
        }
    </div>
    
    <div class="portfolio-link-container">
        <a href="/portfolio" class="view-portfolio-btn">VIEW FULL PORTFOLIO</a>
    </div>
</section>

<style>
    .portfolio-preview {
        width: 100%;
        margin: 2rem 0;
        background: #000;
        padding: 2rem;
        border-radius: 8px;
    }

    .preview-title {
        font-family: var(--font-heading);
        font-size: 1.8rem;
        font-weight: 800;
        color: #fff;
        margin-bottom: 1.5rem;
        text-align: left;
        text-transform: uppercase;
        letter-spacing: 0.02em;
    }

    .preview-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.5rem;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    .preview-card {
        position: relative;
        aspect-ratio: 4/3;
        border-radius: 12px;
        overflow: hidden;
        text-decoration: none;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        cursor: pointer;
    }

    .preview-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
    }

    .preview-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .preview-card:hover .preview-img {
        transform: scale(1.05);
    }

    .preview-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: linear-gradient(
            transparent 0%,
            rgba(0, 0, 0, 0.6) 30%,
            rgba(0, 0, 0, 0.9) 100%
        );
        padding: 2rem 1.5rem 1.5rem;
        transform: translateY(0);
        transition: transform 0.3s ease;
    }

    .preview-content {
        color: #fff;
    }

    .preview-project-title {
        font-family: 'Manrope', var(--font-sans);
        font-size: 1.25rem;
        font-weight: 800;
        margin: 0 0 0.5rem 0;
        line-height: 1.2;
        color: #fff;
        text-transform: uppercase;
        letter-spacing: 0.02em;
    }

    .preview-project-desc {
        font-size: 0.9rem;
        opacity: 0.8;
        margin: 0 0 0.75rem 0;
        line-height: 1.4;
        font-family: 'Manrope', var(--font-sans);
        color: #fff;
        text-transform: uppercase;
        font-weight: 500;
        letter-spacing: 0.01em;
    }

    .preview-category {
        font-size: 0.8rem;
        color: #000;
        background: #fff;
        padding: 0.25rem 0.75rem;
        border-radius: 0;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        border: 1px solid #fff;
    }

    .portfolio-link-container {
        display: flex;
        justify-content: center;
        margin-top: 3rem;
    }

    .view-portfolio-btn {
        display: inline-block;
        padding: 1rem 2.5rem;
        font-size: 0.9rem;
        font-weight: 800;
        color: #fff;
        background: #A00000;
        border: 2px solid #A00000;
        text-decoration: none;
        transition: all 0.3s ease;
        font-family: 'Manrope', var(--font-sans);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        cursor: pointer;
    }

    .view-portfolio-btn:hover {
        background: transparent;
        color: #A00000;
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(160, 0, 0, 0.2);
    }

    @media (max-width: 768px) {
        .preview-grid {
            grid-template-columns: 1fr;
            gap: 1rem;
            padding: 0 0.5rem;
        }

        .preview-title {
            font-size: 1.5rem;
            margin-bottom: 1rem;
        }

        .preview-card {
            aspect-ratio: 16/10;
        }

        .preview-overlay {
            padding: 1.5rem 1rem 1rem;
        }

        .preview-project-title {
            font-size: 1.1rem;
        }

        .preview-project-desc {
            font-size: 0.85rem;
        }

        .preview-category {
            font-size: 0.75rem;
            padding: 0.2rem 0.6rem;
        }

        .portfolio-link-container {
            margin-top: 2rem;
        }

        .view-portfolio-btn {
            font-size: 0.8rem;
            padding: 0.8rem 2rem;
        }
    }

    @media (max-width: 480px) {
        .preview-grid {
            padding: 0;
        }

        .preview-card {
            border-radius: 8px;
        }
    }

    /* Grid variations based on toShow prop */
    .portfolio-preview[data-count="2"] .preview-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .portfolio-preview[data-count="4"] .preview-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    @media (min-width: 768px) {
        .portfolio-preview[data-count="4"] .preview-grid {
            grid-template-columns: repeat(4, 1fr);
        }
    }

    /* Compact version for smaller displays */
    .portfolio-preview.compact .preview-card {
        aspect-ratio: 3/2;
    }

    .portfolio-preview.compact .preview-overlay {
        padding: 1rem;
    }

    .portfolio-preview.compact .preview-project-title {
        font-size: 1rem;
    }

    .portfolio-preview.compact .preview-project-desc {
        font-size: 0.8rem;
    }
</style>

<script>
    // Add data attribute for CSS grid variations
    document.addEventListener('DOMContentLoaded', () => {
        const previews = document.querySelectorAll('.portfolio-preview');
        previews.forEach(preview => {
            const cardCount = preview.querySelectorAll('.preview-card').length;
            preview.setAttribute('data-count', cardCount.toString());
        });
    });
</script>