---
// ThreeDSection.astro
---

<section class="three-d-section">
    <div class="model-container">
        <model-viewer
            src="/models/Phone.glb"
            alt="Easy Logo 3D Model"
            auto-rotate
            camera-controls
            shadow-intensity="1"
            environment-image="neutral"
            exposure="1"
            shadow-softness="1"
            camera-orbit="0deg 75deg 105%"
            min-camera-orbit="auto auto auto"
            max-camera-orbit="auto auto 105%"
            interaction-prompt="none"
        >
        </model-viewer>
    </div>
</section>

<style>
    .three-d-section {
        width: 100%;
        height: 80vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: var(--site-bg);
        padding: 2rem 0;
    }

    .model-container {
        width: 100%;
        max-width: 1300px;
        height: 100%;
        margin: 0 auto;
        padding: 0 2rem;
    }

    model-viewer {
        width: 100%;
        height: 100%;
        --poster-color: transparent;
        --progress-bar-color: var(--brand-red);
        --progress-bar-height: 2px;
    }

    @media (max-width: 768px) {
        .three-d-section {
            height: 60vh;
        }

        .model-container {
            padding: 0 1rem;
        }
    }
</style>

<script>
    // Import model-viewer from CDN
    import '@google/model-viewer';
</script> 