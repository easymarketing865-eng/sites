---
/**
 * Showreel.astro
 * Modular homepage showreel section (brand background, hero image/video, quick facts)
 * Uses /photos/showreel.webp as the main visual.
 * Matches easy. production editorial/brand style.
 */
import AccentScript from "./AccentScript.astro";
import "../styles/global.css";
---

<script
    src="https://cdn.jsdelivr.net/npm/lite-youtube-embed@0.3.0/src/lite-yt-embed.js"
></script>
<link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/lite-youtube-embed@0.3.0/src/lite-yt-embed.css"
/>

<script>
    // Enhanced autoplay functionality
    document.addEventListener("DOMContentLoaded", function () {
        const liteYT = document.querySelector("lite-youtube");
        const fallbackVideo = document.querySelector(".fallback-video");

        // Check if we can use the fallback video
        function tryFallbackVideo() {
            if (
                fallbackVideo &&
                fallbackVideo.querySelector(
                    'source[src="/videos/showreel.mp4"]',
                )
            ) {
                // Check if video file exists
                fetch("/videos/showreel.mp4", { method: "HEAD" })
                    .then((response) => {
                        if (response.ok) {
                            liteYT.style.display = "none";
                            fallbackVideo.style.display = "block";
                            fallbackVideo
                                .play()
                                .catch((e) =>
                                    console.log("Fallback autoplay blocked"),
                                );
                        }
                    })
                    .catch(() => {
                        // Video file doesn't exist, use YouTube
                        useLiteYouTube();
                    });
            } else {
                useLiteYouTube();
            }
        }

        function useLiteYouTube() {
            if (liteYT) {
                // Mobile-specific autoplay attempt
                const isMobile =
                    /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(
                        navigator.userAgent,
                    );

                if (isMobile) {
                    // On mobile, try autoplay after a slight delay
                    setTimeout(() => {
                        try {
                            liteYT.click();
                        } catch (e) {
                            console.log(
                                "Mobile autoplay blocked by browser policy",
                            );
                        }
                    }, 500);
                } else {
                    // Desktop autoplay
                    setTimeout(() => {
                        try {
                            liteYT.click();
                        } catch (e) {
                            console.log(
                                "Desktop autoplay blocked by browser policy",
                            );
                        }
                    }, 1000);
                }

                // Add intersection observer for autoplay when in view
                const observer = new IntersectionObserver(
                    (entries) => {
                        entries.forEach((entry) => {
                            if (
                                entry.isIntersecting &&
                                entry.intersectionRatio > 0.5
                            ) {
                                try {
                                    // Only trigger if not already playing
                                    if (
                                        !liteYT.classList.contains(
                                            "lyt-activated",
                                        )
                                    ) {
                                        liteYT.click();
                                    }
                                } catch (e) {
                                    console.log("Autoplay on scroll blocked");
                                }
                            }
                        });
                    },
                    { threshold: 0.5 },
                );

                observer.observe(liteYT);
            }
        }

        // Try fallback first, then YouTube
        tryFallbackVideo();
    });
</script>

<section class="hero-section">
    <div class="hero-content">
        <div class="team-section">
            <div class="team-headshot">
                <img
                    src="/photos/headshot.webp"
                    alt="Our creative team"
                    class="headshot-image"
                    loading="eager"
                />
            </div>
            <div class="team-info">
                <h1
                    class="hero-headline"
                    style="color: #A00000; text-transform: uppercase; font-weight: 800;"
                >
                    easy creative studio
                </h1>
                <p class="team-description">
                    <span class="mobile-text"
                        >All-around video production studio.</span
                    >
                    <span class="desktop-text"
                        >All-around video production studio.<br />Get in touch
                        with us, or see our showreel below.</span
                    >
                </p>
                <div class="desktop-only">
                    <a href="#contact" class="cta-link">Get in touch →</a>
                </div>
            </div>
        </div>
        <div class="showreel-section">
            <div class="showreel-header">
                <h2 class="showreel-title">
                    <span class="mobile-title">Our Showreel</span>
                    <span class="desktop-title"
                        >Our Latest Work & Creative Projects</span
                    >
                </h2>
                <p class="showreel-subtitle desktop-only">
                    Check out some of our recent video productions, commercial
                    work, and creative collaborations.
                </p>
            </div>
            <div class="showreel-frame">
                <!-- Fallback HTML5 video for better autoplay support -->
                <video
                    class="fallback-video"
                    autoplay
                    muted
                    loop
                    playsinline
                    poster="https://i.ytimg.com/vi/6PsK4jTaKCA/maxresdefault.jpg"
                    style="display: none;"
                >
                    <source src="/videos/showreel.mp4" type="video/mp4" />
                    <source src="/videos/showreel.webm" type="video/webm" />
                </video>

                <lite-youtube
                    videoid="6PsK4jTaKCA"
                    class="showreel-video"
                    autoload
                    params="autoplay=1&mute=1&loop=1&controls=0&modestbranding=1&rel=0&playsinline=1"
                    playlabel="▶ Play our showreel video"
                    title="Easy Production Showreel - Video Production Studio"
                    style="background-image: url('https://i.ytimg.com/vi/6PsK4jTaKCA/maxresdefault.jpg');"
                ></lite-youtube>
            </div>
            <div class="team-stats">
                <div class="stat">
                    <span class="stat-number">50+</span>
                    <span class="stat-label">Projects Delivered</span>
                </div>
                <div class="stat">
                    <span class="stat-number">5+</span>
                    <span class="stat-label">Years Experience</span>
                </div>
                <div class="stat">
                    <span class="stat-number">20+</span>
                    <span class="stat-label">Happy Clients</span>
                </div>
                <div class="stat">
                    <span class="stat-number">3</span>
                    <span class="stat-label">Countries Served</span>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .hero-section {
        padding: 4rem 0;
        width: 100%;
        background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
    }

    .hero-content {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 4rem;
        align-items: start;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    /* Team Section */
    .team-section {
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .team-headshot {
        width: 100%;
        max-width: 500px;
        margin: 0 auto;
    }

    .headshot-image {
        width: 100%;
        height: auto;
        border-radius: 20px;
        object-fit: cover;
    }

    .team-info {
        text-align: left;
    }

    .hero-headline {
        font-size: 2.1rem;
        font-weight: 800;
        color: #222;
        margin: 0 0 1.5rem 0;
        line-height: 1.1;
    }

    .team-description {
        font-size: 1.1rem;
        line-height: 1.6;
        color: #666;
        margin: 0 0 2rem 0;
        max-width: 500px;
    }

    .mobile-text {
        display: none;
    }

    .desktop-text {
        display: block;
    }

    .team-stats {
        display: flex;
        gap: 3rem;
    }

    .stat {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .stat-number {
        font-size: 2.5rem;
        font-weight: 800;
        color: #000;
        line-height: 1;
    }

    .stat-label {
        font-size: 0.9rem;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-weight: 600;
    }

    /* Showreel Section */
    .showreel-section {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .showreel-header {
        text-align: left;
    }

    .showreel-title {
        font-size: 2rem;
        font-weight: 700;
        color: #222;
        margin: 0 0 1rem 0;
    }

    .mobile-title {
        display: none;
    }

    .desktop-title {
        display: block;
    }

    .showreel-subtitle {
        font-size: 1rem;
        color: #666;
        margin: 0 0 1rem 0;
        line-height: 1.5;
    }

    .desktop-only {
        display: block;
    }

    .cta-link {
        display: inline-block;
        color: #a00000;
        text-decoration: none;
        font-weight: 600;
        font-size: 1.1rem;
        padding: 0.75rem 1.5rem;
        border: 2px solid #a00000;
        border-radius: 8px;
        transition: all 0.3s ease;
        margin-top: 1rem;
    }

    .cta-link:hover {
        background-color: #a00000;
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(160, 0, 0, 0.3);
    }

    .showreel-frame {
        position: relative;
        width: 100%;
        aspect-ratio: 16 / 9;
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
        overflow: hidden;
        background: #eee;
    }

    @media (max-width: 768px) {
        .showreel-frame {
            box-shadow: none;
        }
    }

    .showreel-video,
    .fallback-video {
        width: 100%;
        height: 100%;
        border-radius: 20px;
        overflow: hidden;
        cursor: pointer;
        transition: transform 0.3s ease;
        object-fit: cover;
    }

    .showreel-video:hover,
    .fallback-video:hover {
        transform: scale(1.02);
    }

    /* Custom play button styling */
    .showreel-video::before {
        content: "";
        position: absolute;
        top: 50%;
        left: 50%;
        width: 80px;
        height: 80px;
        background: rgba(160, 0, 0, 0.9);
        border-radius: 50%;
        transform: translate(-50%, -50%);
        z-index: 2;
        transition: all 0.3s ease;
    }

    .showreel-video::after {
        content: "▶";
        position: absolute;
        top: 50%;
        left: 52%;
        transform: translate(-50%, -50%);
        color: white;
        font-size: 24px;
        z-index: 3;
        pointer-events: none;
    }

    .showreel-video:hover::before {
        background: rgba(160, 0, 0, 1);
        transform: translate(-50%, -50%) scale(1.1);
    }

    /* Hide custom play button when video is activated */
    .showreel-video.lyt-activated::before,
    .showreel-video.lyt-activated::after {
        display: none;
    }

    /* Mobile Responsive */
    @media (max-width: 768px) {
        .hero-content {
            grid-template-columns: 1fr;
            gap: 2rem;
            padding: 0 1rem;
        }

        .hero-section {
            padding: 2rem 0;
        }

        /* Reorder sections on mobile - showreel first */
        .showreel-section {
            /* order: 1; */
            gap: 1rem;
            /* margin-left: -8rem; */
            /* margin-right: 2rem; */
        }

        .team-section {
            /* order: 2; */
            margin-left: -8rem;
            gap: 0;
        }

        .team-info {
            margin-left: -5rem;
            margin-right: 4rem;
            margin-top: 2rem;
        }

        .showreel-header {
            text-align: center;
        }

        .showreel-title {
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
            color: #a00000;
            font-weight: 400;
            line-height: 1.2;
        }

        .mobile-title {
            display: block;
        }

        .desktop-title {
            display: none;
        }

        .desktop-only {
            display: none;
        }

        .hero-headline {
            font-size: 1.5rem;
            text-align: center;
        }

        .team-section {
            flex-direction: row;
        }

        .team-info {
            text-align: center;
        }

        .team-description {
            max-width: 100%;
            font-size: 1rem;
            margin-bottom: 1rem;
        }

        .mobile-text {
            display: block;
        }

        .desktop-text {
            display: none;
        }

        .team-stats {
            justify-content: center;
            gap: 2rem;
        }
    }

    @media (max-width: 480px) {
        .hero-section {
            padding: 1.5rem 0;
        }

        .hero-content {
            gap: 1.5rem;
        }

        .showreel-title {
            font-size: 1.1rem;
            margin-bottom: 0.3rem;
            color: #a00000;
            font-weight: 400;
        }

        .hero-headline {
            font-size: 1.2rem;
        }

        .team-description {
            font-size: 0.95rem;
            margin-bottom: 0.75rem;
        }

        .stat-number {
            font-size: 2rem;
        }

        .team-stats {
            gap: 1.5rem;
        }
    }
</style>
