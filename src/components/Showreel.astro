---
/**
 * Showreel.astro
 * Modular homepage showreel section (brand background, hero image/video, quick facts)
 * Uses /photos/showreel.webp as the main visual.
 * Matches easy. production editorial/brand style.
 */
import AccentScript from "./AccentScript.astro";
import "../styles/global.css";
import styles from "../styles/Showreel.module.css";
---

<section class={styles.showreelSection} id="showreel">
  <div class={styles.backgroundWords}>
    <AccentScript text="production · scriptwriting · editing · creativity · direction · filming · Kyrgyzstan · Dubai · brand · portfolio · storytelling ·" style="font-size:2.15rem;opacity:0.16;left:1em;top:.5em;position:relative;line-height:1.2;" />
  </div>
  <div class={styles.contentWrap}>
    <div class={styles.mediaBlock}>
      <img 
        src="/photos/showreel.webp" 
        alt="Showreel preview" 
        class={styles.showreelImg} 
        loading="lazy"
      />
      <!-- VIDEO-EMBED TODO: Replace img with <video> if showreel hosted -->
      <div class={styles.overlayAccent}>
        <AccentScript text="showreel" style="font-size:2.4em;opacity:.28;top:1.2em;left:1.1em;position:absolute;" />
      </div>
    </div>
    <div class={styles.quickFactsBlock}>
      <h2 class={styles.sectionTitle}>Showreel Highlights</h2>
      <ul class={styles.factsList}>
        <li>Shot on ARRI, RED & Drone</li>
        <li>Projects in Kyrgyzstan & Dubai</li>
        <li>Script-to-screen expertise</li>
        <li>Documentary & commercial styles</li>
        <li>International, scalable team</li>
      </ul>
    </div>
  </div>
</section>
