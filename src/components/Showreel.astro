---
/**
 * Showreel.astro
 * Simple fullwidth video with overlaid text
 */
import "../styles/global.css";
---

<section class="showreel-section">
  <div class="video-container">
    <video
      class="showreel-video"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
    >
      <source src="/video/EASY PRODUCTION SHOWREEL 2024.mp4" type="video/mp4" />
      Your browser does not support the video tag.
    </video>
    
    <div class="text-overlay">
      <div class="text-wrapper">
        <h1 class="studio-title">easy creative studio</h1>
      </div>
    </div>
  </div>
</section>

<style>
  .showreel-section {
    width: 100%;
    position: relative;
  }

  .video-container {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }

  .showreel-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .text-overlay {
    position: absolute;
    width: 100%;
    bottom: 60px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
  }

  .text-wrapper {
    
    mix-blend-mode: difference;
    padding: 0.5rem 2rem;
    display: inline-block;
    margin: 0 auto;
    width: auto;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
  }

  .studio-title {
    color: #fff;
    font-size: 3rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
    text-align: center;
    line-height: 1;
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .video-container {
      height: 70vh;
    }

    .text-overlay {
      bottom: 40px;
    }

    .studio-title {
      font-size: 2rem;
    }
  }

  @media (max-width: 480px) {
    .video-container {
      height: 60vh;
    }

    .text-overlay {
      bottom: 30px;
    }

    .studio-title {
      font-size: 1.5rem;
    }

    .text-wrapper {
      padding: 0.3rem 1.5rem;
    }
  }
</style>
