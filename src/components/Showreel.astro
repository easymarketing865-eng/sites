---
/**
 * Showreel.astro
 * Simple fullwidth video with overlaid text
 */
import "../styles/global.css";
import { content, files, pb } from "../lib/pocketbase.js";
import { t, getLocaleFromUrl } from "../lib/i18n.js";

export interface Props {
  locale?: string;
}

const { locale } = Astro.props;

// Get current locale from URL if not provided as prop
const currentLocale = locale || getLocaleFromUrl(Astro.url.pathname);

let showreelVideoUrl = null;
let hasVideo = false;

try {
  // Use unified page data for faster loading
  const pageData = await content.getPageData('home');
  if (pageData.showreelVideo && (pageData.showreelVideo as any).showreel) {
    showreelVideoUrl = pb.files.getURL(pageData.showreelVideo, (pageData.showreelVideo as any).showreel);
    hasVideo = true;
    console.log(`Loaded showreel video from unified page data: ${showreelVideoUrl}`);
  }
} catch (error) {
  console.log('PocketBase not available for showreel, video will not be displayed:', (error as Error).message);
}
---

<section class="showreel-section emerge" data-spin="true" data-spin-size="32" data-spin-color="white" data-effect="slide" data-up="40px">
  <div class="video-container">
    {hasVideo ? (
      <video
        class="showreel-video"
        preload="auto"
        autoplay
        muted
        loop
        playsinline
      >
        <source src={showreelVideoUrl} type="video/mp4" />
        Your browser does not support the video tag.
      </video>
    ) : (
      <div class="video-placeholder">
        <img src="/photos/showreel.webp" alt="Easy Production Showreel" class="placeholder-image" />
        <div class="placeholder-overlay">
          <h3>Showreel Coming Soon</h3>
          <p>Our latest work showcase will be available shortly</p>
        </div>
      </div>
    )}

    <!-- Hidden for now -->
    <div class="text-overlay" style="display: none;">
      <img src="/icons/easy-studio.svg" alt="Easy Creative Studio" class="studio-logo" />
    </div>

    <!-- Social buttons -->
    <div class="social-buttons-container">
      <!-- YouTube button -->
      <div class="youtube-button emerge" data-continue="true" data-hold="300" data-effect="slide" data-up="15px">
        <a href="https://www.youtube.com/watch?v=bKVk2B7qNn4" target="_blank" rel="noopener noreferrer" class="youtube-link">
          <svg class="youtube-icon" viewBox="0 0 24 24" fill="currentColor">
            <path d="M8 5v14l11-7z"/>
          </svg>
          <span>{t(currentLocale, 'showreel.watchYoutube')}</span>
        </a>
      </div>

      <!-- WhatsApp button -->
      <div class="contact-buttons emerge" data-continue="true" data-hold="300" data-effect="slide" data-up="15px">
        <a href="https://wa.me/+996502003162" target="_blank" rel="noopener noreferrer" class="contact-link whatsapp-link">
          <svg class="contact-icon" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.465 3.488"/>
          </svg>
          <span class="whatsapp-label">WhatsApp</span>
        </a>
      </div>
    </div>
  </div>
</section>

<div class="showreel-tagline emerge" data-effect="slide" data-up="20px" data-continue="true" data-expose="true">
  <p>{t(currentLocale, 'showreel.tagline')}</p>
</div>

<style>
  .showreel-section {
    margin-top: -150px;
    margin-bottom: 0;
    width: 100vw;
    position: relative;
    margin-left: calc(-50vw + 50%);
    margin-right: calc(-50vw + 50%);
    --mediaWidthRatio: 16;
    --mediaHeightRatio: 9;
    z-index: 1;
    overflow-x: hidden;
    max-width: 100vw;
  }

  .showreel-tagline {

    background: #8E0C12;
    color: var(--brand-white);
    padding: 2rem;
    text-align: left;
    width: 100vw;
    line-height: 1.2;
    margin-top: 0;
    margin-bottom: 0;
  }

  .showreel-tagline p {
    font-size: var(--text-title);
    font-weight: 800;
    line-height: var(--line-height-relaxed);
    margin: 0;
    max-width: 1200px;

  }

  .video-container {
    position: relative;
    width: 100%;
    max-height: 80vh;
    overflow: hidden;
  }

  .showreel-video {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
    aspect-ratio: var(--mediaWidthRatio) / var(--mediaHeightRatio);
    max-width: 100vw;
    z-index: -1;
    position: relative;
  }

  .text-overlay {
    position: absolute;
    top: 10%;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    text-align: center;
  }

  .studio-logo {
    width: auto;
    height: 74px;
  }

  .social-buttons-container {
    position: absolute;
    bottom: 20px;
    left: 40px;
    right: 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 10;
  }

  .youtube-button {
    height: 40px;
  }

  .youtube-link {
    height: 40px;
    display: flex;
    align-items: center;
    gap: 8px;
    background: white;
    color: black;
    padding: 12px 16px;
    border-radius: 3px;
    text-decoration: none;
    font-weight: 500;
    font-size: 20px;
    pointer-events: auto;
  }

  .youtube-link:hover {
    color: white;
    background: rgba(255, 0, 0, 1);
  }

  .youtube-icon {
    width: 30px;
    height: 30px;
  }

  .contact-buttons {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .contact-link {
    height: 40px;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    border-radius: 3px;
    text-decoration: none;
    font-weight: 500;
    font-size: 20px;
    pointer-events: auto;
    color: white;
  }

  .whatsapp-link {
    background: #1eaa52;
  }

  .whatsapp-link:hover {
    background: #128C7E;
  }

  .contact-icon {
    width: 20px;
    height: 20px;
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .showreel-section {
      --mediaWidthRatio: 4;
      --mediaHeightRatio: 5.32;
      margin-top: -90px;
    }

    .showreel-tagline {
      padding: 1.5rem 1rem;
    }

    .showreel-tagline p {
      font-size: 20px;
    }

    .social-buttons-container {
      bottom: 15px;
      left: 16px;
      right: 16px;
    }

    .youtube-link {
      padding: 10px 14px;
      font-size: 12px;
    }

    .youtube-icon {
      width: 18px;
      height: 18px;
    }

    .contact-link {
      padding: 10px 14px;
      font-size: 12px;
    }

    .contact-icon {
      width: 18px;
      height: 18px;
    }

    .studio-logo {
      height: 32px;
    }

    /* Hide WhatsApp label on mobile, keep YouTube label */
    .whatsapp-label {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .showreel-section {
      margin-top: -90px;
    }

    .showreel-tagline {
      padding: 1rem;
    }

    .social-buttons-container {
      bottom: 10px;
      left: 10px;
      right: 10px;
    }

    .youtube-link,
    .contact-link {
      width: fit-content;
      padding: 8px 12px;
      font-size: 18px;
    }

    .youtube-icon {
      width: 16px;
      height: 16px;
    }

    .contact-icon {
      width: 16px;
      height: 16px;
    }

    .studio-logo {
      height: 24px;
    }
  }

  /* Video Placeholder Styles */
  .video-placeholder {
    position: relative;
    width: 100%;
    height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #000;
    overflow: hidden;
  }

  .placeholder-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.6;
  }

  .placeholder-overlay {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    color: white;
    z-index: 2;
  }

  .placeholder-overlay h3 {
    font-size: 2rem;
    margin: 0 0 1rem 0;
    font-weight: 700;
  }

  .placeholder-overlay p {
    font-size: 1.1rem;
    margin: 0;
    opacity: 0.9;
  }

  @media (max-width: 768px) {
    .video-placeholder {
      height: 300px;
    }

    .placeholder-overlay h3 {
      font-size: 1.5rem;
    }

    .placeholder-overlay p {
      font-size: 1rem;
    }
  }
</style>
