---
/**
 * Showreel.astro
 * Simple fullwidth video with overlaid text
 */
import "../styles/global.css";
---

<section class="showreel-section">
  <div class="video-container">
    <video
      class="showreel-video"
      preload="auto"
      autoplay
      muted
      loop
      playsinline
    >
      <source src="/video/EASY PRODUCTION SHOWREEL 2024.mp4" type="video/mp4" />
      Your browser does not support the video tag.
    </video>
    
    <div class="text-overlay">
      <img src="/icons/easy-studio.svg" alt="Easy Creative Studio" class="studio-logo" />
    </div>
  </div>
</section>

<style>
  .showreel-section {
    margin-top: 40px;
    width: 100%;
    position: relative;
  }

  .video-container {
    position: relative;
    width: 100vw;
    height: 100vh;
    margin-left: calc(-50vw + 50%);
    margin-right: calc(-50vw + 50%);
  }

  .showreel-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .text-overlay {
    position: absolute;
    
    top: -3%;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    
    text-align: center;
  }

  .studio-logo {
    width: auto;
    height: 74px;
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .video-container {
      height: 70vh;
    }

    .studio-logo {
      height: 32px;
    }
  }

  @media (max-width: 480px) {
    .studio-logo {
      height: 24px;
    }
  }
</style>
