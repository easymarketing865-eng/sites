---
/**
 * Showreel.astro
 * Simple fullwidth video with overlaid text
 */
import "../styles/global.css";
---

<section class="showreel-section">
  <div class="video-container">
    <video
      class="showreel-video"
      preload="auto"
      autoplay
      muted
      loop
      playsinline
    >
      <source src="/video/EASY PRODUCTION SHOWREEL 2024.mp4" type="video/mp4" />
      Your browser does not support the video tag.
    </video>
    
    <!-- Hidden for now -->
    <div class="text-overlay" style="display: none;">
      <img src="/icons/easy-studio.svg" alt="Easy Creative Studio" class="studio-logo" />
    </div>

    <!-- YouTube button -->
    <div class="youtube-button">
      <a href="#" class="youtube-link">
        <svg class="youtube-icon" viewBox="0 0 24 24" fill="currentColor">
          <path d="M8 5v14l11-7z"/>
        </svg>
        Watch on YouTube
      </a>
    </div>
  </div>
</section>

<style>
  .showreel-section {
    margin-top: -95px;
    width: 100vw;
    position: relative;
    margin-left: calc(-50vw + 50%);
    margin-right: calc(-50vw + 50%);
    --mediaWidthRatio: 16;
    --mediaHeightRatio: 9;
    z-index: 1;
    overflow-x: hidden;
    max-width: 100vw;
  }

  .video-container {
    position: relative;
    width: 100%;
    max-height: 100vh;
    overflow: hidden;
  }

  .showreel-video {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
    aspect-ratio: var(--mediaWidthRatio) / var(--mediaHeightRatio);
    max-width: 100vw;
    z-index: -1;
    position: relative;
  }

  .text-overlay {
    position: absolute;
    top: 10%;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    text-align: center;
  }

  .studio-logo {
    width: auto;
    height: 74px;
  }

  .youtube-button {
    height: 40px;
    position: absolute;
    bottom: 20px;
    left: 2.5vw;

    z-index: 10;
  }

  .youtube-link {
    height: 40px;
    display: flex;
    align-items: center;
    gap: 2px;
    background: white;
    color: black;
    padding: 12px 16px;
    border-radius: 3px;
    text-decoration: none;
    font-weight: 500;
    font-size: 20px;
    
    
    pointer-events: auto;
  }

  .youtube-link:hover {
    color: white;
    background: rgba(255, 0, 0, 1);
   
  }

  .youtube-icon {
    width: 30px;
    height: 30px;
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .showreel-section {
      
      --mediaWidthRatio: 4;
      --mediaHeightRatio: 5.32;
      margin-top: -90px;
    }

    .youtube-button {
      bottom: 15px;
      left: 16px;
    }

    .youtube-link {
      padding: 10px 14px;
      font-size: 12px;
    }

    .youtube-icon {
      width: 18px;
      height: 18px;
    }

    .studio-logo {
      height: 32px;
    }
  }

  @media (max-width: 480px) {
    .showreel-section {
      margin-top: -90px;
    }

    .youtube-button {
      bottom: 10px;
      right: 10px;
    }

    .youtube-link {
      width: fit-content;
      padding: 8px 12px;
      font-size: 18px;
    }

    .youtube-icon {
      width: 16px;
      height: 16px;
    }

    .studio-logo {
      height: 24px;
    }
  }
</style>
