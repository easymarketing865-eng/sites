---
/**
 * TalkToUs2.astro
 * Alternative contact component with different visual approach
 */
import "../styles/global.css";
---

<section class="talk-to-us-2">
    <div class="talk-content">
        <h2 class="talk-headline">LET'S TALK</h2>
        <p class="talk-description">
            Choose your preferred way to connect.
        </p>

        <div class="contact-channels">
            <a
                href="https://wa.me/996555123456"
                class="channel whatsapp"
                target="_blank"
                rel="noopener"
            >
                <div class="channel-icon">
                    <svg
                        width="28"
                        height="28"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                    >
                        <path
                            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.89 3.495"
                        ></path>
                    </svg>
                </div>
                <div class="channel-info">
                    <span class="channel-name">WHATSAPP</span>
                    <span class="channel-action">MESSAGE US NOW</span>
                </div>
            </a>

            <a
                href="https://t.me/easyproductionkg"
                class="channel telegram"
                target="_blank"
                rel="noopener"
            >
                <div class="channel-icon">
                    <svg
                        width="28"
                        height="28"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                    >
                        <path
                            d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"
                        ></path>
                    </svg>
                </div>
                <div class="channel-info">
                    <span class="channel-name">TELEGRAM</span>
                    <span class="channel-action">CHAT INSTANTLY</span>
                </div>
            </a>

            <a href="mailto:hello@easy.production.kg" class="channel email">
                <div class="channel-icon">
                    <svg
                        width="28"
                        height="28"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                    >
                        <path
                            d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
                        ></path>
                    </svg>
                </div>
                <div class="channel-info">
                    <span class="channel-name">EMAIL</span>
                    <span class="channel-action">HELLO@EASY.PRODUCTION.KG</span>
                </div>
            </a>
        </div>
    </div>
</section>

<style>
    .talk-to-us-2 {
        padding: 2rem 2rem;
        background: #f5f5f5;
        width: 100%;
        margin: 0 auto;
    }

    .talk-content {
        max-width: 1200px;
        margin: 0 auto;
    }

    .talk-headline {
        font-family: "Manrope", var(--font-sans);
        font-size: 2.5rem;
        font-weight: 800;
        color: #a00000;
        margin: 0 0 1rem 0;
        line-height: 1.2;
        text-transform: uppercase;
        letter-spacing: 0.02em;
    }

    .talk-description {
        font-size: 1rem;
        line-height: 1.6;
        color: #000;
        margin: 0 0 2rem 0;
        max-width: 600px;
        text-transform: uppercase;
        font-weight: 500;
        letter-spacing: 0.02em;
    }

    .contact-channels {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .channel {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem;
        background: #fff;
        border: none;
        text-decoration: none;
        color: #000;
        transition: all 0.3s ease;
    }

    .channel:hover {
        background: #f0f0f0;
        color: #000;
    }

    .channel-icon {
        width: 48px;
        height: 48px;
        border: 2px solid #000;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: all 0.3s ease;
    }

    .channel:hover .channel-icon {
        border-color: currentColor;
    }

    .whatsapp .channel-icon {
        background: #25d366;
        border-color: #25d366;
        color: #fff;
    }

    .whatsapp:hover .channel-icon {
        background: #fff;
        color: #25d366;
        border-color: #25d366;
    }

    .telegram .channel-icon {
        background: #0088cc;
        border-color: #0088cc;
        color: #fff;
    }

    .telegram:hover .channel-icon {
        background: #fff;
        color: #0088cc;
        border-color: #0088cc;
    }

    .email .channel-icon {
        background: #a00000;
        border-color: #a00000;
        color: #fff;
    }

    .email:hover .channel-icon {
        background: #fff;
        color: #a00000;
        border-color: #a00000;
    }

    .channel-info {
        display: flex;
        flex-direction: column;
        text-align: left;
        flex: 1;
    }

    .channel-name {
        font-family: "Manrope", var(--font-sans);
        font-size: 1rem;
        font-weight: 800;
        color: inherit;
        text-transform: uppercase;
        letter-spacing: 0.02em;
    }

    .channel-action {
        font-size: 0.8rem;
        color: inherit;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.02em;
        opacity: 0.7;
    }

    @media (max-width: 768px) {
        .talk-to-us-2 {
            padding: 2rem 1rem;
        }

        .talk-headline {
            font-size: 1.8rem;
        }

        .talk-description {
            font-size: 0.9rem;
            margin-bottom: 1.5rem;
        }

        .contact-channels {
            grid-template-columns: 1fr 1fr 1fr;
            gap: 0.75rem;
        }

        .channel {
            padding: 0.75rem;
        }

        .channel-icon {
            width: 36px;
            height: 36px;
        }

        .channel-name {
            font-size: 0.8rem;
        }

        .channel-action {
            font-size: 0.7rem;
        }
    }

    @media (max-width: 480px) {
        .contact-channels {
            grid-template-columns: 1fr 1fr 1fr;
        }

        .channel {
            flex-direction: column;
            text-align: center;
            gap: 0.5rem;
            padding: 0.5rem;
        }

        .channel-info {
            text-align: center;
        }

        .channel-icon {
            width: 32px;
            height: 32px;
        }
    }
</style>