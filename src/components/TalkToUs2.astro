---
/**
 * TalkToUs2.astro
 * Alternative contact component with different visual approach
 */
import "../styles/global.css";
---

<section class="talk-to-us-2">
    <div class="talk-container">
        <div class="talk-header">
            <h2 class="talk-title">LET'S CREATE SOMETHING <span class="script">amazing</span> TOGETHER</h2>
            <p class="talk-subtitle">
                Your story deserves the perfect visual narrative. Choose your preferred way to connect and let's start crafting your vision.
            </p>
        </div>

        <div class="contact-grid">
            <div class="contact-card primary">
                <div class="card-header">
                    <div class="card-icon whatsapp-bg">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.89 3.495"></path>
                        </svg>
                    </div>
                    <div class="card-content">
                        <h3 class="card-title">WHATSAPP</h3>
                        <p class="card-description">Quick responses & real-time planning</p>
                    </div>
                </div>
                <a href="https://wa.me/996555123456" class="card-action" target="_blank" rel="noopener">
                    START CHAT
                </a>
            </div>

            <div class="contact-card">
                <div class="card-header">
                    <div class="card-icon telegram-bg">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"></path>
                        </svg>
                    </div>
                    <div class="card-content">
                        <h3 class="card-title">TELEGRAM</h3>
                        <p class="card-description">Professional communication</p>
                    </div>
                </div>
                <a href="https://t.me/easyproductionkg" class="card-action" target="_blank" rel="noopener">
                    SEND MESSAGE
                </a>
            </div>

            <div class="contact-card">
                <div class="card-header">
                    <div class="card-icon email-bg">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"></path>
                        </svg>
                    </div>
                    <div class="card-content">
                        <h3 class="card-title">EMAIL</h3>
                        <p class="card-description">Detailed project discussions</p>
                    </div>
                </div>
                <a href="mailto:hello@easy.production.kg" class="card-action">
                    WRITE EMAIL
                </a>
            </div>
        </div>

        <div class="response-info">
            <div class="response-badge">
                <span class="response-text">TYPICAL RESPONSE TIME: 15 MINUTES</span>
            </div>
        </div>
    </div>
</section>

<style>
    .talk-to-us-2 {
        padding: 4rem 2rem;
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        position: relative;
        overflow: hidden;
    }

    .talk-to-us-2::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23a00000' fill-opacity='0.02'%3E%3Ccircle cx='30' cy='30' r='1'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E") repeat;
        pointer-events: none;
    }

    .talk-container {
        max-width: 1200px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
    }

    .talk-header {
        text-align: center;
        margin-bottom: 3rem;
    }

    .talk-title {
        font-family: "Manrope", var(--font-sans);
        font-size: 2.8rem;
        font-weight: 900;
        color: #000;
        margin: 0 0 1.5rem 0;
        line-height: 1.2;
        text-transform: uppercase;
        letter-spacing: 0.02em;
    }

    .script {
        font-family: cursive;
        color: #a00000;
        text-transform: lowercase;
        font-weight: 400;
        font-style: italic;
        position: relative;
    }

    .script::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        right: 0;
        height: 2px;
        background: #a00000;
        transform: scaleX(0);
        animation: underlineGrow 1s ease-out 0.5s forwards;
    }

    @keyframes underlineGrow {
        to { transform: scaleX(1); }
    }

    .talk-subtitle {
        font-size: 1.1rem;
        line-height: 1.6;
        color: #333;
        margin: 0;
        max-width: 700px;
        margin: 0 auto;
        font-weight: 400;
    }

    .contact-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
        margin-bottom: 3rem;
    }

    .contact-card {
        background: #fff;
        border-radius: 1.5rem;
        padding: 2rem;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        transition: all 0.4s ease;
        position: relative;
        overflow: hidden;
    }

    .contact-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
        transition: left 0.5s ease;
    }

    .contact-card:hover::before {
        left: 100%;
    }

    .contact-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
    }

    .primary {
        border: 2px solid #a00000;
        background: linear-gradient(135deg, #fff 0%, #fef7f7 100%);
    }

    .card-header {
        display: flex;
        align-items: flex-start;
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .card-icon {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        flex-shrink: 0;
        position: relative;
        z-index: 2;
    }

    .whatsapp-bg {
        background: linear-gradient(135deg, #25d366 0%, #128c7e 100%);
    }

    .telegram-bg {
        background: linear-gradient(135deg, #0088cc 0%, #005577 100%);
    }

    .email-bg {
        background: linear-gradient(135deg, #a00000 0%, #700000 100%);
    }

    .card-content {
        flex: 1;
    }

    .card-title {
        font-family: "Manrope", var(--font-sans);
        font-size: 1.3rem;
        font-weight: 800;
        color: #000;
        margin: 0 0 0.5rem 0;
        text-transform: uppercase;
        letter-spacing: 0.02em;
    }

    .card-description {
        font-size: 0.95rem;
        color: #666;
        margin: 0;
        line-height: 1.4;
    }

    .card-action {
        display: inline-block;
        width: 100%;
        padding: 1rem 2rem;
        background: #000;
        color: #fff;
        text-decoration: none;
        text-align: center;
        border-radius: 0.8rem;
        font-family: "Manrope", var(--font-sans);
        font-weight: 700;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.02em;
        transition: all 0.3s ease;
        position: relative;
        z-index: 2;
    }

    .card-action:hover {
        background: #a00000;
        transform: translateY(-2px);
    }

    .primary .card-action {
        background: #a00000;
    }

    .primary .card-action:hover {
        background: #000;
    }

    .response-info {
        text-align: center;
    }

    .response-badge {
        display: inline-block;
        padding: 1rem 2rem;
        background: rgba(160, 0, 0, 0.1);
        border: 2px solid #a00000;
        border-radius: 2rem;
        position: relative;
        overflow: hidden;
    }

    .response-badge::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(160, 0, 0, 0.1), transparent);
        animation: shimmer 2s infinite;
    }

    @keyframes shimmer {
        0% { left: -100%; }
        100% { left: 100%; }
    }

    .response-text {
        font-family: "Manrope", var(--font-sans);
        font-size: 0.9rem;
        font-weight: 700;
        color: #a00000;
        text-transform: uppercase;
        letter-spacing: 0.02em;
        position: relative;
        z-index: 2;
    }

    @media (max-width: 768px) {
        .talk-to-us-2 {
            padding: 3rem 1rem;
        }

        .talk-title {
            font-size: 2rem;
        }

        .talk-subtitle {
            font-size: 1rem;
        }

        .contact-grid {
            grid-template-columns: 1fr;
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .contact-card {
            padding: 1.5rem;
        }

        .card-header {
            gap: 1rem;
        }

        .card-icon {
            width: 50px;
            height: 50px;
        }
    }

    @media (max-width: 480px) {
        .talk-title {
            font-size: 1.6rem;
        }

        .card-header {
            flex-direction: column;
            align-items: center;
            text-align: center;
            gap: 1rem;
        }

        .card-content {
            text-align: center;
        }

        .response-badge {
            padding: 0.8rem 1.5rem;
        }

        .response-text {
            font-size: 0.8rem;
        }
    }
</style>