---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FloatingContactButton from "../components/FloatingContactButton.astro";

export interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta
            name="description"
            content="Easy Production - Creative video production and marketing services"
        />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Onest:wght@400;500;600;700;800&display=swap"
            rel="stylesheet"
        />
        
        <!-- Emerge.js for page load animations -->
        <script src="/js/emerge.js"></script>
        <style>.emerge { opacity: 0; }</style>
    </head>
    <body>
        <article>
            <Header />
            <slot />
            <Footer />
        </article>
        <FloatingContactButton />
        
        <!-- Emerge Replay Button for Testing -->
        <button class="emerge-replay" style="position: fixed; top: 20px; right: 20px; z-index: 1000; background: #000; color: white; border: none; padding: 8px 12px; border-radius: 4px; cursor: pointer; font-size: 12px;">
            🔄 Replay
        </button>
    </body>
</html>

<style is:global>
    :root {
        --brand-red: rgb(160, 0, 0);
        --brand-black: #111111;
        --brand-bg: #f9f7f3;
        --brand-white: #fff;
        --brand-beige: #f9f7f3;
        --site-bg: #f1f3e8;
        --shadow: 0 4px 32px 0 #0002;

        --font-sans: "Onest", system-ui, sans-serif;
        --font-heading: "Onest", var(--font-sans);
        /* Mobile-first font sizes */
        --font-size-xl: clamp(2.5rem, 8vw, 5.5rem);
        --font-size-lg: clamp(1.5rem, 5vw, 2.625rem);
        --font-size-md: clamp(1.25rem, 4vw, 2rem);
        --font-size-base: clamp(0.875rem, 2.5vw, 1rem);
        --main-padding: clamp(0.75rem, 3vw, 1.5rem);
        --main-maxwidth: 1400px;
        --hero-head-size: clamp(2.05rem, 8vw, 3.3rem);
        --hero-tagline-size: clamp(1rem, 1.25vw, 1.11rem);
    }

    * {
        box-sizing: border-box;
    }

    html {
        font-family: var(--font-sans);
        background: var(--brand-white);
        font-size: var(--font-size-base);
    }

    body {
        margin: 0;
        padding: 0;
        min-height: 100vh;
        color: var(--brand-black);
        line-height: 1.5;
        display: flex;
        flex-direction: column;
    }

    /* Mobile-first responsive typography */
    h1,
    h2,
    h3,
    h4,
    h5,
    h6 {
        line-height: 1.2;
        margin: 0 0 1rem 0;
    }

    h1 {
        font-size: var(--font-size-xl);
        font-weight: 800;
    }

    h2 {
        font-size: var(--font-size-lg);
        font-weight: 700;
    }

    h3 {
        font-size: var(--font-size-md);
        font-weight: 600;
    }

    p {
        margin: 0 0 1rem 0;
        line-height: 1.6;
    }

    /* Mobile-first container */
    .container {
        width: 100%;
        max-width: var(--main-maxwidth);
        margin: 0 auto;
        padding: 0 var(--main-padding);
    }

    /* Mobile-first spacing */
    .section {
        padding: 2rem 0;
    }

    article {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: var(--main-padding);
        max-width: var(--main-maxwidth);
        margin: 0 auto;
    }

    /* Tablet and up */
    @media (min-width: 768px) {
        .section {
            padding: 3rem 0;
        }
    }

    /* Desktop and up */
    @media (min-width: 1024px) {
        body {
            line-height: 1.6;
        }

        .section {
            padding: 4rem 0;
        }
    }

    code {
        font-family:
            Menlo,
            Monaco,
            Lucida Console,
            Liberation Mono,
            DejaVu Sans Mono,
            Bitstream Vera Sans Mono,
            Courier New,
            monospace;
    }
</style>
