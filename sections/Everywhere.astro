---
import { t, getLocaleFromUrl } from "../src/lib/i18n.js";

export interface Props {
  locale?: string;
}

const { locale } = Astro.props;

// Get current locale from URL if not provided as prop
const currentLocale = locale || getLocaleFromUrl(Astro.url.pathname);
---

<style>
  .everywhere-section {
    padding: 6rem 2rem;
    background: #f8f6f3;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    font-family: 'Montserrat', sans-serif;
  }
  
  .everywhere-content {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }
  
  .everywhere-heading {
    font-size: 3.5rem;
    font-weight: 800;
    color: #000;
    margin-bottom: 3rem;
    letter-spacing: 0.02em;
  }
  
  .everywhere-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
    margin-top: 4rem;
  }
  
  .everywhere-item {
    background: #fff;
    padding: 2.5rem 2rem;
    border-radius: 1rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .everywhere-item:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  }
  
  .item-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #000;
    margin-bottom: 1rem;
  }
  
  .item-description {
    font-size: 1rem;
    line-height: 1.6;
    color: #666;
  }
  
  @media (max-width: 768px) {
    .everywhere-section {
      padding: 4rem 1rem;
    }
    
    .everywhere-heading {
      font-size: 2.5rem;
      margin-bottom: 2rem;
    }
    
    .everywhere-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
      margin-top: 2rem;
    }
    
    .everywhere-item {
      padding: 2rem 1.5rem;
    }
  }
  
  @media (min-width: 769px) and (max-width: 1024px) {
    .everywhere-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.5rem;
    }
  }
</style>

<section class="everywhere-section">
  <div class="everywhere-content">
    <h2 class="everywhere-heading">{t(currentLocale, 'everywhere.title')}</h2>
    
    <div class="everywhere-grid">
      <div class="everywhere-item">
        <h3 class="item-title">{t(currentLocale, 'everywhere.onsite.title')}</h3>
        <p class="item-description">
          {t(currentLocale, 'everywhere.onsite.description')}
        </p>
      </div>
      
      <div class="everywhere-item">
        <h3 class="item-title">{t(currentLocale, 'everywhere.remote.title')}</h3>
        <p class="item-description">
          {t(currentLocale, 'everywhere.remote.description')}
        </p>
      </div>
      
      <div class="everywhere-item">
        <h3 class="item-title">{t(currentLocale, 'everywhere.flyUsIn.title')}</h3>
        <p class="item-description">
          {t(currentLocale, 'everywhere.flyUsIn.description')}
        </p>
      </div>
    </div>
  </div>
</section>