---
export interface Props {}
---

<style>
  :root {
    --primary: #fff;
    --background: #f8f6f3;
    --text: #fff;
    --accent: #fff;
    --highlight-bg: #fff4f0;
    --table-bg: #fff;
    --table-alt-bg: #fdf2f2;
  }
  .exceptional-section {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    font-family: var(--font-sans);
    display: flex;
    flex-direction: column;
  }
  
  .exceptional-text-content {
    background: #285F73;
    padding: 6rem 2rem;
    color: var(--text);
  }
  
  .exceptional-bg-image {
    width: 100%;
    height: 100%;
  }
  
  .bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  
  .exceptional-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 3rem;
  }
  .exceptional-heading {
    font-size: 4rem; /* 64px */
    font-weight: 800;
    color: var(--primary);
    margin-bottom: 3rem;
    line-height: 1.2;
  }
  .narrative-block {

    margin-bottom: 2rem;
    line-height: 1.6;
    font-size: 1.125rem;
  }
  .comparison-container {
    overflow-x: auto;
    margin-bottom: 2rem;
  }
  .comparison-table {

    border-collapse: collapse;
  }
  .comparison-table td {
    padding: 0.5rem;
    text-align: left;
  }
  .comparison-table td:first-child {
    font-weight: 500;
  }
  .cta {

    margin-top: 4rem;
  }
  .btn-primary {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: #000;
    color: var(--accent);
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    transition: background 0.3s ease;
  }
  .btn-primary:hover {
    background: #800000;
  }
  @media (max-width: 768px) {
    .exceptional-section {
      width: 100vw;
      margin-left: calc(50% - 50vw);
      margin-right: calc(50% - 50vw);
    }
    .exceptional-text-content {
      padding: 3rem 1rem;
    }
    .exceptional-content {
      padding: 0 1rem;
    }
    .bg-img {
      height: 100%;
      min-height: 400px;
    }
    .exceptional-heading { 
      font-size: 2.5rem; 
      margin-bottom: 2rem;
    }
    .seasonal-content {
      gap: 8px;
    }
    .season-block {
      margin-bottom: 2rem;
    }

    .image-large,
    .image-small {
      flex: none;
      width: 100%;
    }
    .season-images img {
      max-height: 250px;
    }
    .season-title {
      font-size: 1.125rem;
      margin-bottom: 0.75rem;
    }
    .season-description { 
      font-size: 1rem; 
      margin-bottom: 1.5rem;
    }
    .value-proposition {
      margin-top: 3rem;
      font-size: 1rem;
    }
    .cta {
      margin-top: 2rem;
    }
    .showreel-video {
      margin-bottom: 2rem;
    }
    .showreel-video video {
      margin-bottom: 2rem !important;
    }
  }
  @media (min-width: 640px) and (max-width: 1024px) {
    .exceptional-section {
     
    }
    .exceptional-heading { font-size: 3rem; }
    .narrative-block { font-size: 1.125rem; }
  }
  @media (min-width: 1025px) {
    .exceptional-heading { font-size: 3.5rem; }
    .narrative-block { font-size: 1.25rem; }
  }

  .seasonal-content {
    display: flex;
    flex-direction: column;
    
  }

  .season-block {
    margin-bottom: 2rem;
  }

  .season-title {
    font-weight: 700;
    margin-bottom: 0.25rem;
    color: var(--primary);
    display: none;
  }

  .season-description {
    font-size: 1.25rem; /* 20px */
    line-height: 1.6;
    margin-bottom: 1rem;
    width: 80%;
  }

  .season-images {
    display: flex;
    gap: 8px;
    align-items: stretch;
  }

  .image-large {
    flex: 0 0 70%;
  }

  .image-small {
    flex: 0 0 30%;
  }

  .season-images img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    max-height: 400px;
  }

  .value-proposition {
    margin-top: 0rem;
    font-size: 1.25rem;
    line-height: 1.6;
    width: 85%;
  }

  .cta-text {
    margin-top: 0rem;
    font-weight: 600;
  }

  
</style>

<section class="exceptional-section">
  <div class="exceptional-text-content">
    <div class="exceptional-content">
      <h2 class="exceptional-heading">Every Season<br>New Story to Capture</h2>
      <div class="showreel-video">
        <video src="/video/kgshowreel.mp4" controls muted autoplay width="100%" style="margin-bottom: 2rem;"></video>
      </div>
      <div class="seasonal-content">
        <div class="season-block">
          <h3 class="season-title">Summer — Issyk-Kul, Lakes, Beaches</h3>
          <p class="season-description">
            <strong>Summer</strong> in Kyrgyzstan means crystal-clear lakes, golden beaches, and mountain sun. From aerials over Issyk-Kul to cinematic shots by the shoreline, we capture the warmth and energy of the season.
          </p>
          <div class="season-images">
            <div class="image-large">
              <img src="/photos/showreel.jpg" alt="Summer showreel" />
            </div>
            <div class="image-small">
              <img src="/photos/issyk-kol.jpg" alt="Summer Issyk-Kul" />
            </div>
          </div>
        </div>

        <div class="season-block">
          <h3 class="season-title">Winter — Mountains, Skiing, Snowy Landscapes</h3>
          <p class="season-description">
            <strong>Winter</strong> turns Kyrgyzstan into a snow-covered film set. From ski slopes to alpine forests, we shoot in high altitudes and extreme conditions to capture the magic of winter.
          </p>
          <div class="season-images">
            <div class="image-small">
              <img src="/photos/showreel.jpg" alt="Winter showreel" />
            </div>
            <div class="image-large">
              <img src="/photos/issyk-kol.jpg" alt="Winter Issyk-Kul" />
            </div>
          </div>
        </div>

        <div class="season-block">
          <h3 class="season-title">Autumn — Forests, Horses, Warm Colors</h3>
          <p class="season-description">
            <strong>Autumn</strong> brings rich color and timeless beauty. Rolling hills, horseback rides, and golden forests — it's the season for storytelling and soulful visuals.
          </p>
          <div class="season-images">
            <div class="image-large">
              <img src="/photos/showreel.jpg" alt="Autumn showreel" />
            </div>
            <div class="image-small">
              <img src="/photos/issyk-kol.jpg" alt="Autumn Issyk-Kul" />
            </div>
          </div>
        </div>

        <div class="season-block">
          <h3 class="season-title">Spring — Fresh Starts, New Beginnings</h3>
          <p class="season-description">
            <strong>Spring</strong> in Kyrgyzstan is a fresh start — nature awakens, and color returns. It's a perfect time to shoot branding stories, romantic scenes, or nature-focused visuals.
          </p>
          <div class="season-images">
            <div class="image-small">
              <img src="/photos/showreel.jpg" alt="Spring showreel" />
            </div>
            <div class="image-large">
              <img src="/photos/issyk-kol.jpg" alt="Spring Issyk-Kul" />
            </div>
          </div>
        </div>
      </div>

      <div class="value-proposition">
        <p>
          Producing in Dubai or Europe can cost you 3–5× more — and not always with better results. In Kyrgyzstan, you get cinematic landscapes, professional crews, and full-service production — without the inflated budgets.
        </p>
        <p class="cta-text">➡️ Want a comparison? Just ask — we'll show you the difference.</p>
      </div>

      <div class="cta">
        <a href="/contact" class="btn-primary">Get Your Custom Quote</a>
      </div>
    </div>
  </div>
  
  <div class="exceptional-bg-image">
    <img src="/photos/Exceptional-bg.jpg" alt="Exceptional value background" class="bg-img" />
  </div>
</section>