      font-size: 1rem; 
      margin-bottom: 1.5rem;
    }
    .value-proposition {
      margin-top: 3rem;
      font-size: 1rem;
    }
    .cta {
      margin-top: 2rem;
    }
    .showreel-video {
   
    
      margin-bottom: 2rem;
    }
