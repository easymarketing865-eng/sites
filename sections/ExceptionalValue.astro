---
export interface Props {}

import PortfolioPreviewGrid from "../src/components/PortfolioPreviewGrid.astro";
import { pb, files } from "../src/lib/pocketbase.js";

let serviceVideoUrl = "/video/kgshowreel.mp4"; // Fallback

try {
  // Try to fetch service showreel video from PocketBase service_showreel collection
  const result = await pb.collection('service_showreel').getList(1, 1);
  if (result && result.items && result.items.length > 0) {
    const serviceRecord = result.items[0];
    if ((serviceRecord as any).service_showreel) {
      serviceVideoUrl = pb.files.getURL(serviceRecord, (serviceRecord as any).service_showreel);
      console.log(`Loaded service showreel video from PocketBase: ${serviceVideoUrl}`);
    }
  }
} catch (error) {
  console.log('PocketBase not available for service showreel, using local video fallback:', (error as Error).message);
}
---

<style>
  :root {
    --primary: #fff;
    --background: #f8f6f3;
    --text: #fff;
    --accent: #fff;
    --highlight-bg: #fff4f0;
