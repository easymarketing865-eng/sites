---
import PortfolioPreviewGrid from "../src/components/PortfolioPreviewGrid.astro";
import { pb, files, content } from "../src/lib/pocketbase.js";
import { t, getLocaleFromUrl, getLocalizedPath } from "../src/lib/i18n.js";

export interface Props {
  locale?: string;
}

const { locale } = Astro.props;

// Get current locale from URL if not provided as prop
const currentLocale = locale || getLocaleFromUrl(Astro.url.pathname);

// Generate localized contact link
const contactLink = getLocalizedPath('/contact', currentLocale);

let serviceVideoUrl = "/video/kgshowreel.mp4"; // Fallback

try {
  // Use cached approach for service showreel
  const result = await pb.collection('service_showreel').getList(1, 1);
  if (result && result.items && result.items.length > 0) {
    const serviceRecord = result.items[0];
    if ((serviceRecord as any).service_showreel) {
      serviceVideoUrl = pb.files.getURL(serviceRecord, (serviceRecord as any).service_showreel);
      console.log(`Loaded service showreel video from PocketBase: ${serviceVideoUrl}`);
    }
  }
} catch (error) {
  console.log('PocketBase not available for service showreel, using local video fallback:', (error as Error).message);
}
---

<style>
  :root {
    --primary: #fff;
    --background: #f8f6f3;
    --text: #fff;
    --accent: #fff;
    --highlight-bg: #fff4f0;
    --table-bg: #fff;
    --table-alt-bg: #fdf2f2;
  }
  .exceptional-section {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    font-family: var(--font-sans);
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
    max-width: 100vw;
  }
  
  .exceptional-text-content {
    background: #285F73;
    padding: 6rem 2rem;
    color: var(--text);
  }
  
  .exceptional-bg-image {
    width: 100%;
    height: 100%;
  }
  
  .bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  
  .exceptional-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 3rem;
  }
  .exceptional-heading {
    font-size: 4rem; /* 64px */
    font-weight: 800;
    color: var(--primary);
    margin-bottom: 2rem;
    line-height: 1.2;
  }
  .narrative-block {
    margin-bottom: 2rem;
    line-height: 1.6;
    font-size: 1.125rem;
    font-weight: 500;
  }
  .comparison-container {
    overflow-x: auto;
    margin-bottom: 2rem;
  }
  .comparison-table {
    border-collapse: collapse;
  }
  .comparison-table td {
    padding: 0.5rem;
    text-align: left;
  }
  .comparison-table td:first-child {
    font-weight: 500;
  }
  .cta {
    margin-top: 4rem;
  }
  @media (max-width: 768px) {
    .exceptional-section {
      width: 100vw;
      margin-left: calc(50% - 50vw);
      margin-right: calc(50% - 50vw);
    }
    .exceptional-text-content {
      padding: 3rem 1rem;
    }
    .exceptional-content {
      padding: 0;
    }
    .bg-img {
      height: 100%;
      min-height: 400px;
    }
    .exceptional-heading { 
      font-size: 2.5rem; 
      margin-bottom: 2rem;
    }
    .seasonal-content {
      gap: 8px;
    }
    .season-block {
      margin-bottom: 2rem;
    }
    .image-large,
    .image-small {
      flex: none;
      width: 100%;
    }
    .season-images img {
      max-height: 250px;
    }
    .season-title {
      font-size: 1.125rem;
      margin-bottom: 0.75rem;
    }
    .season-description {
      width: 100% !important;
      font-size: 1rem; 
      margin-bottom: 1.5rem;
    }
    .value-proposition {
      margin-top: 3rem;
      font-size: 1rem;
    }
    .cta {
      margin-top: 2rem;
    }
    .showreel-video {
   
    
      margin-bottom: 2rem;
    }
    .showreel-video video {
      margin-bottom: 2rem !important;
    }
  }
  @media (min-width: 640px) and (max-width: 1024px) {
    .exceptional-heading { font-size: 3rem; }
    .narrative-block { font-size: 1.125rem; }
  }
  @media (min-width: 1025px) {
    .exceptional-heading { font-size: 3.5rem; }
    .narrative-block { font-size: 1.25rem; }
  }

  .seasonal-content {
    display: flex;
    flex-direction: column;
  }

  .season-block {
    margin-bottom: 2rem;
  }

  .season-title {
    font-weight: 700;
    margin-bottom: 0.25rem;
    color: var(--primary);
    display: none;
  }

  .season-description {
    font-size: var(--text-base); /* 20px */
    line-height: 1.6;
    margin-bottom: 1rem;
    width: 80%;
    font-weight: 500;
  }

  .season-images {
    display: flex;
    gap: 8px;
    align-items: stretch;
  }

  .image-large {
    flex: 0 0 65%;
  }

  .images-small {
    flex: 0 0 35%;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .image-small {
    flex: 1;
  }

  .season-images img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    max-height: 1000px;
  }

  .images-small .image-small img {
   ;
  }

  .value-proposition {
    margin-top: 0rem;
    font-size: 1.25rem;
    line-height: 1.6;
    width: 85%;
    font-weight: 500;
  }

  .cta-text {
    margin-top: 0rem;
    font-weight: 600;
  }

  .showreel-video {
    margin-bottom: 3rem;
  }
</style>

<section class="exceptional-section">
  <div class="exceptional-text-content">
    <div class="exceptional-content">
      <div class="showreel-video emerge" data-effect="zoom" data-scale="0.8" data-expose="true">
        <video src={serviceVideoUrl} controls muted autoplay loop width="100%"></video>
      </div>
      <h2 class="exceptional-heading emerge" data-effect="slide" data-up="50px" data-duration="700" data-continue="true" data-expose="true">{t(currentLocale, 'exceptional.title')}</h2>
      
      <div class="seasonal-content">
        <div class="season-block emerge" data-effect="slide" data-up="30px" data-continue="true" data-expose="true">
          <h3 class="season-title">{t(currentLocale, 'exceptional.summer.title')}</h3>
          <p class="season-description">
            {t(currentLocale, 'exceptional.summer.description')}
          </p>
          <div class="season-images emerge" data-effect="relax" data-continue="true" data-expose="true">
            <div class="image-large">
              <img src="/photos/1.jpg" alt="Main landscape" />
            </div>
            <div class="images-small">
              <div class="image-small">
                <img src="/photos/2.jpg" alt="Secondary view" />
              </div>
              <div class="image-small">
                <img src="/photos/3.jpg" alt="Third view" />
              </div>
            </div>
          </div>
        </div>

        <div class="season-block emerge" data-effect="slide" data-up="30px" data-continue="true" data-expose="true">
          <h3 class="season-title">{t(currentLocale, 'exceptional.winter.title')}</h3>
          <p class="season-description">
            {t(currentLocale, 'exceptional.winter.description')}
          </p>
        </div>

        <div class="season-block emerge" data-effect="slide" data-up="30px" data-continue="true" data-expose="true">
          <h3 class="season-title">{t(currentLocale, 'exceptional.autumn.title')}</h3>
          <p class="season-description">
            {t(currentLocale, 'exceptional.autumn.description')}
          </p>
        </div>

        <div class="season-block emerge" data-effect="slide" data-up="30px" data-continue="true" data-expose="true">
          <h3 class="season-title">{t(currentLocale, 'exceptional.valueProposition.title')}</h3>
          <p class="season-description">
            {t(currentLocale, 'exceptional.valueProposition.description')}
          </p>
          <p class="season-description cta-text">{t(currentLocale, 'exceptional.valueProposition.cta')}</p>
        </div>

      </div>

      <div class="cta">
        <a href={contactLink} class="btn btn-primary">{t(currentLocale, 'exceptional.button')}</a>
      </div>

      <!-- Portfolio Preview Grid -->
      <PortfolioPreviewGrid 
        startIndex={0} 
        toShow={4} 
        title={t(currentLocale, 'exceptional.portfolioTitle')}
        showTitle={true}
        className="exceptional-portfolio"
        locale={currentLocale}
      />
    </div>
  </div>
  
  <div class="exceptional-bg-image">
    <img src="/photos/Exceptional-bg.jpg" alt="Exceptional value background" class="bg-img" />
  </div>
</section>