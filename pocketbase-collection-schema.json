{
  "collections": [
    {
      "id": "projects_collection",
      "name": "projects",
      "type": "base",
      "system": false,
      "schema": [
        {
          "id": "title_field",
          "name": "title",
          "type": "text",
          "system": false,
          "required": true,
          "unique": false,
          "options": {
            "min": 1,
            "max": 200,
            "pattern": ""
          }
        },
        {
          "id": "slug_field",
          "name": "slug",
          "type": "text",
          "system": false,
          "required": true,
          "unique": true,
          "options": {
            "min": 1,
            "max": 100,
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          }
        },
        {
          "id": "year_field",
          "name": "year",
          "type": "text",
          "system": false,
          "required": true,
          "unique": false,
          "options": {
            "min": 4,
            "max": 4,
            "pattern": "^[0-9]{4}$"
          }
        },
        {
          "id": "featured_field",
          "name": "featured",
          "type": "bool",
          "system": false,
          "required": false,
          "unique": false,
          "options": {}
        },
        {
          "id": "hero_field",
          "name": "hero",
          "type": "url",
          "system": false,
          "required": true,
          "unique": false,
          "options": {
            "exceptDomains": [],
            "onlyDomains": []
          }
        },
        {
          "id": "videoid_field",
          "name": "videoId",
          "type": "text",
          "system": false,
          "required": true,
          "unique": false,
          "options": {
            "min": 1,
            "max": 50,
            "pattern": ""
          }
        },
        {
          "id": "video_thumbnail_field",
          "name": "videoThumbnail",
          "type": "url",
          "system": false,
          "required": false,
          "unique": false,
          "options": {
            "exceptDomains": [],
            "onlyDomains": []
          }
        },
        {
          "id": "description_field",
          "name": "description",
          "type": "editor",
          "system": false,
          "required": false,
          "unique": false,
          "options": {
            "convertUrls": false
          }
        },
        {
          "id": "short_description_field",
          "name": "shortDescription",
          "type": "text",
          "system": false,
          "required": false,
          "unique": false,
          "options": {
            "min": 0,
            "max": 300,
            "pattern": ""
          }
        },
        {
          "id": "category_field",
          "name": "category",
          "type": "select",
          "system": false,
          "required": false,
          "unique": false,
          "options": {
            "maxSelect": 1,
            "values": [
              "commercial",
              "fashion",
              "corporate",
              "music_video",
              "documentary",
              "animation",
              "real_estate",
              "other"
            ]
          }
        },
        {
          "id": "services_field",
          "name": "services",
          "type": "select",
          "system": false,
          "required": false,
          "unique": false,
          "options": {
            "maxSelect": 10,
            "values": [
              "video_production",
              "cinematography",
              "editing",
              "color_grading",
              "motion_graphics",
              "3d_animation",
              "sound_design",
              "music_composition",
              "drone_filming",
              "photography"
            ]
          }
        },
        {
          "id": "client_field",
          "name": "client",
          "type": "text",
          "system": false,
          "required": false,
          "unique": false,
          "options": {
            "min": 0,
            "max": 100,
            "pattern": ""
          }
        },
        {
          "id": "duration_field",
          "name": "duration",
          "type": "text",
          "system": false,
          "required": false,
          "unique": false,
          "options": {
            "min": 0,
            "max": 20,
            "pattern": ""
          }
        },
        {
          "id": "published_field",
          "name": "published",
          "type": "bool",
          "system": false,
          "required": false,
          "unique": false,
          "options": {}
        },
        {
          "id": "sort_order_field",
          "name": "sortOrder",
          "type": "number",
          "system": false,
          "required": false,
          "unique": false,
          "options": {
            "min": 0,
            "max": null,
            "noDecimal": true
          }
        },
        {
          "id": "gallery_field",
          "name": "gallery",
          "type": "file",
          "system": false,
          "required": false,
          "unique": false,
          "options": {
            "mimeTypes": [
              "image/jpeg",
              "image/png",
              "image/webp"
            ],
            "thumbs": [
              "100x100",
              "400x300",
              "800x600"
            ],
            "maxSelect": 20,
            "maxSize": 5242880,
            "protected": false
          }
        },
        {
          "id": "seo_title_field",
          "name": "seoTitle",
          "type": "text",
          "system": false,
          "required": false,
          "unique": false,
          "options": {
            "min": 0,
            "max": 60,
            "pattern": ""
          }
        },
        {
          "id": "seo_description_field",
          "name": "seoDescription",
          "type": "text",
          "system": false,
          "required": false,
          "unique": false,
          "options": {
            "min": 0,
            "max": 160,
            "pattern": ""
          }
        }
      ],
      "indexes": [
        "CREATE INDEX idx_projects_featured ON projects (featured)",
        "CREATE INDEX idx_projects_published ON projects (published)",
        "CREATE INDEX idx_projects_year ON projects (year)",
        "CREATE INDEX idx_projects_sort_order ON projects (sortOrder)"
      ],
      "listRule": "published = true || @request.auth.id != ''",
      "viewRule": "published = true || @request.auth.id != ''",
      "createRule": "@request.auth.id != ''",
      "updateRule": "@request.auth.id != ''",
      "deleteRule": "@request.auth.id != ''",
      "options": {}
    },
    {
