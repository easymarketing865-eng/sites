<file path="components/InstagramEmbedWrapper.tsx">
/**
 * InstagramEmbedWrapper.tsx
 * Renders the official Instagram embed HTML in a stable, styled container.
 */
import { JSX } from "preact";

interface InstagramEmbedWrapperProps {
  url: string;
  width?: number | string;
  height?: number | string;
  className?: string;
  style?: JSX.CSSProperties;
}

export default function InstagramEmbedWrapper({
  url,
  width = 400,
  height = 480,
  className = "",
  style = {},
}: InstagramEmbedWrapperProps) {
  // Instagram expects the blockquote to have a specific structure and script.
  // We use dangerouslySetInnerHTML to inject the embed code.
  const embedHtml = `
    <blockquote class="instagram-media" data-instgrm-permalink="${url}" data-instgrm-version="14" style="background:#FFF; border:0; border-radius:3px; box-shadow:0 0 1px 0 rgba(0,0,0,0.5),0 1px 10px 0 rgba(0,0,0,0.15); margin: 1px; max-width:658px; min-width:326px; padding:0; width:99.375%; width:-webkit-calc(100% - 2px); width:calc(100% - 2px);">
    </blockquote>
    <script async src="https://www.instagram.com/embed.js"></script>
  `;

  return (
    <div
      class={`ig-embed-wrapper ${className}`}
      style={{
        width: typeof width === "number" ? `${width}px` : width,
        height: typeof height === "number" ? `${height}px` : height,
        maxWidth: "100%",
        margin: "0 auto",
        overflow: "hidden",
        borderRadius: "12px",
        boxShadow: "0 2px 16px rgba(0,0,0,0.08)",
        background: "#fff",
        ...style,
        position: "relative",
      }}
    >
      <div
        style={{
          width: "100%",
          height: "100%",
        }}
        dangerouslySetInnerHTML={{ __html: embedHtml }}
      />
    </div>
  );
}
</file>

<file path="components/LiteYouTubeEmbedWrapper.tsx">
/**
 * LiteYouTubeEmbedWrapper.tsx
 * Renders a YouTube video using the lite-youtube-embed web component via CDN, with a stable container.
 * See: https://github.com/paulirish/lite-youtube-embed
 */
import { useEffect } from "preact/hooks";
import { JSX } from "preact";

interface LiteYouTubeEmbedWrapperProps {
  videoId: string;
  title?: string;
  width?: number | string;
  height?: number | string;
  className?: string;
  style?: JSX.CSSProperties;
}

export default function LiteYouTubeEmbedWrapper({
  videoId,
  title = "YouTube video",
  width = 560,
  height = 315,
  className = "",
  style = {},
}: LiteYouTubeEmbedWrapperProps) {
  // Inject the lite-youtube-embed script and CSS once on mount
  useEffect(() => {
    if (!document.querySelector('script[src*="lite-youtube-embed"]')) {
      const script = document.createElement("script");
      script.src = "https://cdn.jsdelivr.net/npm/lite-youtube-embed@0.2.0/src/lite-yt-embed.js";
      script.type = "module";
      document.body.appendChild(script);
    }
    if (!document.querySelector('link[href*="lite-yt-embed.css"]')) {
      const link = document.createElement("link");
      link.rel = "stylesheet";
      link.href = "https://cdn.jsdelivr.net/npm/lite-youtube-embed@0.2.0/src/lite-yt-embed.css";
      document.head.appendChild(link);
    }
  }, []);

  // Correctly escape double quotes in the title
  const safeTitle = title.replace(/"/g, "");
  const embedHtml = `
    <lite-youtube
      videoid="${videoId}"
      style="width:100%;height:100%;display:block;"
      title="${safeTitle}"
      params="controls=1&modestbranding=1"
    ></lite-youtube>
  `;

  return (
    <div
      class={`yt-embed-wrapper ${className}`}
      style={{
        width: typeof width === "number" ? `${width}px` : width,
        height: typeof height === "number" ? `${height}px` : height,
        maxWidth: "100%",
        margin: "0 auto",
        borderRadius: "12px",
        boxShadow: "0 2px 16px rgba(0,0,0,0.08)",
        background: "#000",
        overflow: "hidden",
        ...style,
        position: "relative",
      }}
    >
      <div
        style={{
          width: "100%",
          height: "100%",
        }}
        dangerouslySetInnerHTML={{ __html: embedHtml }}
      />
    </div>
  );
}
</file>

