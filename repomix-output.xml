<file path="islands/HeroFeatureIsland.tsx">
import { useEffect, useState } from "preact/hooks";
import { JSX } from "preact";

// Use 4 words for default, feel free to expand via props
const FEATURES = [
  "production?",
  "scouting?",
  "photoshoots?",
  "onsite?",
];

export default function HeroFeatureIsland(
  { features = FEATURES }: { features?: string[] }
): JSX.Element {
  const [featureIndex, setFeatureIndex] = useState(0);
  const [easyIndex, setEasyIndex] = useState(0);

  useEffect(() => {
    const featureTimer = setInterval(() => {
      setFeatureIndex((i) => (i + 1) % features.length);
    }, 1600);
    const easyTimer = setInterval(() => {
      setEasyIndex((i) => (i + 1) % features.length);
    }, 4500);
    return () => {
      clearInterval(featureTimer);
      clearInterval(easyTimer);
    };
  }, [features.length]);

  return (
    <div class="relative flex flex-col items-start justify-center w-full select-none" style={{height: '3.3rem', minWidth: '18rem', maxWidth: '100%'}}>
      <div
        class="absolute left-0 right-0 top-0 transition-transform duration-700 ease-in-out will-change-transform"
        style={{
          transform: `translateY(-${featureIndex * 2.8}rem)`,
        }}
      >
        {features.map((w, idx) => (
          <div
            class="flex items-end gap-3 h-11"
            style={{
              transition: "opacity 0.6s cubic-bezier(.4,1.2,.6,1)",
              opacity: featureIndex === idx ? 1 : 0.35,
            }}
            key={w}
          >
            <span class="text-2xl sm:text-3xl font-semibold uppercase tracking-wide text-black" style={{fontFamily:"Montserrat, sans-serif", letterSpacing: '0.08em'}}>
              {w}
            </span>
            <span
              class={`
                text-4xl sm:text-5xl font-extrabold uppercase transition-opacity
              `}
              style={{
                fontFamily: "Montserrat, sans-serif",
                color: "#A00000",
                opacity: easyIndex === idx ? 1 : 0.13,
                transition: "opacity 2.6s cubic-bezier(.6,1.3,0.7,0.9)"
              }}
              aria-label="EASY"
            >
              EASY
            </span>
          </div>
        ))}
      </div>
    </div>
  );
}
